---
import { getSortedAnnouncements } from '../data/announcements';

const items = getSortedAnnouncements();
const doubled = [...items, ...items];

const categoryColors: Record<string, string> = {
  admission:     "bg-blue-500",
  exam:          "bg-amber-500",
  recruitment:   "bg-green-600",
  event:         "bg-purple-500",
  result:        "bg-rose-500",
  scholarship:   "bg-teal-500",
  accreditation: "bg-indigo-500",
  general:       "bg-gray-500",
};
---

<div class="bg-primary text-white border-b border-primary/80 w-full overflow-hidden">
  <div class="flex items-stretch min-h-[38px]">
    <!-- Label -->
    <div class="flex-shrink-0 flex items-center gap-1.5 px-3 py-1.5 bg-white/10 border-r border-white/20 text-sm font-semibold tracking-wide whitespace-nowrap select-none">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
      </svg>
      <span class="hidden sm:inline">Announcements</span>
      <span class="sm:hidden">News</span>
    </div>

    <!-- Scrolling track -->
    <div
      id="ticker-viewport"
      class="flex-1 overflow-hidden relative flex items-center"
    >
      <div id="ticker-track" class="animate-marquee flex items-center whitespace-nowrap">
        {doubled.map((ann, idx) => (
          <span class="flex items-center">
            <span class="mx-3 opacity-40 select-none" aria-hidden="true">|</span>
            {ann.isNew && (
              <span class="mr-1.5 inline-flex items-center rounded-sm bg-white/20 px-1 py-px text-[10px] font-bold uppercase tracking-wider border border-white/30">NEW</span>
            )}
            <span
              class={`mr-1.5 inline-block h-2 w-2 rounded-full flex-shrink-0 opacity-80 ${categoryColors[ann.category] ?? "bg-gray-400"}`}
              aria-hidden="true"
            ></span>
            {ann.hasDetailPage ? (
              <a
                href={`/announcements/${ann.slug}`}
                class="text-sm text-white/95 hover:text-white hover:underline underline-offset-2 transition-colors"
                tabindex={idx >= items.length ? -1 : 0}
                aria-hidden={idx >= items.length ? "true" : "false"}
              >
                {ann.title}
              </a>
            ) : (
              <span class="text-sm text-white/90">{ann.title}</span>
            )}
            <span class="ml-2 text-xs text-white/60 flex-shrink-0">({ann.date})</span>
          </span>
        ))}
      </div>
    </div>

    <!-- View All -->
    <div class="flex-shrink-0 flex items-center px-3 border-l border-white/20 bg-white/10">
      <a href="/announcements" class="text-xs font-semibold text-white/90 hover:text-white whitespace-nowrap hover:underline underline-offset-2 transition-colors">
        View All
      </a>
    </div>
  </div>
</div>

<script>
  const track = document.getElementById("ticker-track");
  const viewport = document.getElementById("ticker-viewport");
  viewport?.addEventListener("mouseenter", () => {
    if (track) track.style.animationPlayState = "paused";
  });
  viewport?.addEventListener("mouseleave", () => {
    if (track) track.style.animationPlayState = "running";
  });
</script>
