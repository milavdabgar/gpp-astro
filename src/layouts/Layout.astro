---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Government Polytechnic Palanpur - Premier Engineering Education",
  description = "Government Polytechnic Palanpur - AICTE approved institution offering diploma programs in Civil, Electrical, Mechanical, Electronics, ICT and IT Engineering. Over 40 years of excellence."
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <slot />
  </body>
</html>
