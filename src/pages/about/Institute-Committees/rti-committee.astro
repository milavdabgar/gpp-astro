---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import AnnouncementTicker from '../../../components/AnnouncementTicker.astro';

const officers = [
  { role: "First Appellate Authority", name: "Principal, GPP Palanpur", contact: "principal@gpp.edu.in" },
  { role: "Public Information Officer (PIO)", name: "Vice Principal / Senior Admin Officer", contact: "pio@gpp.edu.in" },
  { role: "Assistant Public Information Officer (APIO)", name: "Administrative Staff (designated)", contact: "admin@gpp.edu.in" },
];

const process = [
  { step: "1", title: "Submit Application", desc: "Write to the PIO with your RTI request along with ₹10 application fee (DD/IPO/cash)." },
  { step: "2", title: "Acknowledgement", desc: "PIO acknowledges receipt within 5 working days." },
  { step: "3", title: "Information Provided", desc: "Information is provided within 30 days of receipt (48 hours if life/liberty is concerned)." },
  { step: "4", title: "First Appeal", desc: "If unsatisfied, appeal to the First Appellate Authority within 30 days." },
  { step: "5", title: "Second Appeal", desc: "Further appeal to the Gujarat Information Commission within 90 days." },
];

const disclosures = [
  "Organization, functions and duties of GPP",
  "Powers and duties of faculty and staff",
  "Rules, regulations, and policies followed",
  "Approved budget and expenditure",
  "Admission norms and fee structure",
  "List of students and faculty",
  "Minutes of governing body meetings (non-confidential)",
];
---

<Layout title="RTI Committee | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/about/committees" class="hover:text-primary transition-colors">Institute Committees</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">RTI Committee</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Right to Information Act, 2005</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">RTI Committee</h1>
      <p class="text-lg text-gray-600 max-w-2xl">Government Polytechnic Palanpur is committed to transparency and proactive disclosure under the RTI Act, 2005.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">RTI Officers</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {officers.map(o => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="text-xs font-semibold text-primary bg-primary/10 rounded-full px-3 py-1 inline-block mb-3">{o.role}</div>
            <h3 class="font-bold text-gray-900 mb-1">{o.name}</h3>
            <a href={`mailto:${o.contact}`} class="text-sm text-primary underline">{o.contact}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">RTI Application Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        {process.map(p => (
          <div class="bg-white rounded-xl p-5 border border-gray-100 text-center">
            <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white font-bold mx-auto mb-3">{p.step}</div>
            <h3 class="font-bold text-gray-900 text-sm mb-2">{p.title}</h3>
            <p class="text-gray-600 text-xs">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Proactive Disclosures (Section 4)</h2>
      <p class="text-gray-600 mb-5">The following categories of information are proactively disclosed by GPP as required under Section 4 of the RTI Act:</p>
      <ul class="space-y-2">
        {disclosures.map(d => (
          <li class="flex items-start gap-3 text-gray-700">
            <div class="w-5 h-5 bg-primary/10 rounded flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            {d}
          </li>
        ))}
      </ul>
      <div class="mt-6">
        <a href="/legal/rti" class="text-primary font-semibold underline text-sm">View RTI Documents &rarr;</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
