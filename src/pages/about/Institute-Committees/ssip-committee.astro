---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import AnnouncementTicker from '../../../components/AnnouncementTicker.astro';

const members = [
  { role: "Chairperson", name: "Principal, GPP Palanpur", department: "Administration" },
  { role: "SSIP Coordinator", name: "Senior Faculty (nominated)", department: "Innovation Cell" },
  { role: "Faculty Member", name: "Nominated Faculty", department: "EC Engineering" },
  { role: "Faculty Member", name: "Nominated Faculty", department: "Mechanical Engineering" },
  { role: "Faculty Member", name: "Nominated Faculty", department: "Computer Engineering" },
  { role: "Student Representative", name: "Student nominee", department: "Student Body" },
  { role: "Industry Expert", name: "External mentor", department: "Industry" },
];

const activities = [
  { title: "Idea Submission Drive", desc: "Biannual campaigns to collect student and faculty innovation ideas for SSIP funding." },
  { title: "Project Evaluation", desc: "Committee reviews submitted ideas and recommends projects for SSIP seed grants." },
  { title: "Mentorship Matching", desc: "Connecting approved SSIP projects with internal faculty and external industry mentors." },
  { title: "Progress Reviews", desc: "Quarterly reviews of ongoing SSIP projects to track milestones and fund utilisation." },
  { title: "SSIP Exhibition", desc: "Annual event showcasing SSIP projects to students, faculty, and industry visitors." },
  { title: "State-Level Reporting", desc: "Reporting project outcomes and fund utilisation to i-Hub/GTU SSIP portal." },
];

const funding = [
  { category: "Student Innovation Project", max: "₹2,00,000", eligibility: "Student teams with faculty mentor" },
  { category: "startup/Entrepreneurship", max: "₹2,00,000", eligibility: "Students with viable startup ideas" },
  { category: "Faculty Research Support", max: "₹1,00,000", eligibility: "Faculty with applied R&D proposal" },
];
---

<Layout title="SSIP Committee | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/about/committees" class="hover:text-primary transition-colors">Institute Committees</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">SSIP Committee</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Govt. of Gujarat Initiative</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">SSIP Committee</h1>
      <p class="text-lg text-gray-600 max-w-2xl">The institutional committee that manages the Student Startup and Innovation Policy (SSIP) at GPP — approving projects, disbursing funds, and overseeing outcomes.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About SSIP at GPP</h2>
      <p class="text-gray-700 text-lg leading-relaxed mb-4">The Student Startup and Innovation Policy (SSIP) is a flagship initiative of the Government of Gujarat to foster an innovation and entrepreneurship culture in academic institutions. GPP's SSIP Committee is the institutional body responsible for implementing SSIP activities, reviewing project applications, and managing fund disbursements.</p>
      <p class="text-gray-700 text-lg leading-relaxed">Students and faculty with innovative ideas can apply for grants of up to ₹2 lakh. The committee meets regularly to evaluate proposals and monitor projects.</p>
    </div>
  </section>

  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Funding Categories</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Category</th>
              <th class="px-5 py-3 font-semibold">Maximum Grant</th>
              <th class="px-5 py-3 font-semibold">Eligibility</th>
            </tr>
          </thead>
          <tbody>
            {funding.map((f, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">{f.category}</td>
                <td class="px-5 py-3 text-green-700 font-semibold">{f.max}</td>
                <td class="px-5 py-3 text-gray-600">{f.eligibility}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Committee Activities</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {activities.map(a => (
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-2">{a.title}</h3>
            <p class="text-gray-600 text-sm">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Committee Members</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Role</th>
              <th class="px-5 py-3 font-semibold">Name / Designation</th>
              <th class="px-5 py-3 font-semibold">Department</th>
            </tr>
          </thead>
          <tbody>
            {members.map((m, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">{m.role}</td>
                <td class="px-5 py-3 text-gray-700">{m.name}</td>
                <td class="px-5 py-3 text-gray-600">{m.department}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Apply for SSIP Funding</h2>
      <p class="text-gray-600 mb-6">Have an innovation idea? Submit your SSIP project proposal to the committee through the Innovation Cell.</p>
      <a href="/ssip" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Learn More About SSIP</a>
    </div>
  </section>

  <Footer />
</Layout>
