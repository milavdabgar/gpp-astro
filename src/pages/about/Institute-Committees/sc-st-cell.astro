---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import AnnouncementTicker from '../../../components/AnnouncementTicker.astro';

const members = [
  { role: "Liaison Officer", name: "SC/ST Faculty (nominated by Principal)", department: "Faculty" },
  { role: "Member", name: "SC/ST Faculty Member", department: "Faculty" },
  { role: "Member", name: "Administrative Staff", department: "Administration" },
  { role: "Student Representative", name: "SC/ST Student Representative", department: "Student Body" },
];

const services = [
  { title: "Scholarship Assistance", desc: "Guidance on Post-Matric Scholarships, National Scholarship Portal (NSP), and state government scholarship schemes for SC/ST students." },
  { title: "Reservation Compliance", desc: "Ensuring AICTE-mandated reservations in admissions are followed across all diploma programmes." },
  { title: "Grievance Redressal", desc: "Addressing caste-based discrimination, harassment, or unfair treatment of SC/ST students and staff." },
  { title: "Awareness Programmes", desc: "Conducting sessions on constitutional rights, available schemes, and career opportunities for SC/ST students." },
  { title: "Remedial Classes", desc: "Coordinating extra academic support for SC/ST students who may need additional assistance." },
  { title: "Liaison with Government", desc: "Coordinating with district Social Welfare Office and other government bodies for welfare schemes." },
];
---

<Layout title="SC/ST Cell | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/about/committees" class="hover:text-primary transition-colors">Institute Committees</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">SC/ST Cell</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Student Welfare</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">SC/ST Cell</h1>
      <p class="text-lg text-gray-600 max-w-2xl">Ensuring equal opportunity, welfare, and protection of rights for Scheduled Caste and Scheduled Tribe students and staff at GPP.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About the SC/ST Cell</h2>
      <p class="text-gray-700 text-lg leading-relaxed">The SC/ST Cell at GPP is constituted as per AICTE guidelines to safeguard the interests of Scheduled Caste and Scheduled Tribe students and staff. The cell ensures reservation norms are followed, welfare schemes are accessible, and any form of discrimination is addressed promptly and fairly.</p>
    </div>
  </section>

  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Services & Activities</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(s => (
          <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Cell Members</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Role</th>
              <th class="px-5 py-3 font-semibold">Name / Designation</th>
              <th class="px-5 py-3 font-semibold">Department</th>
            </tr>
          </thead>
          <tbody>
            {members.map((m, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">{m.role}</td>
                <td class="px-5 py-3 text-gray-700">{m.name}</td>
                <td class="px-5 py-3 text-gray-600">{m.department}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 bg-primary/5 rounded-xl p-5 border border-primary/20">
        <p class="text-gray-700 text-sm">For assistance or to report discrimination, contact the SC/ST Cell Liaison Officer or the Principal's office at GPP Palanpur.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
