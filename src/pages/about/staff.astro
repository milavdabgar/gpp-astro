---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

// Staff data from GTU Affiliation Document 2026-27
const teachingStaffSummary = {
  permanent: 63,
  proTerm: 1,
  total: 64,
  permanentPct: 98.44,
};

const vacancyHistory = [
  { role: "Director / Principal",  sanctioned: 1,  vacant2122: 1, vacant2223: 1, vacant2324: 1 },
  { role: "Head Of Department",    sanctioned: 6,  vacant2122: 2, vacant2223: 3, vacant2324: 3 },
  { role: "Lecturer",              sanctioned: 76, vacant2122: 34, vacant2223: 34, vacant2324: 14 },
];

const nonTeachingTechnical = [
  { id: 1, name: "Prakashji Navghanji Thakor",    designation: "Instructor Grade B", category: "SEBC", dateJoined: "4 Sep 2025",   type: "Regular" },
  { id: 2, name: "Acharya Minal Devendrkumar",     designation: "Lab Assistant",      category: "GEN",  dateJoined: "11 Aug 1998",  type: "Regular" },
  { id: 3, name: "Kathrotiya Rameshbhai Bhemjibhai",designation: "Lab Assistant",     category: "SEBC", dateJoined: "13 Dec 2013",  type: "Regular" },
  { id: 4, name: "Nehal Prafulbhai Jethva",        designation: "Lab Assistant",      category: "SEBC", dateJoined: "13 Dec 2013",  type: "Regular" },
  { id: 5, name: "Vasimkhan Sikanderkhan Sama",    designation: "Lab Assistant",      category: "GEN",  dateJoined: "12 Jan 2015",  type: "Regular" },
];

const nonTeachingSupporting = [
  { id: 1,  name: "Chauhan Lallubhai Rupabhai",          designation: "Peon / Hamal",  category: "ST",   dateJoined: "24 Apr 1990",  type: "Regular" },
  { id: 2,  name: "Goswami Dattagiri Bhanugiri",         designation: "Peon / Hamal",  category: "SEBC", dateJoined: "11 Aug 1997",  type: "Regular" },
  { id: 3,  name: "Kharodiya Ibrahimbhai Pirabhbhai",    designation: "Store Keeper",  category: "GEN",  dateJoined: "8 May 1995",   type: "Regular" },
  { id: 4,  name: "Vishnuprasad Amolbhai Trivedi",       designation: "Gardener",      category: "GEN",  dateJoined: "7 Jun 1991",   type: "Regular" },
  { id: 5,  name: "Chauhan Nirav Mafatlal",              designation: "Sr. Clerk",     category: "SEBC", dateJoined: "22 May 2017",  type: "Regular" },
  { id: 6,  name: "Raval Bhaveshkumar Natvarlal",        designation: "Librarian",     category: "SEBC", dateJoined: "14 Jul 2017",  type: "Regular" },
  { id: 7,  name: "Kailashben Bhagvanbhai Desai",        designation: "Sr. Clerk",     category: "SEBC", dateJoined: "16 May 2017",  type: "Regular" },
  { id: 8,  name: "Maheshkumar Bhavanbhai Valagot",      designation: "Head Clerk",    category: "SEBC", dateJoined: "27 Aug 2013",  type: "Regular" },
  { id: 9,  name: "Parmar Chimanbhai Ramjibhai",         designation: "Peon",          category: "SC",   dateJoined: "1 Jun 1967",   type: "Regular" },
  { id: 10, name: "Varshaben Premjibhai Patel",          designation: "Sr. Clerk",     category: "GEN",  dateJoined: "30 Jun 2026",  type: "Regular" },
];

const studentTeacherRatio = { students: 689, teachers: 64, ratio: 10, supportTeachers: 15, supportRatio: 46 };

const aiCertificate = { completed: 10, total: 64, remaining: 54, deadline: "31 December 2026" };

const catBadge: Record<string, string> = {
  GEN:  "bg-gray-100 text-gray-700",
  SEBC: "bg-blue-100 text-blue-700",
  ST:   "bg-amber-100 text-amber-700",
  SC:   "bg-purple-100 text-purple-700",
};
---

<Layout title="Staff Details | About | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span>About</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Staff Details</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-slate-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-slate-100 text-slate-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        GTU Affiliation 2026-27 — Verified Data
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Staff Details</h1>
      <p class="text-gray-600 text-lg">
        GPP Palanpur is staffed by {teachingStaffSummary.total} qualified teaching faculty and {nonTeachingTechnical.length + nonTeachingSupporting.length} support staff, maintaining a {studentTeacherRatio.ratio}:1 student-teacher ratio.
      </p>
    </div>
  </section>

  <!-- Quick stats -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto text-center">
        <div>
          <div class="text-3xl font-bold text-primary">{teachingStaffSummary.total}</div>
          <div class="text-sm font-semibold text-gray-900">Teaching Faculty</div>
          <div class="text-xs text-gray-500">{teachingStaffSummary.permanentPct}% permanent</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{nonTeachingTechnical.length}</div>
          <div class="text-sm font-semibold text-gray-900">Technical Staff</div>
          <div class="text-xs text-gray-500">Lab assistants + instructor</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{nonTeachingSupporting.length}</div>
          <div class="text-sm font-semibold text-gray-900">Support Staff</div>
          <div class="text-xs text-gray-500">Clerks, peons, others</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{studentTeacherRatio.ratio}:1</div>
          <div class="text-sm font-semibold text-gray-900">Student:Teacher</div>
          <div class="text-xs text-gray-500">{studentTeacherRatio.students} students</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Teaching Staff Summary -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Teaching Staff Summary</h2>
      <div class="grid md:grid-cols-2 gap-5">
        <!-- Composition card -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <h3 class="font-semibold text-gray-800 mb-4">Staff Composition</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-700">Permanent Faculty</span>
              <div class="flex items-center gap-2">
                <div class="w-32 bg-gray-100 rounded-full h-2">
                  <div class="bg-primary rounded-full h-2" style={`width:${teachingStaffSummary.permanentPct}%`}></div>
                </div>
                <span class="text-sm font-bold text-primary w-8">{teachingStaffSummary.permanent}</span>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-700">Pro-term Faculty</span>
              <div class="flex items-center gap-2">
                <div class="w-32 bg-gray-100 rounded-full h-2">
                  <div class="bg-orange-400 rounded-full h-2" style="width:1.56%"></div>
                </div>
                <span class="text-sm font-bold text-orange-500 w-8">{teachingStaffSummary.proTerm}</span>
              </div>
            </div>
            <div class="border-t border-gray-100 pt-3 flex justify-between">
              <span class="font-semibold text-gray-900">Total</span>
              <span class="font-bold text-primary">{teachingStaffSummary.total}</span>
            </div>
          </div>
        </div>

        <!-- S:T Ratio card -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <h3 class="font-semibold text-gray-800 mb-4">Students–Teachers Ratio</h3>
          <div class="space-y-4">
            <div class="bg-primary/5 border border-primary/20 rounded-xl p-4">
              <div class="text-xs text-gray-500 font-medium mb-1">Teaching Staff Ratio</div>
              <div class="text-3xl font-bold text-primary">{studentTeacherRatio.ratio}:1</div>
              <div class="text-xs text-gray-500 mt-1">{studentTeacherRatio.students} students ÷ {studentTeacherRatio.teachers} faculty</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs text-gray-500 font-medium mb-1">Supporting Staff Ratio</div>
              <div class="text-3xl font-bold text-gray-700">{studentTeacherRatio.supportRatio}:1</div>
              <div class="text-xs text-gray-500 mt-1">{studentTeacherRatio.students} students ÷ {studentTeacherRatio.supportTeachers} support staff</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vacancy History -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Faculty Position History</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border border-gray-200">
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Category</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Sanctioned</th>
              <th class="text-right px-4 py-3 font-semibold text-amber-700 border-r border-gray-200">Vacant 2021-22</th>
              <th class="text-right px-4 py-3 font-semibold text-amber-700 border-r border-gray-200">Vacant 2022-23</th>
              <th class="text-right px-4 py-3 font-semibold text-emerald-700">Vacant 2023-24</th>
            </tr>
          </thead>
          <tbody>
            {vacancyHistory.map((r, i) => (
              <tr class={`border border-gray-200 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                <td class="px-4 py-3 border-r border-gray-200 font-medium text-gray-900">{r.role}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-right font-mono">{r.sanctioned}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-right text-amber-700 font-semibold">{r.vacant2122}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-right text-amber-700 font-semibold">{r.vacant2223}</td>
                <td class={`px-4 py-3 text-right font-semibold ${r.vacant2324 <= r.vacant2223 ? 'text-emerald-700' : 'text-red-600'}`}>{r.vacant2324}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2">Source: GTU Affiliation Application 2026-27 — Lecturer vacancies reduced from 34 to 14 between 2021-22 and 2023-24.</p>
    </div>
  </section>

  <!-- Non-Teaching Technical Staff -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Non-Teaching Technical Staff</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border border-gray-200">
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">#</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Name</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Designation</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Category</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Date of Joining</th>
            </tr>
          </thead>
          <tbody>
            {nonTeachingTechnical.map((s, i) => (
              <tr class={`border border-gray-200 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-400 font-mono text-xs">{s.id}</td>
                <td class="px-4 py-3 border-r border-gray-200 font-medium text-gray-900">{s.name}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-600">{s.designation}</td>
                <td class="px-4 py-3 border-r border-gray-200">
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${catBadge[s.category]}`}>{s.category}</span>
                </td>
                <td class="px-4 py-3 text-gray-500">{s.dateJoined}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Supporting Staff -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Non-Teaching Supporting Staff</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-gray-50 border border-gray-200">
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">#</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Name</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Designation</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Category</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Date of Joining</th>
            </tr>
          </thead>
          <tbody>
            {nonTeachingSupporting.map((s, i) => (
              <tr class={`border border-gray-200 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-400 font-mono text-xs">{s.id}</td>
                <td class="px-4 py-3 border-r border-gray-200 font-medium text-gray-900">{s.name}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-600">{s.designation}</td>
                <td class="px-4 py-3 border-r border-gray-200">
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${catBadge[s.category]}`}>{s.category}</span>
                </td>
                <td class="px-4 py-3 text-gray-500">{s.dateJoined}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- AI Certificate Compliance -->
  <section class="py-8 bg-amber-50 border-t border-amber-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="flex flex-col md:flex-row items-start md:items-center gap-5">
        <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-amber-900 text-lg mb-1">AI Certificate Course Compliance</h3>
          <p class="text-sm text-amber-800">As per GTU Circular no. GTU/Academic/AI-Certification/2025/7889 (dated 13 Oct 2025), all regular faculty must complete the mandatory Artificial Intelligence Certificate Course.</p>
          <div class="flex flex-wrap gap-4 mt-3">
            <div class="bg-emerald-100 border border-emerald-200 rounded-lg px-3 py-2 text-center">
              <div class="text-xl font-bold text-emerald-700">{aiCertificate.completed}</div>
              <div class="text-xs text-emerald-600">Completed</div>
            </div>
            <div class="bg-amber-100 border border-amber-200 rounded-lg px-3 py-2 text-center">
              <div class="text-xl font-bold text-amber-700">{aiCertificate.remaining}</div>
              <div class="text-xs text-amber-600">Remaining</div>
            </div>
            <div class="bg-white border border-amber-200 rounded-lg px-3 py-2 text-center">
              <div class="text-xl font-bold text-gray-700">{aiCertificate.total}</div>
              <div class="text-xs text-gray-500">Total Faculty</div>
            </div>
          </div>
          <p class="text-xs text-amber-700 mt-2">Deadline for remaining {aiCertificate.remaining} faculty: <strong>{aiCertificate.deadline}</strong></p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
