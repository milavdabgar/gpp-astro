---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const labs = [
  {
    name: "Modern Workshop — Bosch Sponsored",
    department: "Mechanical Engineering",
    partner: "Bosch India Foundation",
    year: "2022",
    description:
      "Equipped with Bosch-powered tools and modern CNC machining equipment to provide students with hands-on industrial machining experience. The lab bridges the gap between academic learning and industrial manufacturing practices.",
    features: [
      "CNC Turning & Milling Machines",
      "Bosch Power Tools",
      "Precision Measurement Instruments",
      "Industry-standard CAD/CAM integration",
    ],
    color: "blue",
  },
  {
    name: "Electrical Machines & Drives Lab",
    department: "Electrical Engineering",
    partner: "Industry Collaboration",
    year: "2021",
    description:
      "A state-of-the-art lab for studying AC/DC machine characteristics, drives, and power electronics. Equipped with modern variable-frequency drives and energy measurement systems.",
    features: [
      "3-Phase Induction Motors (VFD-controlled)",
      "DC Shunt & Series Machines",
      "Power Quality Analyzers",
      "SCADA-based monitoring systems",
    ],
    color: "green",
  },
  {
    name: "Embedded Systems & IoT Lab",
    department: "Electronics & Communication Engineering",
    partner: "Industry Collaboration",
    year: "2023",
    description:
      "A dedicated lab for hands-on learning in embedded systems design, microcontrollers, and IoT applications. Students work on real-world projects including smart agriculture and industrial automation.",
    features: [
      "Arduino, Raspberry Pi & ESP32 platforms",
      "IoT Cloud connectivity modules",
      "Sensor arrays (soil, temperature, proximity)",
      "PCB Design & Fabrication setup",
    ],
    color: "orange",
  },
  {
    name: "Computer Networks Lab",
    department: "Computer Engineering / IT",
    partner: "Industry Collaboration",
    year: "2020",
    description:
      "Fully equipped networking lab for practical learning of LAN, WAN, and network security configurations. Features Cisco packet-tracer setups and live network infrastructure simulation.",
    features: [
      "Cisco Managed Switches & Routers",
      "Network Simulation Software",
      "Firewall & Security Appliances",
      "Fiber optic & structured cabling",
    ],
    color: "purple",
  },
];

const stats = [
  { label: "Active Labs", value: "4+" },
  { label: "Industry Partners", value: "3+" },
  { label: "Students Trained", value: "1000+" },
  { label: "Investment (Lakhs)", value: "30+" },
];

const colorMap: Record<string, { border: string; bg: string; badge: string }> = {
  blue:   { border: "border-blue-300",   bg: "bg-blue-50",   badge: "bg-blue-100 text-blue-700" },
  green:  { border: "border-green-300",  bg: "bg-green-50",  badge: "bg-green-100 text-green-700" },
  orange: { border: "border-orange-300", bg: "bg-orange-50", badge: "bg-orange-100 text-orange-700" },
  purple: { border: "border-purple-300", bg: "bg-purple-50", badge: "bg-purple-100 text-purple-700" },
};
---

<Layout title="Industry Sponsored Labs | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Industry Sponsored Labs</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Industry Sponsored Labs</h1>
      <p class="text-lg text-gray-600">Bridging academic learning with real-world industrial applications through strategic partnerships and modern infrastructure.</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((s) => (
          <div>
            <div class="text-3xl font-extrabold text-white">{s.value}</div>
            <div class="text-blue-200 text-sm mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">About Industry Sponsored Labs</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        Industry Sponsored Labs at Government Polytechnic Palanpur represent strategic partnerships between leading industrial organizations and our institution. These collaborations bring cutting-edge technology, practical training, and real-world experience directly to our students and faculty.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Our industry partners invest in state-of-the-art equipment, provide expert training, and offer mentorship to ensure our graduates are industry-ready professionals equipped with the latest skills and knowledge demanded by the market.
      </p>
    </div>
  </section>

  <!-- Lab Cards -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        {labs.map((lab) => {
          const c = colorMap[lab.color] || colorMap.blue;
          return (
            <div class={`bg-white rounded-xl border ${c.border} shadow-sm overflow-hidden`}>
              <div class={`${c.bg} px-6 py-5 border-b ${c.border}`}>
                <div class="flex flex-wrap items-start gap-2 mb-2">
                  <span class={`text-xs font-semibold rounded-full px-3 py-1 ${c.badge}`}>{lab.department}</span>
                  <span class="text-xs bg-gray-100 text-gray-600 rounded-full px-3 py-1">Est. {lab.year}</span>
                </div>
                <h3 class="text-lg font-bold text-gray-900">{lab.name}</h3>
                <p class="text-sm text-gray-500 mt-1">Partner: <span class="font-medium text-gray-700">{lab.partner}</span></p>
              </div>
              <div class="px-6 py-5">
                <p class="text-gray-600 text-sm mb-4 leading-relaxed">{lab.description}</p>
                <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2">Key Features</h4>
                <ul class="space-y-1">
                  {lab.features.map((f) => (
                    <li class="flex items-start gap-2 text-sm text-gray-700">
                      <svg class="h-4 w-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Partner CTA -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Partner with GPP</h2>
      <p class="text-gray-600 mb-6">
        Interested in establishing an industry-sponsored lab at Government Polytechnic Palanpur? We welcome collaborations with industries to enhance student learning and develop industry-ready graduates.
      </p>
      <a href="/contact" class="bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Contact Us</a>
    </div>
  </section>

  <Footer />
</Layout>
