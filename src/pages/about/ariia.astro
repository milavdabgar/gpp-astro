---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const ariaParameters = [
  {
    name: "Budget under IP/Innovation/Startups Activity",
    weight: "15%",
    desc: "Total budget allocated specifically for IP creation, innovation activities, and startup support.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 8v1m-3-5h6m-9 5h12",
  },
  {
    name: "IPR/Patent/Startup Output",
    weight: "25%",
    desc: "Filed/published/granted patents, trademark registrations, copyrights, and startups supported.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
  {
    name: "Innovation Ecosystem Support",
    weight: "25%",
    desc: "Incubation centers, MoUs, technology transfer, entrepreneurship development programs.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    name: "Promotion and Support",
    weight: "35%",
    desc: "Awareness activities, mentoring, funding support, awards and recognition for student innovators.",
    icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
  },
];

const gppInnovationHighlights = [
  { label: "SSIP Cell", desc: "Active Student Startup and Innovation Policy cell with dedicated faculty mentors and annual budget." },
  { label: "Prototype Lab", desc: "Innovation lab where students develop physical prototypes and implement their project ideas." },
  { label: "Industry MoUs", desc: "Collaborations with industry partners for mentoring students and providing project resources." },
  { label: "SSIP Grants", desc: "Students receive financial grants through SSIP for startup and innovation project development." },
];

const submissionHistory = [
  { year: "2024", status: "submitted" },
  { year: "2023", status: "submitted" },
  { year: "2022", status: "submitted" },
];
---

<Layout title="ARIIA Ranking | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-orange-500 to-amber-600 py-16 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white border border-white/30">
        Innovation Ranking Framework
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">ARIIA Ranking</h1>
      <p class="text-xl text-orange-100 max-w-2xl mx-auto">
        Atal Ranking of Institutions on Innovation Achievements (ARIIA) — assessing Government Polytechnic Palanpur
        on its innovation, entrepreneurship, and IP generation activities.
      </p>
    </div>
  </section>

  <!-- About ARIIA -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is ARIIA?</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Atal Ranking of Institutions on Innovation Achievements (ARIIA) is an initiative by the Ministry of
            Education (MoE), Government of India to systematically rank higher educational institutions and
            universities primarily on innovation-related indicators.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            ARIIA is managed by Innovation Cell, MoE and All India Council for Technical Education (AICTE),
            and ranks institutions based on their innovation outputs, IPR filing, startup support, and
            ecosystem building.
          </p>
          <p class="text-gray-600 leading-relaxed">
            All technical institutions including polytechnics are encouraged to participate to benchmark
            themselves and improve their innovation ecosystem.
          </p>
          <a
            href="https://ariia.gov.in/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-orange-500 text-white rounded-lg font-medium hover:bg-orange-600 transition-colors text-sm"
          >
            Visit ARIIA Portal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-gray-900">GPP's Innovation Strengths</h3>
          {gppInnovationHighlights.map((h) => (
            <div class="bg-orange-50 rounded-xl border border-orange-200 p-5">
              <h4 class="font-bold text-orange-900 mb-1">{h.label}</h4>
              <p class="text-sm text-orange-800">{h.desc}</p>
            </div>
          ))}
          <div class="text-sm text-gray-500 pt-2">
            More about our innovation activities: <a href="/ssip" class="text-primary underline hover:text-primary/80">SSIP Cell →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Parameters -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">ARIIA Evaluation Parameters</h2>
      <div class="grid md:grid-cols-2 gap-5">
        {ariaParameters.map((p) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <div class="flex items-center gap-3 mb-3">
              <div class="p-2 rounded-lg bg-orange-50">
                <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={p.icon}/>
                </svg>
              </div>
              <span class="text-xl font-bold text-orange-500">{p.weight}</span>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{p.name}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Submission History -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">ARIIA Submission History</h2>
      <div class="space-y-3">
        {submissionHistory.map((r) => (
          <div class="flex items-center justify-between p-4 rounded-xl border border-gray-200 bg-gray-50">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-orange-400"></span>
              <span class="font-semibold text-gray-800">ARIIA {r.year}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-700">Submitted</span>
              <span class="text-xs text-gray-400 italic">Available on ARIIA portal</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 text-center text-sm text-gray-500">
        Visit the official
        <a href="https://ariia.gov.in/" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-primary/80">ARIIA portal</a>
        for detailed rankings and scores.
      </div>
    </div>
  </section>

  <Footer />
</Layout>
