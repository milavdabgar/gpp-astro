---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const milestones = [
  {
    year: "1984",
    title: "Establishment",
    description: "Government Polytechnic Palanpur was established by the Department of Technical Education, Government of Gujarat, to provide quality technical education to the youth of Banaskantha district and surrounding regions.",
    highlight: true,
  },
  {
    year: "1984",
    title: "First Programs Launched",
    description: "The institute started with three diploma programs: Civil Engineering, Electrical Engineering, and Mechanical Engineering, with an initial intake of students from across North Gujarat.",
    highlight: false,
  },
  {
    year: "1990s",
    title: "Infrastructure Growth",
    description: "Significant expansion of academic buildings, laboratories, workshops, and hostel facilities. The campus spread across 20+ acres near Malan Gate on Ambaji Road, Palanpur.",
    highlight: false,
  },
  {
    year: "2008",
    title: "GTU Affiliation",
    description: "Government Polytechnic Palanpur was affiliated with the newly formed Gujarat Technological University (GTU), Ahmedabad. Affiliation No.: GTU/INST_AFFI/626/2012-13/677.",
    highlight: true,
  },
  {
    year: "2013",
    title: "Electronics & Communication Engineering",
    description: "The Electronics & Communication Engineering program was introduced, responding to growing demand for skilled professionals in the electronics and telecom sector.",
    highlight: false,
  },
  {
    year: "2018",
    title: "Computer Engineering Program",
    description: "Computer Engineering department established with an intake of 60 students, addressing the rapid growth of the IT industry and the need for computer science professionals in the region.",
    highlight: false,
  },
  {
    year: "2020",
    title: "Information Technology Program",
    description: "Information Technology program added with an intake of 30 students, broadening the institute's offerings in the digital and software space.",
    highlight: false,
  },
  {
    year: "2022",
    title: "SSIP Recognition",
    description: "GPP became an active participant in the Student Startup and Innovation Policy (SSIP) initiated by the Government of Gujarat, fostering innovation and entrepreneurship among students.",
    highlight: false,
  },
  {
    year: "2024",
    title: "NBA Accreditation",
    description: "Three programs — Civil Engineering, Electrical Engineering, and Mechanical Engineering — received NBA (National Board of Accreditation) accreditation, valid from July 2024 to June 2027, a landmark achievement in academic quality.",
    highlight: true,
  },
];

const stats = [
  { label: "Year Established", value: "1984" },
  { label: "Programs Offered", value: "6" },
  { label: "Total Intake", value: "330" },
  { label: "Campus Area", value: "20+ Acres" },
];
---

<Layout title="History | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">History</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">History of GPP</h1>
      <p class="text-lg text-gray-600">Four decades of excellence in technical education, shaping engineers who serve the nation</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{stat.value}</div>
            <div class="text-sm mt-1 text-white/80">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About the Institute -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About Government Polytechnic Palanpur</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-4">
        <p>
          Government Polytechnic Palanpur (GPP) is a premier government technical institute located in Palanpur, the administrative headquarters of Banaskantha district in North Gujarat, India. Established in 1984 by the Department of Technical Education, Government of Gujarat, GPP has been at the forefront of providing quality technical education to the youth of the region.
        </p>
        <p>
          The institute is affiliated with Gujarat Technological University (GTU), Ahmedabad, and is situated on a sprawling 20+ acre campus outside Malan Gate on the Ambaji Road, Palanpur. Over the decades, GPP has grown from a modest institution offering three diploma programs to a multi-disciplinary polytechnic offering six programs with a combined annual intake of 330 students.
        </p>
        <p>
          GPP has consistently maintained high academic standards and is committed to the holistic development of students through education, research, innovation, and extracurricular activities. The institute actively participates in government initiatives such as SSIP and has earned NBA accreditation for three of its programs.
        </p>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">Our Journey Through the Years</h2>
      <div class="space-y-6">
        {milestones.map((m) => (
          <div class={`flex gap-6 rounded-xl p-6 border-l-4 bg-white shadow-sm ${m.highlight ? 'border-primary' : 'border-primary/30'}`}>
            <div class="flex-shrink-0">
              <div class={`w-16 h-16 rounded-full flex items-center justify-center text-sm font-bold text-white ${m.highlight ? 'bg-primary' : 'bg-primary/60'}`}>
                {m.year.length <= 5 ? m.year : m.year.slice(0,4)}
              </div>
            </div>
            <div>
              <div class="text-xs font-bold text-primary uppercase tracking-wide mb-1">{m.year}</div>
              <h3 class="font-bold text-gray-900 text-lg mb-2">{m.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{m.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Legacy CTA -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="bg-gradient-to-r from-primary/5 to-blue-50 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Carrying the Legacy Forward</h2>
        <p class="text-gray-700 text-lg leading-relaxed max-w-2xl mx-auto">
          For over four decades, Government Polytechnic Palanpur has been shaping the careers of thousands of engineers from Banaskantha and beyond. Our alumni serve across industries, government bodies, and academic institutions.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/about" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">
            About GPP
          </a>
          <a href="/about/principal" class="border border-primary text-primary px-6 py-3 rounded-lg font-semibold hover:bg-primary/5 transition-colors">
            Principal's Message
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
