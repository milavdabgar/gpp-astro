---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
---

<Layout title="Vision & Mission | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Vision & Mission</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Vision & Mission</h1>
      <p class="text-lg text-gray-600">The guiding principles behind everything we do at Government Polytechnic Palanpur</p>
    </div>
  </section>

  <!-- Vision -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row gap-8 items-start mb-16">
          <div class="flex-shrink-0">
            <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </div>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Vision</h2>
            <blockquote class="text-xl text-primary font-semibold border-l-4 border-primary pl-6 mb-6 italic">
              "To be a centre of excellence in technical education, producing competent and ethical diploma engineers who contribute to the technological and socio-economic development of the nation."
            </blockquote>
            <p class="text-gray-600 leading-relaxed">
              Government Polytechnic Palanpur envisions becoming a premier institution in Gujarat that nurtures technical talent from the Banaskantha region and beyond. We strive to bridge the gap between theoretical knowledge and practical industry skills, preparing students to meet the challenges of an ever-evolving technological landscape.
            </p>
          </div>
        </div>

        <!-- Mission -->
        <div class="flex flex-col md:flex-row gap-8 items-start">
          <div class="flex-shrink-0">
            <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Mission</h2>
            <div class="space-y-4">
              {[
                { title: "Quality Technical Education", desc: "To provide high-quality, affordable diploma engineering education aligned with industry requirements and AICTE/GTU standards, enabling students from all socio-economic backgrounds to access professional technical training." },
                { title: "Industry-Readiness", desc: "To develop students' practical skills through well-equipped laboratories, workshops, industrial visits, and internships so they are job-ready from day one of their career." },
                { title: "Holistic Development", desc: "To nurture not only technical competencies but also communication skills, ethical values, leadership qualities, and entrepreneurial mindset in every student." },
                { title: "Faculty Excellence", desc: "To continuously upgrade faculty expertise through Faculty Development Programs (FDPs), industry training, and research activities, ensuring cutting-edge teaching delivery." },
                { title: "Infrastructure & Innovation", desc: "To maintain and upgrade infrastructure, laboratories, and digital resources to keep pace with technological advancements, fostering a culture of innovation and problem-solving." },
                { title: "Community Engagement", desc: "To contribute to the local community through NSS activities, technical outreach programmes, and collaborations with local industries and government bodies." },
              ].map((item, i) => (
                <div class="flex gap-4 p-4 rounded-lg bg-gray-50 hover:bg-primary/5 transition-colors">
                  <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center shrink-0 text-sm font-bold">{i + 1}</div>
                  <div>
                    <div class="font-semibold text-gray-900">{item.title}</div>
                    <div class="text-sm text-gray-600 mt-1">{item.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quality Policy -->
  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h2 class="text-3xl font-bold mb-6">Quality Policy</h2>
      <p class="text-lg text-blue-100 leading-relaxed mb-6">
        We at Government Polytechnic Palanpur are committed to providing quality technical education through a process of continuous improvement, ensuring that all our programmes meet the standards set by AICTE, GTU, and the State Government of Gujarat.
      </p>
      <p class="text-base text-blue-200 leading-relaxed">
        Our quality policy drives us to regularly review curriculum, adopt innovation in pedagogy, maintain transparency in governance, and ensure student satisfaction at every step of their academic journey.
      </p>
    </div>
  </section>

  <!-- Core Values -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Core Values</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 max-w-5xl mx-auto">
        {[
          { value: "Integrity", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", color: "text-blue-600 bg-blue-50" },
          { value: "Excellence", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z", color: "text-yellow-600 bg-yellow-50" },
          { value: "Innovation", icon: "M13 10V3L4 14h7v7l9-11h-7z", color: "text-purple-600 bg-purple-50" },
          { value: "Inclusivity", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", color: "text-green-600 bg-green-50" },
          { value: "Accountability", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2", color: "text-red-600 bg-red-50" },
          { value: "Service", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z", color: "text-pink-600 bg-pink-50" },
        ].map(item => (
          <div class="text-center p-4">
            <div class={`w-14 h-14 rounded-full ${item.color} flex items-center justify-center mx-auto mb-3`}>
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
              </svg>
            </div>
            <div class="font-semibold text-gray-900 text-sm">{item.value}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
