---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const mous = [
  {
    id: 1,
    partner: "Bee-Robokids Pvt Ltd",
    type: "Industry",
    scope: "Robotics & Automation Lab — equipment, mentorship, and joint student training",
    signed: "2023",
    status: "Active",
    benefits: ["Industry-sponsored robotics lab", "Expert sessions on robotics & IoT", "Student internship opportunities", "Project mentorship"],
    logo: "🤖",
  },
  {
    id: 2,
    partner: "Gujarat Technological University (GTU)",
    type: "University",
    scope: "Academic affiliation, SSIP support, examination, and curriculum alignment",
    signed: "2014",
    status: "Active",
    benefits: ["Affiliated diploma programmes", "SSIP grant facilitation", "Research & innovation support", "GTU skill development programmes"],
    logo: "🎓",
  },
  {
    id: 3,
    partner: "NIELIT (National Institute of Electronics & IT)",
    type: "Government Body",
    scope: "IT literacy, certification courses, and digital skills training for students",
    signed: "2021",
    status: "Active",
    benefits: ["O-Level & CCC certification support", "Digital literacy workshops", "Faculty training sessions", "Student skill certifications"],
    logo: "💻",
  },
  {
    id: 4,
    partner: "District Industries Centre, Banaskantha",
    type: "Government",
    scope: "Industrial visits, entrepreneurship awareness, and MSME exposure for students",
    signed: "2022",
    status: "Active",
    benefits: ["MSME unit visits for students", "Entrepreneurship workshops", "Linkage with local industries", "Start-up ecosystem interaction"],
    logo: "🏭",
  },
  {
    id: 5,
    partner: "ACPDC (Admission Committee for Professional Diploma Courses)",
    type: "Regulatory",
    scope: "Centralized diploma admissions, reservation implementation, and student support",
    signed: "2014",
    status: "Active",
    benefits: ["Transparent merit-based admissions", "Scholarship co-ordination", "Reservation category support", "Online admission facilitation"],
    logo: "📋",
  },
];

const objectives = [
  "Bridge the gap between academia and industry for diploma students",
  "Provide access to real-world equipment, tools, and mentors",
  "Facilitate internships, live projects, and campus recruitment",
  "Enable joint research, certification programmes, and skill development",
  "Strengthen institutional reputation through recognized partnerships",
];
---

<Layout title="MOU & Collaborations | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">MOU & Collaborations</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Partnerships</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">MOU & Collaborations</h1>
      <p class="text-lg text-gray-600 max-w-2xl">Memoranda of Understanding signed by GPP Palanpur with industry, government bodies, and institutions to enhance education and student outcomes.</p>
    </div>
  </section>

  <!-- Objectives -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-5">Objectives of MoUs</h2>
      <ul class="grid md:grid-cols-2 gap-3">
        {objectives.map(o => (
          <li class="flex items-start gap-3 bg-primary/5 rounded-xl px-4 py-3 text-sm text-gray-700">
            <div class="w-1.5 h-1.5 bg-primary rounded-full flex-shrink-0 mt-2"></div>
            {o}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- MOU Cards -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Active MOUs</h2>
      <div class="space-y-6">
        {mous.map(mou => (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="flex items-start gap-5 p-6">
              <div class="text-4xl flex-shrink-0">{mou.logo}</div>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <h3 class="text-lg font-bold text-gray-900">{mou.partner}</h3>
                  <span class="text-xs font-medium bg-primary/10 text-primary px-2.5 py-0.5 rounded-full">{mou.type}</span>
                  <span class="text-xs font-medium bg-green-100 text-green-700 px-2.5 py-0.5 rounded-full">{mou.status}</span>
                </div>
                <p class="text-gray-600 text-sm mb-4">{mou.scope}</p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                  {mou.benefits.map(b => (
                    <div class="text-xs text-gray-600 bg-gray-50 rounded-lg px-3 py-2 border border-gray-100">{b}</div>
                  ))}
                </div>
              </div>
              <div class="text-right flex-shrink-0 hidden sm:block">
                <div class="text-xs text-gray-400">Signed</div>
                <div class="font-bold text-gray-900">{mou.signed}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-primary">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Interested in Partnering with GPP?</h2>
      <p class="text-white/80 mb-6 text-sm">Industries, institutions, and organisations wishing to sign an MOU with Government Polytechnic Palanpur may write to the Principal's office.</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-white text-primary font-semibold px-6 py-3 rounded-xl hover:bg-white/90 transition-colors">
        Get in Touch
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
