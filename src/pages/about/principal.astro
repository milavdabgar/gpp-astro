---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
---

<Layout title="Principal's Message | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Principal's Message</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Principal's Message</h1>
      <p class="text-lg text-gray-600">Leadership, vision, and a commitment to excellence in technical education</p>
    </div>
  </section>

  <!-- Principal Profile + Message -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="grid lg:grid-cols-3 gap-10">

          <!-- Profile Card -->
          <div class="lg:col-span-1">
            <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden sticky top-24">
              <div class="bg-gradient-to-br from-primary to-blue-700 p-8 text-center text-white">
                <div class="w-28 h-28 rounded-full bg-white/20 flex items-center justify-center mx-auto mb-4 text-5xl font-bold text-white">
                  SD
                </div>
                <h2 class="text-xl font-bold">Shri S. D. Dabhi</h2>
                <p class="text-blue-200 text-sm mt-1">Principal (In-charge)</p>
              </div>
              <div class="p-6 space-y-3 text-sm">
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider mb-1">Full Name</span>
                  <span class="font-medium text-gray-900">Shri Sureshkumar Dalabhai Dabhi</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider mb-1">Qualification</span>
                  <span class="font-medium text-gray-900">M.Tech. (Manufacturing Systems)</span>
                  <span class="block text-gray-500 text-xs">NIT Jaipur — First Class (68%)</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider mb-1">Appointment Type</span>
                  <span class="font-medium text-gray-900">In-charge Principal</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider mb-1">In Charge Since</span>
                  <span class="font-medium text-gray-900">1st April 2019</span>
                </div>
                <div>
                  <span class="text-gray-500 block text-xs uppercase tracking-wider mb-1">Date of Birth</span>
                  <span class="font-medium text-gray-900">12th August 1968</span>
                </div>
                <div class="pt-2 border-t border-gray-100">
                  <a href="tel:9825697278" class="flex items-center gap-2 text-primary hover:text-primary/80 font-medium transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    +91 98256 97278
                  </a>
                </div>
                <div>
                  <a href="mailto:sureshdabhi1968@gmail.com" class="flex items-center gap-2 text-primary hover:text-primary/80 text-xs transition-colors break-all">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    sureshdabhi1968@gmail.com
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Message -->
          <div class="lg:col-span-2">
            <div class="prose prose-lg max-w-none text-gray-600">
              <h3 class="text-2xl font-bold text-gray-900 mb-6">A Message from the Principal</h3>

              <p class="leading-relaxed mb-6">
                Dear Students, Parents, Faculty, and Well-wishers,
              </p>

              <p class="leading-relaxed mb-6">
                It gives me immense pride and pleasure to welcome you to <strong class="text-gray-900">Government Polytechnic Palanpur</strong> — an institution that has been shaping the technical minds of the Banaskantha district for over four decades. Since its establishment in 1984, our polytechnic has stood as a beacon of quality technical education, providing accessible, affordable, and industry-relevant diploma engineering programmes.
              </p>

              <p class="leading-relaxed mb-6">
                We are proud to hold <strong class="text-gray-900">NBA Accreditation</strong> for three of our flagship programmes — Civil Engineering, Electrical Engineering, and Mechanical Engineering — a testament to the academic rigour, quality of our faculty, and the robust learning environment we provide. This recognition drives us to continuously raise the bar and strive for excellence in every aspect of our functioning.
              </p>

              <p class="leading-relaxed mb-6">
                At GPP, we firmly believe that technical education must go beyond textbooks. Our 20.36-acre campus hosts well-equipped laboratories, modern workshops, a rich library with over 18,000 books, digital resources, and sports facilities — all designed to facilitate holistic learning. Our faculty — 64 dedicated professionals with qualifications from premier institutions — bring both academic depth and industry experience to the classroom.
              </p>

              <p class="leading-relaxed mb-6">
                The journey from student to professional is one that our institution takes very seriously. Through our Training and Placement Cell, NSS activities, SSIP programmes, and regular industrial visits, we ensure that every student who leaves our gates is equipped not just with a diploma, but with the confidence, skills, and values to make a meaningful contribution to society.
              </p>

              <p class="leading-relaxed mb-6">
                To our students: This institution is yours. Make the most of every opportunity it offers. Be curious, be persistent, and embrace the wonderful world of engineering with enthusiasm and integrity.
              </p>

              <p class="leading-relaxed mb-6">
                To parents and guardians: Your trust in us is our greatest responsibility. We assure you that we will continue to create a safe, nurturing, and academically stimulating environment for your children.
              </p>

              <p class="leading-relaxed">
                To our alumni, industry partners, and community members: Your continued support and engagement makes GPP stronger year after year. We look forward to deepening our partnerships with you.
              </p>

              <div class="mt-10 pt-6 border-t border-gray-200">
                <p class="font-semibold text-gray-900">Shri Sureshkumar Dalabhai Dabhi</p>
                <p class="text-gray-500 text-sm">Principal (In-charge)</p>
                <p class="text-gray-500 text-sm">Government Polytechnic Palanpur</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
