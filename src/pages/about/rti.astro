---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const infoCategories = [
  {
    category: "Institutional Information",
    items: ["Institute history and background", "Vision, mission and objectives", "Governing body composition", "Organisational chart"],
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 00-1-1h-2a1 1 0 00-1 1v5m4 0H9",
  },
  {
    category: "Academic Information",
    items: ["Programmes offered and intake", "GTU affiliation and course codes", "Syllabus and curriculum", "Examination results and merit list"],
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
  {
    category: "Admissions",
    items: ["Admission procedure via ACPC", "Eligibility criteria per programme", "Fee structure (tuition and other charges)", "Reservation policy for SC/ST/EWS"],
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01",
  },
  {
    category: "Faculty & Staff",
    items: ["Teaching faculty list with qualifications", "Non-teaching staff details", "Faculty-to-student ratio", "Recruitment procedures and vacancies"],
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
  {
    category: "Finance & Budget",
    items: ["Annual budget allocation", "Expenditure details (teaching/non-teaching)", "Fee collected and utilisation", "Audit reports"],
    icon: "M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M12 7h.01M3 5a2 2 0 012-2h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5z",
  },
  {
    category: "Infrastructure",
    items: ["Land and building details", "Laboratory and equipment list", "Library holdings (books, journals)", "Hostel and amenities"],
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16M3 21h18M9 21v-8a1 1 0 011-1h4a1 1 0 011 1v8",
  },
];

const rtiProcess = [
  {
    step: "1",
    title: "Draft Your Application",
    desc: "Write your RTI application clearly stating the specific information you need. Applications can be in English, Gujarati or Hindi.",
  },
  {
    step: "2",
    title: "Pay the Application Fee",
    desc: "Attach a Demand Draft / Postal Order of ₹10 payable to the Principal, Government Polytechnic Palanpur, or pay in cash at the institute office.",
  },
  {
    step: "3",
    title: "Submit to the PIO",
    desc: "Address the application to the Public Information Officer (Principal I/C), Government Polytechnic Palanpur — 385001. You may submit in person, by post, or via the Gujarat RTI online portal.",
  },
  {
    step: "4",
    title: "Receive Response",
    desc: "The PIO will respond within 30 days of receipt. For information concerning life or liberty the response must be furnished within 48 hours.",
  },
];
---

<Layout title="Right to Information (RTI) | Government Polytechnic Palanpur">
  <Nav />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-700 text-white py-20">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 rounded-full px-4 py-1.5 text-gray-300 text-sm font-medium mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        About — RTI
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Right to Information</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        Government Polytechnic Palanpur is committed to transparency under the
        <strong class="text-white">Right to Information Act, 2005</strong>. Citizens may seek
        information from the institute as provided by law.
      </p>

      <!-- key stats -->
      <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-3xl mx-auto">
        {[
          { val: "RTI Act 2005", label: "Governing Legislation" },
          { val: "30 Days", label: "Response Time Limit" },
          { val: "₹10", label: "Application Fee" },
        ].map((s) => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5">
            <p class="text-2xl font-bold text-white">{s.val}</p>
            <p class="text-gray-300 text-sm mt-1">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PIO & Appellate Authority -->
  <section class="py-14 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Designated Authorities</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- PIO card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">Public Information Officer (PIO)</h3>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            <li><span class="font-medium text-gray-700">Name:</span> Mr. S. D. Dabhi</li>
            <li><span class="font-medium text-gray-700">Designation:</span> Lecturer & Principal I/C</li>
            <li><span class="font-medium text-gray-700">Institute:</span> Government Polytechnic Palanpur</li>
            <li><span class="font-medium text-gray-700">Address:</span> Palanpur, Banaskantha — 385001, Gujarat</li>
            <li>
              <span class="font-medium text-gray-700">Phone:</span>{" "}
              <a href="tel:02742252204" class="text-blue-600 hover:underline">02742-252204</a>
            </li>
            <li>
              <span class="font-medium text-gray-700">Email:</span>{" "}
              <a href="mailto:gp-palanpur-dte@gujarat.gov.in" class="text-blue-600 hover:underline break-all">
                gp-palanpur-dte@gujarat.gov.in
              </a>
            </li>
          </ul>
        </div>

        <!-- Appellate Authority card -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-purple-100 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800">First Appellate Authority</h3>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            <li><span class="font-medium text-gray-700">Authority:</span> Directorate of Technical Education (DTE)</li>
            <li><span class="font-medium text-gray-700">State:</span> Government of Gujarat</li>
            <li><span class="font-medium text-gray-700">Address:</span> DTE, Gandhinagar, Gujarat</li>
            <li class="pt-2 text-xs text-gray-400 italic">
              Appeals against the PIO's decision or non-response must be filed with the First
              Appellate Authority within 30 days of receiving (or failing to receive) the PIO
              response.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Institute Identity -->
  <section class="py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-6">Institute Details</h2>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
          <tbody>
            {[
              ["Institute Name", "Government Polytechnic Palanpur"],
              ["Institute Code (GTU)", "626"],
              ["GTU Affiliation Number", "GTU/INST_AFFI/626/2012-13/677"],
              ["First GTU Affiliation", "31 January 2013"],
              ["Established in", "1984 (Civil & Electrical Engineering)"],
              ["Type", "Government — Directly managed by DTE, Gujarat"],
              ["Location", "Palanpur, Banaskantha District, Gujarat — 385001"],
              ["Coordinates", "24°12′ N, 72°28′ E"],
              ["Campus Area", "20.36 acres — Government land (registered 13 January 1989)"],
              ["Land Registration", "Collectorate of Banaskantha, Gujarat"],
            ].map(([label, value], i) => (
              <tr class={i % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                <td class="px-6 py-3.5 font-medium text-gray-600 w-2/5">{label}</td>
                <td class="px-6 py-3.5 text-gray-800">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Information Available Under RTI -->
  <section class="py-14 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-2">Categories of Information Accessible</h2>
      <p class="text-gray-500 text-sm mb-8">
        Citizens may request information from the institute under the following categories:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {infoCategories.map((cat) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={cat.icon} />
                </svg>
              </div>
              <h3 class="font-semibold text-gray-800 text-sm">{cat.category}</h3>
            </div>
            <ul class="space-y-1.5">
              {cat.items.map((item) => (
                <li class="flex items-start gap-2 text-xs text-gray-600">
                  <svg class="w-3.5 h-3.5 text-green-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How to File RTI -->
  <section class="py-14">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-8">How to File an RTI Application</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {rtiProcess.map((p) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 relative">
            <div class="w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold mb-3">
              {p.step}
            </div>
            <h3 class="font-semibold text-gray-800 mb-2 text-sm">{p.title}</h3>
            <p class="text-xs text-gray-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>

      <!-- Fee & Timeline box -->
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          {
            title: "Application Fee",
            detail: "₹10 per RTI application (additional ₹2 per page for photocopies)",
            color: "blue",
          },
          {
            title: "Response Timeline",
            detail: "30 days (or 48 hours if the information concerns life or liberty)",
            color: "green",
          },
          {
            title: "First Appeal",
            detail: "File within 30 days of receiving (or not receiving) PIO's response",
            color: "purple",
          },
        ].map((item) => (
          <div class={`rounded-xl p-5 border bg-${item.color}-50 border-${item.color}-100`}>
            <p class={`text-xs font-semibold text-${item.color}-700 uppercase tracking-wider mb-1`}>{item.title}</p>
            <p class="text-sm text-gray-700 leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Exempt Information Note -->
  <section class="py-10 bg-amber-50 border-y border-amber-100">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div class="text-sm">
          <p class="font-semibold text-amber-800 mb-1">Exemptions under Section 8 of the RTI Act</p>
          <p class="text-amber-700 leading-relaxed">
            Certain categories of information are exempt from disclosure under Section 8 of the RTI
            Act, 2005 — including information that would prejudicially affect national security, trade
            secrets, personal privacy (where no public interest is involved), and information received
            in confidence from foreign governments. Requests for such information will be declined with
            written reasons.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-14">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-gray-800 mb-3">Submit an RTI Application</h2>
      <p class="text-gray-500 mb-8 max-w-xl mx-auto">
        Address your application to the Public Information Officer at Government Polytechnic Palanpur
        by post, in person, or via the Gujarat RTI online portal.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://rtionline.gujarat.gov.in"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-blue-600 text-white rounded-xl px-6 py-3 font-semibold hover:bg-blue-700 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Gujarat RTI Portal
        </a>
        <a
          href="mailto:gp-palanpur-dte@gujarat.gov.in"
          class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 rounded-xl px-6 py-3 font-semibold hover:border-blue-400 hover:text-blue-700 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email the PIO
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
