---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

// First-year enrollment data sourced from GTU Affiliation Document 2026-27 (939.md)
const enrollmentRows = [
  { year: "2020-21", ec: 6,  elec: 22, mech: 49, civil: 64,  ict: null, it: null, total: 141 },
  { year: "2021-22", ec: 19, elec: 29, mech: 36, civil: 69,  ict: null, it: null, total: 153 },
  { year: "2022-23", ec: 11, elec: 35, mech: 35, civil: 77,  ict: 21,   it: null, total: 179 },
  { year: "2023-24", ec: 7,  elec: 53, mech: 56, civil: 86,  ict: 43,   it: 29,   total: 274 },
  { year: "2024-25", ec: 15, elec: 52, mech: 67, civil: 118, ict: 28,   it: 37,   total: 317 },
  { year: "2025-26", ec: 24, elec: 79, mech: 75, civil: 108, ict: 55,   it: 55,   total: 396 },
];

const intake = { ec: 30, elec: 60, mech: 60, civil: 90, ict: 60, it: 30 };

const depts = [
  { key: "ec",    label: "EC",          full: "Electronics & Communication", color: "bg-purple-500",     light: "bg-purple-50 text-purple-700" },
  { key: "elec",  label: "Electrical",  full: "Electrical Engineering",      color: "bg-yellow-500",     light: "bg-yellow-50 text-yellow-700" },
  { key: "mech",  label: "Mechanical",  full: "Mechanical Engineering",      color: "bg-orange-500",     light: "bg-orange-50 text-orange-700" },
  { key: "civil", label: "Civil",       full: "Civil Engineering",           color: "bg-green-500",      light: "bg-green-50 text-green-700" },
  { key: "ict",   label: "ICT",         full: "Information & Comm. Tech.",   color: "bg-blue-500",       light: "bg-blue-50 text-blue-700" },
  { key: "it",    label: "IT",          full: "Information Technology",      color: "bg-pink-500",       light: "bg-pink-50 text-pink-700" },
];

const maxTotal = Math.max(...enrollmentRows.map(r => r.total));

// Dept-level growth (comparing 2021-22 to 2025-26)
const deptGrowth = [
  { dept: "Civil",      from: 69,  to: 108, pct: Math.round(((108-69)/69)*100) },
  { dept: "Electrical", from: 29,  to: 79,  pct: Math.round(((79-29)/29)*100) },
  { dept: "Mechanical", from: 36,  to: 75,  pct: Math.round(((75-36)/36)*100) },
  { dept: "EC",         from: 19,  to: 24,  pct: Math.round(((24-19)/19)*100) },
  { dept: "ICT",        from: 21,  to: 55,  pct: Math.round(((55-21)/21)*100) },
  { dept: "IT",         from: 29,  to: 55,  pct: Math.round(((55-29)/29)*100) },
];
---

<Layout title="Student Strength | About | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span>About</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Student Strength</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-sky-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Enrollment Statistics
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Student Strength</h1>
      <p class="text-gray-600 text-lg">
        First-year enrollment trends at Government Polytechnic Palanpur from 2020-21 to 2025-26, reflecting steady growth across all engineering disciplines.
      </p>
    </div>
  </section>

  <!-- Top KPIs -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-primary">396</div>
          <div class="text-sm text-gray-500 mt-1">Students Enrolled (2025-26)</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">181%</div>
          <div class="text-sm text-gray-500 mt-1">Growth since 2020-21</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">6</div>
          <div class="text-sm text-gray-500 mt-1">Departments</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">330</div>
          <div class="text-sm text-gray-500 mt-1">Sanctioned Intake</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Growth Bar Chart -->
  <section class="py-10 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Year-wise Total First-Year Enrollment</h2>
      <div class="space-y-3">
        {enrollmentRows.map(row => (
          <div class="flex items-center gap-4">
            <span class="text-sm font-semibold text-gray-700 w-20 shrink-0">{row.year}</span>
            <div class="flex-1 bg-gray-200 rounded-full h-8 overflow-hidden relative">
              <div
                class="h-full bg-gradient-to-r from-primary to-primary/70 rounded-full flex items-center justify-end pr-3 transition-all"
                style={`width: ${Math.round((row.total / maxTotal) * 100)}%`}
              >
                <span class="text-white text-xs font-bold">{row.total}</span>
              </div>
            </div>
            <div class="text-sm text-gray-500 w-24 shrink-0 text-right">
              {row.it !== null ? "6 depts" : row.ict !== null ? "5 depts" : "4 depts"}
            </div>
          </div>
        ))}
      </div>
      <p class="mt-4 text-xs text-gray-500">* ICT department added in 2022-23. IT department added in 2023-24.</p>
    </div>
  </section>

  <!-- Department-wise Data Table -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Department-wise First-Year Enrollment</h2>
      <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700">Academic Year</th>
              {depts.map(d => (
                <th class="px-3 py-3 text-center font-semibold text-gray-700">{d.label}</th>
              ))}
              <th class="px-4 py-3 text-center font-bold text-primary">Total</th>
            </tr>
            <!-- Intake row -->
            <tr class="bg-primary/5 border-b border-gray-200">
              <td class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide">Sanctioned Intake</td>
              {depts.map(d => (
                <td class="px-3 py-2 text-center text-xs font-semibold text-gray-600">{intake[d.key as keyof typeof intake]}</td>
              ))}
              <td class="px-4 py-2 text-center text-xs font-bold text-primary">330</td>
            </tr>
          </thead>
          <tbody>
            {enrollmentRows.map((row, idx) => (
              <tr class={`border-b border-gray-100 ${idx % 2 === 0 ? '' : 'bg-gray-50/60'} hover:bg-primary/5 transition-colors`}>
                <td class="px-4 py-3 font-semibold text-gray-900">{row.year}</td>
                <td class="px-3 py-3 text-center">
                  {row.ec !== null
                    ? <span class="font-medium text-gray-800">{row.ec}</span>
                    : <span class="text-gray-300">—</span>}
                </td>
                <td class="px-3 py-3 text-center">
                  {row.elec !== null
                    ? <span class="font-medium text-gray-800">{row.elec}</span>
                    : <span class="text-gray-300">—</span>}
                </td>
                <td class="px-3 py-3 text-center">
                  {row.mech !== null
                    ? <span class="font-medium text-gray-800">{row.mech}</span>
                    : <span class="text-gray-300">—</span>}
                </td>
                <td class="px-3 py-3 text-center">
                  {row.civil !== null
                    ? <span class="font-medium text-gray-800">{row.civil}</span>
                    : <span class="text-gray-300">—</span>}
                </td>
                <td class="px-3 py-3 text-center">
                  {row.ict !== null
                    ? <span class="font-medium text-gray-800">{row.ict}</span>
                    : <span class="text-xs text-gray-400">New in 2022-23</span>}
                </td>
                <td class="px-3 py-3 text-center">
                  {row.it !== null
                    ? <span class="font-medium text-gray-800">{row.it}</span>
                    : <span class="text-xs text-gray-400">New in 2023-24</span>}
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="font-bold text-primary text-base">{row.total}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-gray-500">All figures represent first-year (Semester 1) enrollment. Source: GTU Affiliation Report 2026-27.</p>
    </div>
  </section>

  <!-- Dept growth -->
  <section class="py-8 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-xl font-bold text-gray-900 mb-5">Department Growth (2021-22 → 2025-26)</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {deptGrowth.map(d => (
          <div class="bg-white border border-gray-200 rounded-xl p-5">
            <div class="font-bold text-gray-900 mb-2">{d.dept}</div>
            <div class="flex items-end gap-2 mb-3">
              <span class="text-3xl font-bold text-primary">{d.to}</span>
              <span class="text-sm text-gray-400 pb-1">students (2025-26)</span>
            </div>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-gray-500">from {d.from}</span>
              <span class={`font-bold px-2 py-0.5 rounded-full text-xs ${d.pct >= 100 ? 'bg-green-100 text-green-700' : d.pct >= 50 ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700'}`}>
                +{d.pct}%
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Per-department fill-rate (2025-26) -->
  <section class="py-8 bg-white border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-xl font-bold text-gray-900 mb-5">Seat Fill Rate — 2025-26</h2>
      <div class="space-y-3">
        {[
          { d: "Electronics & Communication (EC)",  enrolled: 24,  intake: 30 },
          { d: "Electrical Engineering",             enrolled: 79,  intake: 60 },
          { d: "Mechanical Engineering",             enrolled: 75,  intake: 60 },
          { d: "Civil Engineering",                  enrolled: 108, intake: 90 },
          { d: "Information & Comm. Tech. (ICT)",   enrolled: 55,  intake: 60 },
          { d: "Information Technology (IT)",        enrolled: 55,  intake: 30 },
        ].map(row => {
          const pct = Math.min(Math.round((row.enrolled / row.intake) * 100), 150);
          const bar = Math.min(pct, 100);
          const over = pct > 100;
          return (
            <div class="flex items-center gap-3">
              <span class="text-xs text-gray-600 w-56 shrink-0">{row.d}</span>
              <div class="flex-1 bg-gray-100 rounded-full h-4 overflow-hidden">
                <div
                  class={`h-full rounded-full ${over ? 'bg-green-500' : 'bg-primary'}`}
                  style={`width: ${bar}%`}
                ></div>
              </div>
              <span class={`text-xs font-bold w-16 text-right ${over ? 'text-green-600' : 'text-gray-700'}`}>
                {row.enrolled}/{row.intake} {over && '✓'}
              </span>
            </div>
          );
        })}
      </div>
      <p class="mt-3 text-xs text-gray-500">Three departments (Electrical, Mechanical, Civil, IT) exceeded sanctioned intake in 2025-26, indicating high demand.</p>
    </div>
  </section>

  <Footer />
</Layout>
