---

<Layout title="IQAC & Quality Assurance | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">IQAC & Quality</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">IQAC &amp; Quality Assurance</h1>
      <p class="text-gray-600 text-lg mb-8">
        The Internal Quality Assurance Cell (IQAC) at GPP works to develop a quality culture through systematic documentation, regular assessments, and continuous improvements in academic and administrative processes.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <div class="text-3xl font-bold text-primary">3</div>
          <div class="text-sm text-gray-500 mt-1">NBA Accredited Programs</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <div class="text-3xl font-bold text-primary">4</div>
          <div class="text-sm text-gray-500 mt-1">Research Papers Published</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <div class="text-3xl font-bold text-primary">20+</div>
          <div class="text-sm text-gray-500 mt-1">NPTEL FDPs (2024-25)</div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm">
          <div class="text-3xl font-bold text-primary">50+</div>
          <div class="text-sm text-gray-500 mt-1">Industrial Visits/Year</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Objectives -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-5">IQAC Objectives</h2>
          <ul class="space-y-3">
            {[
              "Develop and apply quality benchmarks for academic and administrative activities.",
              "Promote research culture and faculty development through FDPs and workshops.",
              "Ensure student-centric learning through Outcome Based Education (OBE).",
              "Facilitate implementation of quality-enhancing measures from stakeholder feedback.",
              "Prepare Annual Quality Assurance Reports (AQAR) for institutional documentation.",
              "Support NBA accreditation and compliance with AICTE/GTU norms.",
              "Promote best practices in teaching-learning and technological integration.",
            ].map(obj => (
              <li class="flex items-start gap-3 text-gray-700 text-sm">
                <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {obj}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-primary/5 rounded-2xl p-6 space-y-4">
          <h3 class="font-bold text-gray-900">Quality Milestones</h3>
          {[
            { label: "GTU Affiliation", value: "Since 1955 (Establishment)", color: "bg-blue-500" },
            { label: "NBA Accreditation", value: "Civil, Electrical, Mechanical", color: "bg-green-500" },
            { label: "SSIP Projects", value: "41+ Innovation Projects", color: "bg-purple-500" },
            { label: "GTU Best Rank", value: "#32 (2025 Sem 4)", color: "bg-yellow-500" },
            { label: "Faculty FDPs", value: "20+ Completed (2024-25)", color: "bg-teal-500" },
            { label: "Internet Speed", value: "150 Mbps (BSNL + Airtel)", color: "bg-orange-500" },
          ].map(m => (
            <div class="flex items-center gap-3">
              <div class={`w-2 h-8 rounded-full ${m.color} flex-shrink-0`}></div>
              <div>
                <div class="text-xs text-gray-500">{m.label}</div>
                <div class="text-sm font-semibold text-gray-900">{m.value}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Quality Initiatives -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Quality Initiatives</h2>
        <p class="text-gray-500 text-sm">Key programs driving continuous improvement at GPP</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {qualityInitiatives.map(qi => {
          const c = colorMap[qi.color];
          return (
            <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
              <div class={`w-10 h-10 ${c.bg} rounded-lg flex items-center justify-center mb-4`}>
                <svg class={`w-5 h-5 ${c.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={qi.icon}/>
                </svg>
              </div>
              <h3 class="font-bold text-gray-900 mb-2">{qi.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{qi.desc}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Research Publications -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-1">Research Publications</h2>
        <p class="text-gray-500 text-sm">International peer-reviewed journal articles published by GPP faculty</p>
      </div>
      <div class="space-y-4">
        {researchPapers.map((paper, i) => (
          <div class="border border-gray-200 rounded-xl p-5 hover:shadow-sm transition-shadow">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-primary/10 text-primary text-sm font-bold rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">{i + 1}</div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-gray-900 mb-1 leading-snug">{paper.title}</h3>
                <div class="flex flex-wrap items-center gap-3 text-xs text-gray-500 mb-2">
                  <span class="font-medium text-gray-700">{paper.authors}</span>
                  <span>·</span>
                  <span>{paper.department}</span>
                  <span>·</span>
                  <span>{paper.published}</span>
                </div>
                <div class="flex flex-wrap gap-2">
                  <span class="text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded font-medium">{paper.conference}</span>
                  <span class="text-xs bg-gray-100 text-gray-700 px-2 py-0.5 rounded">{paper.issn}</span>
                  <span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded font-medium">IF: {paper.impactFactor}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Published Books -->
      <div class="mt-10">
        <h3 class="text-xl font-bold text-gray-900 mb-5">Published Books</h3>
        {books.map(book => (
          <div class="border border-gray-200 rounded-xl p-5 flex gap-4 hover:shadow-sm transition-shadow">
            <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <div>
              <h4 class="font-semibold text-gray-900 mb-0.5">{book.title}</h4>
              <p class="text-sm text-gray-600">{book.authors}</p>
              <div class="flex gap-3 mt-1 text-xs text-gray-500">
                <span>{book.publisher}</span>
                <span>·</span>
                <span>{book.year}</span>
                <span>·</span>
                <span>{book.department}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Faculty Development Programs -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-1">Faculty Development Programs (2024–25)</h2>
        <p class="text-gray-500 text-sm">NPTEL MOOC certifications completed by faculty — demonstrating commitment to lifelong learning</p>
      </div>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="text-left py-3 px-5 font-semibold">#</th>
              <th class="text-left py-3 px-5 font-semibold">Faculty</th>
              <th class="text-left py-3 px-5 font-semibold">Course / Topic</th>
              <th class="text-left py-3 px-5 font-semibold hidden sm:table-cell">Platform</th>
              <th class="text-right py-3 px-5 font-semibold">Date</th>
            </tr>
          </thead>
          <tbody>
            {fdps.map((f, i) => (
              <tr class={`border-t border-gray-100 ${i % 2 === 0 ? "bg-white" : "bg-gray-50"} hover:bg-primary/5 transition-colors`}>
                <td class="py-3 px-5 text-gray-400 text-xs">{i + 1}</td>
                <td class="py-3 px-5 font-medium text-gray-900">{f.faculty}</td>
                <td class="py-3 px-5 text-gray-600">{f.topic}</td>
                <td class="py-3 px-5 hidden sm:table-cell">
                  <span class="text-xs bg-blue-100 text-blue-800 rounded px-2 py-0.5">{f.platform}</span>
                </td>
                <td class="py-3 px-5 text-right text-xs text-gray-500">{f.date}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Links -->
  <section class="py-10 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Related Resources</h2>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/about/nba-accreditation" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors text-sm shadow-sm">NBA Accreditation</a>
        <a href="/student-section/results" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors text-sm shadow-sm">Academic Results</a>
        <a href="/innovation" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors text-sm shadow-sm">Innovation Cell</a>
        <a href="/about/mandatory-disclosure" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 font-medium px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors text-sm shadow-sm">Mandatory Disclosure</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
