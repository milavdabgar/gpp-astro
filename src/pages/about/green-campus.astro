---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const solarStats = [
  { value: "100 KW",      label: "Rooftop Solar Capacity",      icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" },
  { value: "91,458",      label: "Units Generated (2024-25)",    icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { value: "~73 tonnes",  label: "CO₂ Avoided per Year",         icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" },
  { value: "20 acres",    label: "Green Campus Area",             icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" },
];

const initiatives = [
  {
    title: "Solar Energy",
    icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z",
    color: "yellow",
    points: [
      "100 KW rooftop solar photovoltaic plant installed on campus buildings",
      "91,458 units of electricity generated in AY 2024-25",
      "Approximately 73 tonnes of CO₂ emissions avoided annually",
      "Solar power meets a significant portion of campus energy demand",
      "Reduces electricity cost and dependence on grid power",
    ],
  },
  {
    title: "Tree Plantation & Greenery",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064",
    color: "green",
    points: [
      "Annual tree plantation drives on World Environment Day and National Wildlife Day",
      "Tree-lined pathways across 20-acre campus promoting biodiversity",
      "NSS unit actively participates in plantation programs with the college",
      "Campus grounds maintained with native plant species to reduce water usage",
      "Green cover enhances microclimate: cooler ambient temperature on campus",
    ],
  },
  {
    title: "Water Conservation",
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    color: "blue",
    points: [
      "RO-purified drinking water stations at multiple locations across campus",
      "Rainwater harvesting pits on campus to recharge groundwater",
      "Drip irrigation used for campus garden maintenance",
      "Plumbing fixtures regularly audited for leakage prevention",
      "Water usage awareness campaigns conducted by students",
    ],
  },
  {
    title: "Energy Conservation",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    color: "orange",
    points: [
      "LED lighting installed across all classrooms, labs, and corridors",
      "Solar-powered common areas reducing grid dependency",
      "Energy audit conducted periodically; recommendations implemented",
      "Star-rated appliances and energy-efficient equipment procured",
      "Motion-sensing or scheduled lighting in low-traffic areas",
    ],
  },
  {
    title: "Waste Management",
    icon: "M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16",
    color: "red",
    points: [
      "Segregated waste bins (wet, dry, e-waste) placed across campus",
      "Paper recycling encouraged; double-sided printing policy in office",
      "E-waste collected and handed to authorised recyclers",
      "No single-use plastic policy observed on campus",
      "Organic waste from canteen composted for campus gardens",
    ],
  },
  {
    title: "Green Education & Awareness",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
    color: "teal",
    points: [
      "Environmental studies integrated in curriculum per GTU norms",
      "SWAYAM/NPTEL courses on sustainability offered to students",
      "NSS — National Service Scheme conducts eco-awareness camps",
      "World Environment Day, Earth Day celebrated with student events",
      "SSIP cell encourages green-tech and renewable energy project ideas",
    ],
  },
];

const colorMap: Record<string, { bg: string; text: string; light: string; border: string }> = {
  yellow: { bg: "bg-yellow-500", text: "text-yellow-600", light: "bg-yellow-50", border: "border-yellow-200" },
  green:  { bg: "bg-green-600",  text: "text-green-600",  light: "bg-green-50",  border: "border-green-200" },
  blue:   { bg: "bg-blue-600",   text: "text-blue-600",   light: "bg-blue-50",   border: "border-blue-200" },
  orange: { bg: "bg-orange-500", text: "text-orange-600", light: "bg-orange-50", border: "border-orange-200" },
  red:    { bg: "bg-red-500",    text: "text-red-600",    light: "bg-red-50",    border: "border-red-200" },
  teal:   { bg: "bg-teal-600",   text: "text-teal-600",   light: "bg-teal-50",   border: "border-teal-200" },
};

const sdgGoals = [
  { no: "7",  label: "Affordable & Clean Energy",      color: "bg-yellow-400" },
  { no: "11", label: "Sustainable Cities & Communities",color: "bg-orange-400" },
  { no: "12", label: "Responsible Consumption",         color: "bg-amber-600"  },
  { no: "13", label: "Climate Action",                  color: "bg-green-500"  },
  { no: "15", label: "Life on Land",                    color: "bg-lime-600"   },
];
---

<Layout title="Green Campus | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Green Campus</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-50 to-emerald-50 py-16 border-b border-green-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
        </svg>
        Green & Sustainable Campus
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Green Campus Initiative</h1>
      <p class="text-gray-600 text-lg leading-relaxed">
        Government Polytechnic Palanpur is committed to environmental sustainability — from a 100 KW rooftop solar plant to tree plantation drives, water conservation, and green education — building a campus that cares for the planet.
      </p>
    </div>
  </section>

  <!-- Solar Stats Bar -->
  <section class="bg-green-700 py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {solarStats.map(s => (
          <div class="flex flex-col items-center gap-2">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
              </svg>
            </div>
            <div class="text-2xl md:text-3xl font-bold text-white">{s.value}</div>
            <div class="text-xs text-green-200 font-medium">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Solar Highlight -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="bg-gradient-to-r from-yellow-50 to-orange-50 border border-yellow-200 rounded-2xl p-8 flex flex-col md:flex-row gap-6 items-center">
        <div class="w-20 h-20 bg-yellow-400 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">100 KW Rooftop Solar Power Plant</h2>
          <p class="text-gray-700 leading-relaxed">
            GPP Palanpur has a <strong>100 kilowatt rooftop solar photovoltaic installation</strong> across campus buildings. In the academic year 2024-25, the plant generated <strong>91,458 units</strong> of clean electricity — avoiding approximately 73 tonnes of CO₂ emissions. This flagship green energy initiative is part of Gujarat Government's push towards sustainable government institutions and demonstrates the college's commitment to a low-carbon future.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <div class="bg-white border border-yellow-200 rounded-lg px-3 py-1.5 text-sm font-medium text-yellow-700">100 KW Capacity</div>
            <div class="bg-white border border-green-200 rounded-lg px-3 py-1.5 text-sm font-medium text-green-700">91,458 units / year</div>
            <div class="bg-white border border-orange-200 rounded-lg px-3 py-1.5 text-sm font-medium text-orange-700">~73 tonnes CO₂ saved</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Initiatives Grid -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">Sustainability Initiatives</h2>
      <p class="text-gray-500 text-center mb-10">Our campus-wide programmes for a greener, more sustainable future</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {initiatives.map(init => {
          const c = colorMap[init.color];
          return (
            <div class={`bg-white border ${c.border} rounded-xl overflow-hidden shadow-sm`}>
              <div class={`${c.light} border-b ${c.border} px-5 py-4 flex items-center gap-3`}>
                <div class={`w-10 h-10 ${c.bg} rounded-xl flex items-center justify-center flex-shrink-0`}>
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={init.icon}/>
                  </svg>
                </div>
                <h3 class="font-bold text-gray-900">{init.title}</h3>
              </div>
              <ul class="p-5 space-y-2.5">
                {init.points.map(pt => (
                  <li class="flex items-start gap-2.5 text-sm text-gray-700">
                    <svg class={`w-4 h-4 ${c.text} flex-shrink-0 mt-0.5`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- SDG Alignment -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">UN Sustainable Development Goals</h2>
      <p class="text-gray-500 mb-8 text-sm">GPP Palanpur's green campus initiatives align with these UN SDGs</p>
      <div class="flex flex-wrap justify-center gap-4">
        {sdgGoals.map(g => (
          <div class={`${g.color} text-white rounded-xl px-5 py-4 flex flex-col items-center min-w-[130px] shadow-sm`}>
            <span class="text-3xl font-extrabold leading-none">SDG {g.no}</span>
            <span class="text-xs mt-1.5 font-medium text-white/90 text-center">{g.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Campus Environment CTA -->
  <section class="py-10 bg-green-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h2 class="text-2xl font-bold text-white mb-3">Be Part of the Green Movement</h2>
      <p class="text-green-100 text-sm mb-6 max-w-2xl mx-auto">
        Students, faculty, and staff are all stakeholders in keeping our campus green. From turning off lights when leaving a room to participating in plantation drives — every action counts.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/campus-life/clubs" class="bg-white text-green-700 font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-green-50 transition-colors">
          Join NSS / Eco Club
        </a>
        <a href="/innovation/research" class="bg-green-600 border border-green-400 text-white font-semibold text-sm px-5 py-2.5 rounded-lg hover:bg-green-500 transition-colors">
          Green Tech Projects (SSIP)
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
