---

<Layout title="Mandatory Disclosure | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/about" class="hover:text-primary transition-colors">About</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Mandatory Disclosure</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Mandatory Disclosure</h1>
      <p class="text-gray-600 text-lg">
        As per AICTE Approval Process Handbook — Government Polytechnic, Palanpur (Code: 626)
      </p>
      <div class="mt-4 text-sm text-gray-500">
        Information Effective: Academic Year 2025–26 &nbsp;|&nbsp; Last Updated: March 2026
      </div>
    </div>
  </section>

  <!-- Disclosure Sections -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl space-y-8">
      {sections.map(section => (
        <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm">
          <div class="bg-primary/10 px-5 py-3">
            <h2 class="text-sm font-bold text-primary uppercase tracking-wide">{section.title}</h2>
          </div>
          <table class="w-full text-sm">
            <tbody>
              {section.rows.map((row, i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                  <td class="px-5 py-3 font-medium text-gray-700 w-2/5 border-r border-gray-100">{row[0]}</td>
                  <td class="px-5 py-3 text-gray-900">{row[1]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}

      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm text-blue-800">
        <strong>Note:</strong> This disclosure is filed as per the AICTE Approval Process Handbook. For the latest AICTE Extension of Approval (EoA) letter and detailed institutional data, please contact the college office or visit the AICTE portal at <a href="https://www.aicte-india.org" class="underline font-medium" target="_blank" rel="noopener">aicte-india.org</a>.
      </div>
    </div>
  </section>

  <Footer />
</Layout>
