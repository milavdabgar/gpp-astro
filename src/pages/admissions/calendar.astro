---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const admissionTimeline = [
  { month: "April–May", activity: "ACPDC releases official admission notification and online form", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2", status: "upcoming" },
  { month: "May–June", activity: "Online application submission with SSC marks and documents", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z", status: "upcoming" },
  { month: "June–July", activity: "Merit list publication and document verification", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", status: "upcoming" },
  { month: "July", activity: "Online allotment rounds (R1, R2, R3) on ACPDC portal", icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z", status: "upcoming" },
  { month: "July–August", activity: "Counseling, seat confirmation and fee payment", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z", status: "upcoming" },
  { month: "August", activity: "Reporting at institute; document submission and enrollment confirmation", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5", status: "upcoming" },
  { month: "August", activity: "Commencement of First Semester (Odd Semester begins)", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253", status: "upcoming" },
];

const academicCalendar = [
  {
    sem: "Odd Semester (1st / 3rd / 5th)",
    months: "July – November",
    events: [
      "July: Classes begin",
      "August: Internal tests begin",
      "September–October: Mid-term exams",
      "October–November: Practical exams",
      "November–December: GTU Theory Exams (Winter Exam)",
    ],
  },
  {
    sem: "Even Semester (2nd / 4th / 6th)",
    months: "January – May",
    events: [
      "January: Classes resume",
      "February: Internal tests",
      "March–April: Mid-term exams",
      "April–May: Practical exams / Project submission",
      "May–June: GTU Theory Exams (Summer Exam)",
    ],
  },
];
---

<Layout title="Academic Calendar | Admissions | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/admissions" class="hover:text-primary transition-colors">Admissions</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Academic Calendar</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Academic Calendar</h1>
      <p class="text-gray-600 text-lg">Admission schedule and academic year overview for Government Polytechnic Palanpur</p>
    </div>
  </section>

  <!-- Admission Timeline -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Admission Timeline (Indicative)</h2>
      <div class="relative border-l-2 border-primary/30 pl-8 space-y-8">
        {admissionTimeline.map((item, i) => (
          <div class="relative">
            <div class="absolute -left-10 w-5 h-5 rounded-full bg-primary border-2 border-white shadow flex items-center justify-center">
              <div class="w-2 h-2 rounded-full bg-white"></div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
              <div class="flex items-center gap-3 mb-2">
                <span class="bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full">{item.month}</span>
              </div>
              <p class="text-gray-700 text-sm">{item.activity}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-sm text-yellow-800">
        <strong>Note:</strong> Exact dates vary each year. Always check the official ACPDC portal at <a href="https://gujdiploma.nic.in" target="_blank" rel="noopener" class="underline font-medium">gujdiploma.nic.in</a> for confirmed dates.
      </div>
    </div>
  </section>

  <!-- Academic Year -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Academic Year Structure</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {academicCalendar.map(sem => (
          <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
            <div class="bg-primary/10 px-5 py-3">
              <h3 class="font-bold text-primary text-sm">{sem.sem}</h3>
              <p class="text-xs text-gray-600 mt-0.5">{sem.months}</p>
            </div>
            <ul class="p-5 space-y-2.5">
              {sem.events.map(ev => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {ev}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GTU Exam + Quick Links -->
  <section class="py-10 bg-white border-t border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5">
          <h3 class="font-bold text-blue-900 mb-3">GTU Examination Schedule</h3>
          <ul class="text-sm text-blue-800 space-y-1">
            <li>• Winter Exams: November – December</li>
            <li>• Summer Exams: May – June</li>
            <li>• GTU publishes exact timetables at gtu.ac.in</li>
          </ul>
          <a href="https://gtu.ac.in" target="_blank" rel="noopener" class="inline-flex items-center gap-1 mt-3 text-sm font-medium text-blue-700 hover:underline">
            GTU Official Website
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-5">
          <h3 class="font-bold text-green-900 mb-3">Useful Portals</h3>
          <ul class="text-sm text-green-800 space-y-1.5">
            <li><a href="https://gujdiploma.nic.in" target="_blank" class="hover:underline">→ ACPDC Diploma Admissions</a></li>
            <li><a href="https://gtu.ac.in" target="_blank" class="hover:underline">→ GTU – Gujarat Technological University</a></li>
            <li><a href="https://mysy.guj.nic.in" target="_blank" class="hover:underline">→ MYSY Scholarship Portal</a></li>
            <li><a href="https://digitalgujarat.gov.in" target="_blank" class="hover:underline">→ Digital Gujarat (SC/ST Scholarship)</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
