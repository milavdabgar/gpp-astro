---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const affiliationDetails = {
  university: "Gujarat Technological University (GTU)",
  universityType: "State Technical University",
  affiliationNo: "GTU/INST_AFFI/626/2012-13/677",
  firstAffiliation: 2008,
  website: "https://www.gtu.ac.in",
  address: "Nr. Vishwakarma Government Engineering College, Nr. Visat Three Roads, Visat - Gandhinagar Highway, Chandkheda, Ahmedabad-382424",
};

const programs = [
  { name: "Civil Engineering", code: "CE", duration: "3 Years (6 Semesters)", affYear: 2008 },
  { name: "Electrical Engineering", code: "EE", duration: "3 Years (6 Semesters)", affYear: 2008 },
  { name: "Electronics & Communication Engineering", code: "EC", duration: "3 Years (6 Semesters)", affYear: 2008 },
  { name: "Mechanical Engineering", code: "ME", duration: "3 Years (6 Semesters)", affYear: 2008 },
  { name: "Computer Engineering", code: "CO", duration: "3 Years (6 Semesters)", affYear: 2009 },
  { name: "Information Technology", code: "IF", duration: "3 Years (6 Semesters)", affYear: 2017 },
];

const gtuServices = [
  { name: "Examination & Results", desc: "GTU conducts semester-end examinations and publishes results for all affiliated polytechnic programs." },
  { name: "Curriculum & Syllabus", desc: "GTU prescribes the academic curriculum, syllabus, and course content for all diploma programs." },
  { name: "Degree Certificates", desc: "GTU issues official diploma certificates and marksheets to all graduates of affiliated institutions." },
  { name: "Academic Calendar", desc: "GTU publishes the academic calendar, examination schedules, and important dates for each academic year." },
];
---

<Layout title="GTU Affiliation | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">
        GTU Affiliated Since 2008
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">GTU Affiliation</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Government Polytechnic Palanpur is affiliated with Gujarat Technological University (GTU),
        the premier state technical university of Gujarat, ensuring academic excellence and industry-aligned education.
      </p>
    </div>
  </section>

  <!-- University Info -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-blue-50 rounded-2xl border border-blue-100 p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2 rounded-lg bg-primary/10">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Affiliation Details</h2>
          </div>
          <dl class="space-y-4">
            <div class="flex flex-col gap-1 pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Affiliated University</dt>
              <dd class="text-base font-bold text-gray-900">{affiliationDetails.university}</dd>
            </div>
            <div class="flex flex-col gap-1 pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">University Type</dt>
              <dd class="text-sm font-medium text-gray-700">{affiliationDetails.universityType}</dd>
            </div>
            <div class="flex flex-col gap-1 pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Affiliation Number</dt>
              <dd class="text-sm font-mono bg-white px-3 py-1.5 rounded border border-blue-200 text-gray-900">{affiliationDetails.affiliationNo}</dd>
            </div>
            <div class="flex flex-col gap-1 pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">First Affiliated</dt>
              <dd class="text-sm font-medium text-gray-700">{affiliationDetails.firstAffiliation}</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">GTU Website</dt>
              <dd>
                <a href={affiliationDetails.website} target="_blank" rel="noopener noreferrer" class="text-sm text-primary font-medium hover:underline flex items-center gap-1">
                  {affiliationDetails.website}
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </dd>
            </div>
          </dl>
        </div>
        <div class="space-y-4">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-3">About GTU</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-3">
              Gujarat Technological University (GTU) was established in 2007 under the Gujarat Technological University
              Act, 2007. It is one of the largest universities in India with over 400 affiliated institutions.
            </p>
            <p class="text-sm text-gray-600 leading-relaxed">
              GTU prescribes the curriculum, conducts examinations, and awards degrees/diplomas for all affiliated institutions including Government Polytechnic Palanpur.
            </p>
          </div>
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-3">GTU Address</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{affiliationDetails.address}</p>
            <a href={affiliationDetails.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-3 text-sm font-medium text-primary hover:underline">
              Visit GTU Official Website →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Affiliated Programs -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">GTU Affiliated Programs</h2>
      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sr.</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Program</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Code</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Duration</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Affiliated Since</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {programs.map((p, i) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 text-sm text-gray-500">{i + 1}</td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900">{p.name}</td>
                <td class="px-6 py-4"><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">{p.code}</span></td>
                <td class="px-6 py-4 text-sm text-gray-600">{p.duration}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{p.affYear}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- GTU Services -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">GTU Services for Students</h2>
      <div class="grid md:grid-cols-2 gap-5">
        {gtuServices.map((s) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <h3 class="font-bold text-gray-900 mb-2">{s.name}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
