---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const eoaDetails = {
  institution: "Government Polytechnic Palanpur",
  aicteId: "1-473831721",
  state: "Gujarat",
  district: "Banaskantha",
  address: "Outside Malan Gate, Ambaji Road, Palanpur-385001",
  type: "Government",
  affiliation: "Gujarat Technological University (GTU)",
};

const programs = [
  { name: "Civil Engineering", code: "CE", intake: 60, level: "Diploma" },
  { name: "Electrical Engineering", code: "EE", intake: 60, level: "Diploma" },
  { name: "Electronics & Communication Engineering", code: "EC", intake: 60, level: "Diploma" },
  { name: "Mechanical Engineering", code: "ME", intake: 60, level: "Diploma" },
  { name: "Computer Engineering", code: "CO", intake: 60, level: "Diploma" },
  { name: "Information Technology", code: "IF", intake: 30, level: "Diploma" },
];

const eoaYears = [
  { year: "2025-26", date: "April 2025", status: "active", doc: null },
  { year: "2024-25", date: "April 2024", status: "archived", doc: null },
  { year: "2023-24", date: "April 2023", status: "archived", doc: null },
  { year: "2022-23", date: "April 2022", status: "archived", doc: null },
];
---

<Layout title="AICTE Extension of Approval | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        AICTE Approved Institution
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">AICTE Extension of Approval</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Annual approval granted by the All India Council for Technical Education (AICTE) authorizing
        Government Polytechnic Palanpur to conduct technical education programs.
      </p>
    </div>
  </section>

  <!-- Institution Details -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-blue-50 rounded-2xl border border-blue-100 p-8">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Institution Details</h2>
          <dl class="space-y-4">
            {Object.entries(eoaDetails).map(([key, val]) => (
              <div class="flex items-start justify-between gap-4 pb-3 border-b border-blue-100 last:border-0 last:pb-0">
                <dt class="text-sm font-medium text-gray-500 capitalize">{key.replace(/([A-Z])/g, ' $1').trim()}</dt>
                <dd class="text-sm font-semibold text-gray-800 text-right">{val}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div class="space-y-4">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-4">About AICTE EOA</h3>
            <p class="text-sm text-gray-600 mb-3 leading-relaxed">
              The All India Council for Technical Education (AICTE) is the statutory body regulating technical
              education in India. Every technical institution must obtain Extension of Approval (EOA) from AICTE
              annually to continue operations.
            </p>
            <p class="text-sm text-gray-600 leading-relaxed">
              The EOA specifies the approved programs, intake capacity, and confirms that the institution meets
              AICTE norms regarding faculty, infrastructure, and academic standards.
            </p>
          </div>
          <div class="bg-yellow-50 rounded-xl border border-yellow-200 p-5">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-sm text-yellow-800">
                For the latest EOA document, please visit the official AICTE portal or contact the college administration.
              </p>
            </div>
            <a
              href="https://www.aicte-india.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 mt-3 text-sm font-medium text-yellow-700 hover:text-yellow-900 underline"
            >
              AICTE Official Portal →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Approved Programs -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">AICTE Approved Programs</h2>
      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sr.</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Program</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Code</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Level</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Approved Intake</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {programs.map((p, i) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 text-sm text-gray-500">{i + 1}</td>
                <td class="px-6 py-4 text-sm font-medium text-gray-900">{p.name}</td>
                <td class="px-6 py-4"><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">{p.code}</span></td>
                <td class="px-6 py-4 text-sm text-gray-600">{p.level}</td>
                <td class="px-6 py-4 text-sm font-semibold text-gray-900">{p.intake}</td>
              </tr>
            ))}
            <tr class="bg-blue-50">
              <td colspan="4" class="px-6 py-4 text-sm font-bold text-gray-900">Total Approved Intake</td>
              <td class="px-6 py-4 text-sm font-bold text-primary">{programs.reduce((s, p) => s + p.intake, 0)}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- EOA History -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Approval History</h2>
      <div class="space-y-3">
        {eoaYears.map((y) => (
          <div class={`flex items-center justify-between p-4 rounded-xl border ${y.status === 'active' ? 'border-green-200 bg-green-50' : 'border-gray-200 bg-white'} shadow-sm`}>
            <div class="flex items-center gap-3">
              <span class={`w-2 h-2 rounded-full ${y.status === 'active' ? 'bg-green-500' : 'bg-gray-400'}`}></span>
              <span class={`font-semibold ${y.status === 'active' ? 'text-green-800' : 'text-gray-700'}`}>EOA {y.year}</span>
              <span class="text-sm text-gray-500">({y.date})</span>
            </div>
            <div class="flex items-center gap-3">
              {y.status === 'active' && (
                <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700 border border-green-200">Current</span>
              )}
              <span class="text-xs text-gray-500 italic">Document available on AICTE portal</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
