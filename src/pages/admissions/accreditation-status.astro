---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const nbaPrograms = [
  {
    name: "Civil Engineering",
    code: "CE",
    intake: 60,
    status: "Accredited",
    validFrom: "July 2024",
    validTill: "June 2027",
    cycle: "3rd Cycle",
    color: "green",
  },
  {
    name: "Electrical Engineering",
    code: "EE",
    intake: 60,
    status: "Accredited",
    validFrom: "July 2024",
    validTill: "June 2027",
    cycle: "3rd Cycle",
    color: "green",
  },
  {
    name: "Mechanical Engineering",
    code: "ME",
    intake: 60,
    status: "Accredited",
    validFrom: "July 2024",
    validTill: "June 2027",
    cycle: "3rd Cycle",
    color: "green",
  },
  {
    name: "Electronics & Communication Engineering",
    code: "EC",
    intake: 60,
    status: "Awaiting",
    validFrom: "—",
    validTill: "—",
    cycle: "Under Process",
    color: "orange",
  },
  {
    name: "Computer Engineering",
    code: "CO",
    intake: 60,
    status: "Awaiting",
    validFrom: "—",
    validTill: "—",
    cycle: "Under Process",
    color: "orange",
  },
  {
    name: "Information Technology",
    code: "IF",
    intake: 30,
    status: "Awaiting",
    validFrom: "—",
    validTill: "—",
    cycle: "Under Process",
    color: "orange",
  },
];

const nbaFaqs = [
  {
    q: "What is NBA Accreditation?",
    a: "National Board of Accreditation (NBA) is an autonomous body under the aegis of AICTE that accredits technical programs at the undergraduate and diploma levels, based on outcomes-based criteria including program outcomes (POs), course outcomes (COs), and graduate attributes.",
  },
  {
    q: "Why does NBA accreditation matter for students?",
    a: "NBA accreditation ensures program quality and industry relevance. Graduates of accredited programs are eligible for GATE score waiver benefits in certain cases and their degrees are recognized by Washington Accord/Seoul Accord member countries.",
  },
  {
    q: "What is the validity of NBA accreditation?",
    a: "NBA accreditation is typically granted for 3 years. GPP's current accreditation for Civil, Electrical, and Mechanical Engineering is valid from July 2024 to June 2027.",
  },
  {
    q: "What is AICTE's role?",
    a: "AICTE (All India Council for Technical Education) approves institutions and programs for running technical education. NBA is a separate accreditation body that certifies program quality against defined outcomes.",
  },
];

const colorBadge: Record<string, string> = {
  green: "bg-green-100 text-green-800 border border-green-300",
  orange: "bg-orange-100 text-orange-800 border border-orange-300",
};
---

<Layout title="Accreditation Status | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-600 to-teal-700 py-16 text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-semibold bg-white/20 text-white border border-white/30">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        NBA Accredited Programs
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Accreditation Status</h1>
      <p class="text-xl text-green-100 max-w-2xl mx-auto mb-8">
        3 out of 6 diploma programs at Government Polytechnic Palanpur are accredited by the National Board of Accreditation (NBA), valid through June 2027.
      </p>
      <div class="grid grid-cols-3 gap-6 max-w-xl mx-auto">
        <div class="text-center">
          <div class="text-4xl font-bold text-white">3</div>
          <div class="text-sm text-green-200">NBA Accredited</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white">6</div>
          <div class="text-sm text-green-200">Total Programs</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-bold text-white">2027</div>
          <div class="text-sm text-green-200">Valid Until</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Status Table -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Program Accreditation Status</h2>
      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Program</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Code</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Intake</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Valid From</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Valid Till</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cycle</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {nbaPrograms.map((p) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-5 py-4 text-sm font-medium text-gray-900">{p.name}</td>
                <td class="px-5 py-4"><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">{p.code}</span></td>
                <td class="px-5 py-4 text-sm text-gray-600">{p.intake}</td>
                <td class="px-5 py-4"><span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${colorBadge[p.color]}`}>{p.status}</span></td>
                <td class="px-5 py-4 text-sm text-gray-600">{p.validFrom}</td>
                <td class="px-5 py-4 text-sm text-gray-600">{p.validTill}</td>
                <td class="px-5 py-4 text-sm text-gray-600">{p.cycle}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- What is NBA -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">About NBA Accreditation</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            The National Board of Accreditation (NBA) was established in 1994 as an autonomous body under AICTE
            to accredit technical programs and institutions in India. Accreditation signifies that a program has
            met defined quality standards.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            NBA evaluates programs based on the Outcome-Based Education (OBE) framework, assessing Program
            Educational Objectives (PEOs), Program Outcomes (POs), Course Outcomes (COs), and the overall
            teaching-learning process.
          </p>
          <div class="space-y-3">
            {["Outcome-Based Education (OBE) framework", "Continuous Improvement Process (CIP)", "Industry-aligned curriculum assessment", "Faculty qualification & research criteria", "Infrastructure and student support evaluation"].map((item) => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-sm text-gray-600">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-bold text-gray-900">Frequently Asked Questions</h3>
          {nbaFaqs.map((faq) => (
            <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
              <h4 class="font-semibold text-gray-900 mb-2 text-sm">{faq.q}</h4>
              <p class="text-sm text-gray-600 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
