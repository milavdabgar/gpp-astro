  },
  {
    name: "Entrepreneurship Cell",
    fullName: "Entrepreneurship Development Cell",
    description: "Promotes entrepreneurial thinking and skill development among students. Works closely with the SSIP cell to support startup ideas and business planning.",
    activities: [
      "Entrepreneurship awareness workshops",
      "Startup mentoring sessions",
      "Business plan competitions",
      "Industry mentor networking",
      "SSIP project guidance",
      "EDP programs",
    ],
    link: "/ssip",
    color: "orange",
    badge: "Entrepreneurship",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    name: "Green Club",
    fullName: "Environmental Awareness Club",
    description: "Promotes environmental consciousness and sustainability on campus through green initiatives, awareness drives, and eco-friendly practices.",
