    activities: [
      "Blood donation drives",
      "Tree plantation programs",
      "Village adoption & cleanliness drives",
      "Road safety awareness",
      "COVID-19 awareness campaigns",
      "Adult literacy programs",
    ],
    link: "/student-section/nss",
    color: "red",
    badge: "Social Service",
    icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
  },
  {
    name: "Cultural Club",
    fullName: "Cultural & Arts Club",
    description: "A platform for students passionate about arts, music, dance, drama, and cultural activities. Organizes events during national festivals and college fests.",
    activities: [
      "Annual cultural festival",
      "Republic Day & Independence Day programs",
      "Drama & street play performances",
      "Music & dance competitions",
      "Art exhibitions",
      "Inter-college cultural competitions",
    ],
    color: "purple",
    badge: "Culture & Arts",
    icon: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
  },
  {
    name: "Technical Club",
    fullName: "Technical & Innovation Club",
    description: "Fosters technical knowledge and innovation among students through workshops, seminars, project competitions, and industry interactions.",
    activities: [
      "Technical paper presentations",
      "Project competitions",
      "Guest lectures by industry experts",
      "Hackathons and coding contests",
      "SSIP project support",
      "Industrial visit organization",
    ],
    link: "/ssip",
    color: "blue",
    badge: "Technical",
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
  },
  {
    name: "Sports Club",
    fullName: "Sports & Athletics Club",
    description: "Manages all sports activities at GPP, including team formations, practice schedules, and participation in GTU inter-polytechnic tournaments.",
    activities: [
      "Cricket team management",
      "Volleyball team training",
      "Annual sports day organization",
      "GTU tournament participation",
      "Fitness & wellness programs",
      "Yoga sessions",
    ],
