---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const nssCamps = [
  { id: 1, date: "2 Jan 2023",  days: 7,  students: 50,  note: "Annual Special Camp" },
  { id: 2, date: "14 Jul 2023", days: 1,  students: 46,  note: "Single-day activity" },
  { id: 3, date: "9 Aug 2023",  days: 1,  students: 187, note: "Single-day activity" },
  { id: 4, date: "10 Aug 2023", days: 1,  students: 175, note: "Single-day activity" },
  { id: 5, date: "8 Dec 2023",  days: 1,  students: 48,  note: "Single-day activity" },
  { id: 6, date: "10 Feb 2024", days: 10, students: 2,   note: "Camp leader/resource person" },
  { id: 7, date: "28 Mar 2024", days: 1,  students: 70,  note: "Single-day activity" },
  { id: 8, date: "19 Apr 2024", days: 1,  students: 170, note: "Single-day activity" },
  { id: 9, date: "18 Jul 2025", days: 4,  students: 1,   note: "NSS representative" },
];

const totalNSSStudents = nssCamps.reduce((s, c) => s + c.students, 0);
const totalNSSDays = nssCamps.reduce((s, c) => s + c.days, 0);

const thalassemiaTests = [
  { id: 1, org: "Indian Red Cross Society", date: "15 Mar 2016", participants: 201 },
  { id: 2, org: "Indian Red Cross Society", date: "21 Feb 2018", participants: 374 },
  { id: 3, org: "Indian Red Cross Society", date: "11 Apr 2019", participants: 89 },
  { id: 4, org: "Indian Red Cross Society", date: "26 Mar 2019", participants: 122 },
  { id: 5, org: "Indian Red Cross Society", date: "7 Oct 2021",  participants: 170 },
  { id: 6, org: "Indian Red Cross Society", date: "21 Apr 2023", participants: 58 },
  { id: 7, org: "YGEN Healthcare Pvt. Ltd.", date: "19 Apr 2024", participants: 170 },
];

const totalThalassemia = thalassemiaTests.reduce((s, t) => s + t.participants, 0);

const stats = [
  { label: "NSS Camps", value: nssCamps.length, sub: "2023–2025", color: "text-blue-700", bg: "bg-blue-50 border-blue-200" },
  { label: "Participants (NSS)", value: totalNSSStudents+"+", sub: "total student participants", color: "text-green-700", bg: "bg-green-50 border-green-200" },
  { label: "Blood Donors", value: "70+", sub: "Civil Hospital Palanpur", color: "text-red-700", bg: "bg-red-50 border-red-200" },
  { label: "Thalassemia Tested", value: totalThalassemia.toLocaleString()+"+", sub: "7 screening drives (2016–2024)", color: "text-purple-700", bg: "bg-purple-50 border-purple-200" },
];
---

<Layout title="NSS & Social Activities | Student Section | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/student-section" class="hover:text-primary transition-colors">Student Section</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">NSS &amp; Social Activities</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-red-100 text-red-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Community Service · Health Awareness · Nation Building
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">NSS &amp; Social Activities</h1>
      <p class="text-gray-600 text-lg">
        Government Polytechnic Palanpur fosters a culture of social responsibility through NSS camps, blood donation drives, and health screening programmes.
      </p>
    </div>
  </section>

  <!-- Impact Stats -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {stats.map(s => (
          <div class={`rounded-xl border p-5 text-center ${s.bg}`}>
            <div class={`text-3xl font-bold ${s.color}`}>{s.value}</div>
            <div class="text-sm font-semibold text-gray-900 mt-1">{s.label}</div>
            <div class="text-xs text-gray-500 mt-0.5">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NSS Camps Section -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <!-- Header -->
      <div class="flex items-start justify-between mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">NSS Special Camps</h2>
          <p class="text-gray-500 text-sm mt-1">
            {nssCamps.length} camps organized · {totalNSSDays} total days · {totalNSSStudents}+ student-participations
          </p>
        </div>
        <div class="bg-blue-600 text-white px-3 py-1.5 rounded-lg text-sm font-semibold shrink-0">
          NSS Unit
        </div>
      </div>

      <!-- NSS Camps Table -->
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-5 py-3 text-left font-semibold">#</th>
              <th class="px-5 py-3 text-left font-semibold">Date</th>
              <th class="px-5 py-3 text-center font-semibold">Duration</th>
              <th class="px-5 py-3 text-center font-semibold">Participants</th>
              <th class="px-5 py-3 text-left font-semibold">Note</th>
            </tr>
          </thead>
          <tbody>
            {nssCamps.map((camp, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 text-gray-400 text-xs">{camp.id}</td>
                <td class="px-5 py-3 font-medium text-gray-900">{camp.date}</td>
                <td class="px-5 py-3 text-center">
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${camp.days >= 7 ? 'bg-blue-100 text-blue-800' : camp.days >= 4 ? 'bg-cyan-100 text-cyan-800' : 'bg-gray-100 text-gray-700'}`}>
                    {camp.days} {camp.days === 1 ? 'day' : 'days'}
                  </span>
                </td>
                <td class="px-5 py-3 text-center font-semibold text-gray-900">{camp.students}</td>
                <td class="px-5 py-3 text-gray-500 text-xs">{camp.note}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="bg-blue-50 border-t-2 border-primary/20">
              <td colspan="3" class="px-5 py-3 font-bold text-gray-900 text-sm">Total</td>
              <td class="px-5 py-3 text-center font-bold text-primary text-sm">{totalNSSStudents}+</td>
              <td class="px-5 py-3 text-xs text-gray-500">{totalNSSDays} days total</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <!-- NSS Info Card -->
      <div class="mt-6 bg-blue-50 border border-blue-200 rounded-xl p-5">
        <h3 class="font-bold text-blue-900 text-sm mb-2">About NSS at GPP Palanpur</h3>
        <p class="text-blue-800 text-sm leading-relaxed">
          The National Service Scheme (NSS) unit at Government Polytechnic Palanpur actively engages students in community service, rural development, and social awareness activities. NSS special camps cover areas including cleanliness drives, tree plantation, awareness on health and hygiene, and support for local communities. Students developing a sense of civic responsibility through NSS is a core goal of GPP's student development programme.
        </p>
      </div>
    </div>
  </section>

  <!-- Blood Donation Section -->
  <section class="py-10 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Blood Donation Camp</h2>
      <div class="grid md:grid-cols-2 gap-6 items-start">
        <!-- Info Card -->
        <div class="bg-white border border-red-200 rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900">Blood Donation Drive</h3>
              <p class="text-gray-500 text-xs">In collaboration with Civil Hospital Palanpur</p>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex justify-between border-b border-gray-100 pb-2">
              <span class="text-gray-600">Blood Collector</span>
              <span class="font-medium text-gray-900">Civil Hospital Palanpur</span>
            </div>
            <div class="flex justify-between border-b border-gray-100 pb-2">
              <span class="text-gray-600">Date of Camp</span>
              <span class="font-medium text-gray-900">9 May 2013</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600">Blood Donors</span>
              <span class="font-bold text-red-700 text-lg">70+</span>
            </div>
          </div>
        </div>

        <!-- Message Card -->
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <h3 class="font-bold text-gray-900 mb-3">Why Blood Donation Matters</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-3">
            Blood donation camps organized at GPP Palanpur reinforce the institution's commitment to community welfare. Faculty and students actively participate, contributing to the blood bank at Civil Hospital Palanpur — serving the healthcare needs of Banaskantha district.
          </p>
          <div class="bg-red-50 rounded-lg px-4 py-3 text-sm text-red-800 font-medium">
            "Every donation can save up to three lives. GPP students lead the way."
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Thalassemia Screening Section -->
  <section class="py-12 bg-white border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Thalassemia Screening Drives</h2>
        <p class="text-gray-500 text-sm mt-1">
          {thalassemiaTests.length} drives conducted in partnership with Indian Red Cross Society and YGEN Healthcare · {totalThalassemia.toLocaleString()}+ persons tested (2016–2024)
        </p>
      </div>

      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-5 py-3 text-left font-semibold">#</th>
              <th class="px-5 py-3 text-left font-semibold">Conducting Organization</th>
              <th class="px-5 py-3 text-center font-semibold">Date</th>
              <th class="px-5 py-3 text-center font-semibold">Persons Tested</th>
            </tr>
          </thead>
          <tbody>
            {thalassemiaTests.map((t, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 text-gray-400 text-xs">{t.id}</td>
                <td class="px-5 py-3 font-medium text-gray-900">{t.org}</td>
                <td class="px-5 py-3 text-center text-gray-600">{t.date}</td>
                <td class="px-5 py-3 text-center font-semibold text-gray-900">{t.participants}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr class="bg-purple-50 border-t-2 border-primary/20">
              <td colspan="3" class="px-5 py-3 font-bold text-gray-900 text-sm">Total Persons Screened</td>
              <td class="px-5 py-3 text-center font-bold text-primary text-sm">{totalThalassemia.toLocaleString()}+</td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div class="bg-purple-50 border border-purple-200 rounded-xl p-5">
        <h3 class="font-bold text-purple-900 text-sm mb-2">Significance of Thalassemia Screening</h3>
        <p class="text-purple-800 text-sm leading-relaxed">
          Thalassemia is a hereditary blood disorder prevalent in the Gujarat region. GPP Palanpur has actively hosted screening drives since 2016 in partnership with the Indian Red Cross Society and YGEN Healthcare Pvt. Ltd. These drives create awareness and help in early detection, reducing the risk of severe complications. With {totalThalassemia.toLocaleString()}+ persons screened over 7 drives, GPP's health initiative has made a meaningful impact in the Banaskantha community.
        </p>
      </div>
    </div>
  </section>

  <!-- Achievements Highlight -->
  <section class="py-10 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Notable Achievements</h2>
      <div class="grid md:grid-cols-3 gap-5">
        <!-- Institute achievement -->
        <div class="bg-white border border-amber-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-amber-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <span class="text-xs font-semibold text-amber-700 uppercase tracking-wide">Institute</span>
          </div>
          <h3 class="font-bold text-gray-900 text-sm mb-1">5th Place — Smart City Hackathon</h3>
          <p class="text-gray-600 text-xs">Held at Rajkot · January 2020</p>
        </div>

        <!-- Faculty achievement -->
        <div class="bg-white border border-blue-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
              </svg>
            </div>
            <span class="text-xs font-semibold text-blue-700 uppercase tracking-wide">Faculty</span>
          </div>
          <h3 class="font-bold text-gray-900 text-sm mb-1">Patent Published — Dr. R N Patel</h3>
          <p class="text-gray-600 text-xs">Application No: 202141060958 · January 2022</p>
          <p class="text-gray-500 text-xs mt-1">Also: Dr. L K Patel (PhD, EC) · Dr. N N Chaudhary (PhD, 2026)</p>
        </div>

        <!-- Student achievement -->
        <div class="bg-white border border-green-200 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <span class="text-xs font-semibold text-green-700 uppercase tracking-wide">Student</span>
          </div>
          <h3 class="font-bold text-gray-900 text-sm mb-1">Patent — Water Alarm Tap</h3>
          <p class="text-gray-600 text-xs">Dhaval P Nai · Enr. 186260319044 · January 2021</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
