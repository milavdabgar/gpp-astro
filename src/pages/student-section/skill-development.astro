---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

// Data from GTU Affiliation Document 2026-27 — Sections 4093–4105, 4696–4722
const skillPrograms = [
  {
    id: 1,
    program: "Life & Employability Skills",
    date: "24 March 2021",
    level: "College",
    periodicity: "One-time",
    description: "Comprehensive life skills and employability readiness program for all students preparing for industry placement.",
    badge: "bg-violet-100 text-violet-700",
  },
  {
    id: 2,
    program: "SET-A, B, C, D by H Kumars Education Institute",
    date: "6 February 2023",
    level: "College",
    periodicity: "Annual",
    description: "Student Employability Test series (modules A–D) conducted by H Kumars Education Institute for industry readiness assessment.",
    badge: "bg-blue-100 text-blue-700",
  },
  {
    id: 3,
    program: "SET-A, B, C, D by H Kumars Education Institute",
    date: "19 February 2024",
    level: "College",
    periodicity: "Annual",
    description: "Second annual iteration of the SET assessment program. Covers aptitude, communication, and domain skills.",
    badge: "bg-blue-100 text-blue-700",
  },
  {
    id: 4,
    program: "Spoken Tutorials (IIT Bombay)",
    date: "1 July 2023",
    level: "College",
    periodicity: "One-time launch",
    description: "IIT Bombay's Spoken Tutorial project — free, certificate-based online courses in programming, CAD, and software tools.",
    badge: "bg-orange-100 text-orange-700",
  },
  {
    id: 5,
    program: "Spoken Tutorial Online Training Course (Sem 1 / 3 / 5)",
    date: "1 September 2025",
    level: "College",
    periodicity: "Monthly (ongoing)",
    description: "Semester-wise rollout of IIT Bombay Spoken Tutorial courses integrated into the academic calendar for Sem 1, 3, and 5 students.",
    badge: "bg-orange-100 text-orange-700",
  },
  {
    id: 6,
    program: "Finishing School Training",
    date: "15 September 2025",
    level: "Department",
    periodicity: "Fortnightly (ongoing)",
    description: "Department-level finishing school to sharpen industry communication, personality development, aptitude, and core domain skills.",
    badge: "bg-emerald-100 text-emerald-700",
  },
];

const s4Events = [
  { id: 1,  date: "01 Sep 2020",  participants: "300 students",          event: "Sensitization: SSIP & New India New Palanpur", venue: "Adarsh School, Palanpur" },
  { id: 2,  date: "01 Sep 2020",  participants: "80 students",           event: "Sensitization: SSIP & New India New Palanpur", venue: "Govt Higher Secondary School, Palanpur" },
  { id: 3,  date: "17 Jan 2020",  participants: "250 students",          event: "Sensitization: SSIP & New India New Palanpur", venue: "Karnavat School, Palanpur" },
  { id: 4,  date: "03 Mar 2020",  participants: "250 students",          event: "New Palanpur New India — Our Problem & Solution", venue: "Govt Polytechnic Palanpur" },
  { id: 5,  date: "19 Aug 2020",  participants: "13 students",           event: "IDEATHON",                                   venue: "Govt Polytechnic Palanpur" },
  { id: 6,  date: "20 Sep 2020",  participants: "4 students",            event: "Startup Runway by iHub",                    venue: "iHub Gujarat" },
  { id: 7,  date: "15 Sep 2020",  participants: "184 students",          event: "Engineers Day Celebration",                 venue: "Online" },
  { id: 8,  date: "05 Nov 2020",  participants: "32 students",           event: "Toy Innovation Challenge",                  venue: "Online" },
  { id: 9,  date: "20 Nov 2020",  participants: "741 students",          event: "Twenty App Development Course",             venue: "Online" },
  { id: 10, date: "07 Feb 2021",  participants: "17 students",           event: "Business Badsha Motivation Seminar",        venue: "Online" },
  { id: 11, date: "20 Sep 2022",  participants: "Sem 1 & 6 students",    event: "Group Discussion",                          venue: "G P Palanpur" },
  { id: 12, date: "10 Oct 2022",  participants: "All students",          event: "New Palanpur for New India",                venue: "G P Palanpur" },
  { id: 13, date: "05 Dec 2023",  participants: "55 students",           event: "Start-Up Conclave",                         venue: "Gandhinagar" },
];

const stats = [
  { label: "Skill Programs", value: "6",   sub: "Active / completed" },
  { label: "S4 Events",       value: "13",  sub: "Start-up initiatives" },
  { label: "Peak Outreach",   value: "741", sub: "Students in single event" },
  { label: "Venues",          value: "7+",  sub: "City & online venues" },
];
---

<Layout title="Skill Development | Student Section | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span>Student Section</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Skill Development</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-slate-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Student Empowerment
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Skill Development</h1>
      <p class="text-gray-600 text-lg">
        GPP Palanpur actively bridges the gap between academic learning and industry requirements through skill enhancement programs, employability training, and the S4 Student Start-Up support system.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">{s.value}</div>
            <div class="text-sm font-semibold text-gray-900">{s.label}</div>
            <div class="text-xs text-gray-500">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skill Development Programs -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Skill Development Programs</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {skillPrograms.map(prog => (
          <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-sm transition-shadow">
            <div class="flex items-start justify-between gap-3 mb-2">
              <div class="w-7 h-7 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                <span class="text-xs font-bold text-primary">{prog.id}</span>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${prog.badge} shrink-0`}>{prog.level}</span>
            </div>
            <h3 class="font-semibold text-gray-900 mt-2 mb-1 text-sm leading-snug">{prog.program}</h3>
            <p class="text-xs text-gray-500 mb-3">{prog.description}</p>
            <div class="flex flex-wrap gap-3 text-xs text-gray-500">
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {prog.date}
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {prog.periodicity}
              </span>
            </div>
          </div>
        ))}
      </div>

      <!-- About Spoken Tutorials callout -->
      <div class="mt-6 bg-orange-50 border border-orange-200 rounded-xl p-4 flex gap-4 items-start">
        <svg class="w-5 h-5 text-orange-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="text-sm text-orange-800">
          <strong>Spoken Tutorial Initiative (IIT Bombay):</strong> Students can enroll for free FOSS and domain-specific courses at
          <a href="https://spoken-tutorial.org" target="_blank" rel="noopener" class="underline font-semibold">spoken-tutorial.org</a>. Certificates are provided upon completion of assessments.
        </div>
      </div>
    </div>
  </section>

  <!-- S4 Student Start-Up System -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="flex items-start justify-between gap-4 mb-6">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">S4 Student Start-Up System</h2>
          <p class="text-gray-500 text-sm mt-1">Sensitization, outreach, and incubation events to nurture the entrepreneurial spirit</p>
        </div>
        <span class="bg-primary/10 text-primary text-xs font-bold px-3 py-1.5 rounded-full whitespace-nowrap">{s4Events.length} Events</span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-gray-50 border border-gray-200">
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">#</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Date</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Event</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700 border-r border-gray-200">Participants</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-700">Venue</th>
            </tr>
          </thead>
          <tbody>
            {s4Events.map((ev, idx) => (
              <tr class={`border border-gray-200 ${idx % 2 === 0 ? 'bg-white' : 'bg-gray-50'} hover:bg-primary/5 transition-colors`}>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-500 font-mono">{ev.id}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-700 whitespace-nowrap">{ev.date}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-900 font-medium">{ev.event}</td>
                <td class="px-4 py-3 border-r border-gray-200 text-gray-600 whitespace-nowrap">{ev.participants}</td>
                <td class="px-4 py-3 text-gray-600">
                  <span class={`inline-flex items-center gap-1 ${ev.venue === 'Online' ? 'text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full text-xs' : ''}`}>
                    {ev.venue === 'Online' && (
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
                      </svg>
                    )}
                    {ev.venue}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Highlight: Start-Up Conclave -->
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-indigo-700">741</div>
          <div class="text-xs text-indigo-600 font-medium mt-0.5">Students in Twenty App Dev Course</div>
        </div>
        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-emerald-700">55</div>
          <div class="text-xs text-emerald-600 font-medium mt-0.5">Students at Start-Up Conclave, Gandhinagar</div>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-center">
          <div class="text-2xl font-bold text-amber-700">880+</div>
          <div class="text-xs text-amber-600 font-medium mt-0.5">Students reached in outreach events (2020)</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related links -->
  <section class="py-8 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h3 class="text-base font-semibold text-gray-800 mb-4">Related Programs</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/innovation" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm hover:bg-primary hover:text-white hover:border-primary transition-all">
          Innovation & SSIP
        </a>
        <a href="/ssip" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm hover:bg-primary hover:text-white hover:border-primary transition-all">
          SSIP Activities
        </a>
        <a href="/student-section/expert-lectures" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm hover:bg-primary hover:text-white hover:border-primary transition-all">
          Expert Lectures
        </a>
        <a href="/tpo" class="inline-flex items-center gap-2 bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-sm hover:bg-primary hover:text-white hover:border-primary transition-all">
          Placement Office
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
