---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

// Grievance Redressal Committee — Order: GPP/EST/Work Distribution/662, 4-Jul-2024
const committee = [
  {
    name: "Shri A. D. Shah",
    role: "Chairperson",
    designation: "Head of Department",
    department: "Electrical Engineering",
    phone: "9664982258",
    email: "gppelect09@gmail.com",
  },
  {
    name: "Shri P. G. Chauhan",
    role: "Member",
    designation: "Lecturer (Sr. Scale)",
    department: "Mechanical Engineering",
    phone: "9925208029",
    email: "gppmech19@gmail.com",
  },
  {
    name: "Ms. M. M. Shah",
    role: "Member",
    designation: "Lecturer (SG)",
    department: "ICT Engineering",
    phone: "9824349392",
    email: "gppic17@gmail.com",
  },
  {
    name: "Shri M. F. Tank",
    role: "Member",
    designation: "Lecturer (SG)",
    department: "General Department",
    phone: "9328951125",
    email: "gppgen@gmail.com",
  },
];

const grievanceTypes = [
  { title: "Academic Grievances", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253", desc: "Concerns related to examinations, evaluations, attendance, or academic processes." },
  { title: "Administrative Grievances", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2", desc: "Issues with documentation, certificates, scholarships, or institute administrative procedures." },
  { title: "Facility Grievances", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6", desc: "Complaints about hostel, canteen, laboratory equipment, internet, or campus infrastructure." },
  { title: "Misconduct / Harassment", icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z", desc: "Cases of ragging, bullying, discrimination, or any misconduct against students or staff." },
];

const steps = [
  { n: "01", title: "Submit Complaint", desc: "Approach any committee member in person or submit your complaint in writing to the Complaint Box placed at the college entrance / office." },
  { n: "02", title: "Acknowledgement", desc: "Your complaint will be acknowledged within 2 working days and assigned a reference number for tracking." },
  { n: "03", title: "Enquiry", desc: "The committee will investigate the complaint, gather facts, and may call both parties for a hearing within 10 working days." },
  { n: "04", title: "Resolution", desc: "A decision will be communicated in writing within 30 working days. If unsatisfied, you may escalate to the GTU Ombudsman." },
];
---

<Layout title="Grievance Redressal | Student Section | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/student-section" class="hover:text-primary transition-colors">Student Section</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Grievance Redressal</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Grievance Redressal</h1>
      <p class="text-gray-600 text-lg">
        Government Polytechnic Palanpur is committed to addressing student grievances promptly and fairly. Every student has the right to a safe, equitable, and supportive educational environment.
      </p>
    </div>
  </section>

  <!-- Policy Statement -->
  <section class="py-10 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 flex gap-4">
        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
        </div>
        <div>
          <h2 class="font-bold text-blue-900 mb-1">Institute Commitment</h2>
          <p class="text-blue-800 text-sm leading-relaxed">
            As per GTU and AICTE guidelines, GPP has constituted a Grievance Redressal Committee to address complaints from students, parents, and staff. All complaints are treated with confidentiality and resolved impartially. No student will face any negative consequences for raising a legitimate grievance.
          </p>
          <p class="text-xs text-blue-600 mt-2">
            Appointment Order: GPP/EST/Work Distribution/662 · Dated: 4-Jul-2024
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Grievances -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Types of Grievances Handled</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        {grievanceTypes.map(g => (
          <div class="bg-white rounded-xl border border-gray-200 p-5 flex gap-4 shadow-sm">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={g.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1">{g.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{g.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Committee Table -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-1">Grievance Redressal Committee</h2>
        <p class="text-gray-500 text-sm">Constituted vide Order No. GPP/EST/Work Distribution/662 dated 4-Jul-2024</p>
      </div>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="text-left py-3 px-5 font-semibold">Name</th>
              <th class="text-left py-3 px-5 font-semibold hidden sm:table-cell">Designation</th>
              <th class="text-left py-3 px-5 font-semibold hidden md:table-cell">Department</th>
              <th class="text-left py-3 px-5 font-semibold">Role</th>
              <th class="text-left py-3 px-5 font-semibold hidden lg:table-cell">Contact</th>
            </tr>
          </thead>
          <tbody>
            {committee.map((m, i) => (
              <tr class={`border-t border-gray-100 ${i % 2 === 0 ? "bg-white" : "bg-gray-50"}`}>
                <td class="py-4 px-5 font-medium text-gray-900">{m.name}</td>
                <td class="py-4 px-5 text-gray-600 hidden sm:table-cell">{m.designation}</td>
                <td class="py-4 px-5 text-gray-600 hidden md:table-cell">{m.department}</td>
                <td class="py-4 px-5">
                  <span class={`text-xs font-semibold rounded-full px-2.5 py-1 ${m.role === "Chairperson" ? "bg-primary/10 text-primary" : "bg-gray-100 text-gray-700"}`}>
                    {m.role}
                  </span>
                </td>
                <td class="py-4 px-5 hidden lg:table-cell">
                  <div class="flex flex-col gap-0.5">
                    <a href={`tel:${m.phone}`} class="text-xs text-gray-600 hover:text-primary transition-colors flex items-center gap-1">
                      <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                      {m.phone}
                    </a>
                    <a href={`mailto:${m.email}`} class="text-xs text-primary hover:underline flex items-center gap-1 truncate">
                      <svg class="w-3 h-3 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                      {m.email}
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Grievance Resolution Process</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {steps.map(s => (
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm relative">
            <div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold mb-4">{s.n}</div>
            <h3 class="font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Submit & Escalation -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Submit a Complaint -->
        <div class="bg-green-50 border border-green-200 rounded-xl p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            How to Submit a Grievance
          </h3>
          <ul class="space-y-3 text-sm text-gray-700">
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-green-200 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-bold text-green-800">1</div>
              <span><strong>Written Application:</strong> Submit a signed, dated letter to the Principal's office or any committee member.</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-green-200 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-bold text-green-800">2</div>
              <span><strong>Complaint Box:</strong> Drop your written complaint in the sealed box at the college main entrance.</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-green-200 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-bold text-green-800">3</div>
              <span><strong>Email / Phone:</strong> Contact the committee chairperson directly at <a href="mailto:gppelect09@gmail.com" class="text-primary underline">gppelect09@gmail.com</a> or <a href="tel:9664982258" class="text-primary underline">9664982258</a>.</span>
            </li>
            <li class="flex items-start gap-2">
              <div class="w-5 h-5 bg-green-200 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-xs font-bold text-green-800">4</div>
              <span><strong>Online Portal:</strong> Via the college front office or directly through gtugrs.gtu.ac.in for GTU-level queries.</span>
            </li>
          </ul>
        </div>

        <!-- Escalation / GTU Ombudsman -->
        <div class="bg-orange-50 border border-orange-200 rounded-xl p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            Escalation &amp; Ombudsman
          </h3>
          <p class="text-sm text-gray-700 mb-4 leading-relaxed">
            If you are not satisfied with the committee's decision within 30 days, you may escalate to the <strong>GTU Ombudsman</strong> as per GTU instructions.
          </p>
          <ul class="space-y-2 text-sm text-gray-700 mb-4">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              GTU Grievance Portal: <a href="https://gtugrs.gtu.ac.in" target="_blank" rel="noopener" class="text-primary underline">gtugrs.gtu.ac.in</a>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              Directorate of Technical Education: <a href="https://dte.gujarat.gov.in" target="_blank" rel="noopener" class="text-primary underline">dte.gujarat.gov.in</a>
            </li>
          </ul>
          <p class="text-xs text-gray-500">For ragging or harassment, you may also call the UGC/AICTE Anti-Ragging Helpline: <strong>1800-180-5522</strong></p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>
