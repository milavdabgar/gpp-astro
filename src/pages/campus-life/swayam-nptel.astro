---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const benefits = [
  { title: "IIT-Certified Courses", desc: "Study courses designed and taught by IIT professors and gain certificates that are nationally recognised." },
  { title: "Flexible Self-Paced Learning", desc: "Access course video lectures, assignments, and study materials anytime at your own pace through SWAYAM/NPTEL portal." },
  { title: "Earn Extra Credits", desc: "NPTEL certification credits can be transferred to your academic record as per GTU and institute credit transfer policy." },
  { title: "Industry-Recognised Certification", desc: "NPTEL certificates are valued by top companies and are an excellent addition to your resume during placements." },
  { title: "Wide Course Selection", desc: "Hundreds of courses across engineering, science, humanities, and management to complement your diploma studies." },
  { title: "Faculty Development Programmes", desc: "Faculty members can upskill and earn NPTEL certifications through the Faculty Development Programme (FDP) track." },
];

const howItWorks = [
  { step: "1", title: "Register on SWAYAM", desc: "Create a free account on swayam.gov.in and enrol in any NPTEL course of your choice." },
  { step: "2", title: "Study the Course", desc: "Watch video lectures, read materials, and attempt weekly assignments throughout the course duration (typically 4–12 weeks)." },
  { step: "3", title: "Appear for the Proctored Exam", desc: "Register for and appear in the in-person proctored certification exam conducted at registered exam centres." },
  { step: "4", title: "Earn Your Certificate", desc: "Score at least 40% in the exam (with weightage to assignments) to earn an NPTEL certificate from the IITs." },
];
---

<Layout title="SWAYAM-NPTEL Local Chapter | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/campus-life" class="hover:text-primary transition-colors">Campus Life</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">SWAYAM-NPTEL Local Chapter</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Local Chapter</div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">SWAYAM-NPTEL Local Chapter</h1>
          <p class="text-lg text-gray-600 mb-6">
            Government Polytechnic Palanpur is a registered SWAYAM-NPTEL Local Chapter, enabling students and faculty to pursue IIT-quality online courses and earn nationally recognised certifications.
          </p>
          <div class="flex flex-wrap gap-3">
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">1000+</div>
              <div class="text-xs text-gray-500">Courses Available</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">IIT</div>
              <div class="text-xs text-gray-500">Certified</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">Free</div>
              <div class="text-xs text-gray-500">Enrolment</div>
            </div>
          </div>
        </div>
        <div class="w-40 h-40 bg-primary/10 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-20 h-20 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- About NPTEL Local Chapter -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About SWAYAM-NPTEL</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-4">
        <p>
          NPTEL (National Programme on Technology Enhanced Learning) is a joint initiative of the IITs and IISc, funded by the Ministry of Education (MoE), Government of India. Since 2003, NPTEL has been offering high-quality online courses across engineering, science, and humanities. From March 2014, NPTEL has been offering online certification for its courses through the SWAYAM platform at <a href="https://swayam.gov.in/NPTEL" target="_blank" rel="noopener noreferrer" class="text-primary underline">swayam.gov.in/NPTEL</a>.
        </p>
        <p>
          To encourage and support student participation, NPTEL has established Local Chapters in colleges across India. As a registered Local Chapter, GP Palanpur has a dedicated Single Point of Contact (SPOC) faculty member who coordinates all NPTEL-related activities — from awareness drives and course enrolments to guiding students through certification exams.
        </p>
        <p>
          The SPOC identifies suitable mentors, ensures students are active in enrolled courses, helps them submit assignments on time, and addresses their doubts, creating a structured, supported learning environment right on campus.
        </p>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="https://swayam.gov.in/NPTEL" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/90 transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Visit SWAYAM Portal
        </a>
        <a href="https://nptel.ac.in" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 border border-primary text-primary px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/5 transition-colors text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Visit NPTEL Portal
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">How to Earn an NPTEL Certificate</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {howItWorks.map(h => (
          <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm text-center">
            <div class="w-12 h-12 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white text-lg font-bold">{h.step}</span>
            </div>
            <h3 class="font-bold text-gray-900 mb-2 text-sm">{h.title}</h3>
            <p class="text-gray-600 text-xs leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Benefits of NPTEL Certification</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {benefits.map(b => (
          <div class="flex gap-4 bg-primary/5 rounded-xl p-5">
            <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 text-sm mb-1">{b.title}</h3>
              <p class="text-gray-600 text-xs leading-relaxed">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPOC Info -->
  <section class="py-14 bg-sky-50 border-y border-sky-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="flex-1">
          <h2 class="text-2xl font-bold text-gray-900 mb-3">Contact the NPTEL SPOC</h2>
          <p class="text-gray-600 mb-4 text-sm leading-relaxed">
            For course enrolment guidance, exam registration, assignment support, or any queries related to NPTEL certifications, contact the institute's NPTEL Single Point of Contact (SPOC) faculty member.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/90 transition-colors text-sm">
              Contact the Institute
            </a>
            <a href="mailto:localchapter@nptel.iitm.ac.in" class="inline-flex items-center gap-2 border border-gray-300 text-gray-700 px-5 py-2.5 rounded-lg font-semibold hover:bg-gray-50 transition-colors text-sm">
              NPTEL LC Helpdesk
            </a>
          </div>
        </div>
        <div class="bg-white rounded-2xl p-6 border border-sky-200 shadow-sm w-full md:w-64 flex-shrink-0">
          <h3 class="font-bold text-gray-900 mb-3 text-sm">NPTEL Helpline</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              localchapter@nptel.iitm.ac.in
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              7200043633 (Mon–Fri, 9am–6pm)
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
