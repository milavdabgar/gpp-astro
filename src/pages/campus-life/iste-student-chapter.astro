---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const activities = [
  { title: "Weekly Quiz Programmes", desc: "Regular quiz competitions for members covering technical and general topics to sharpen knowledge and competitive spirit." },
  { title: "Expert Lectures", desc: "Lectures by experts from industry, R&D organisations, defence services, government departments, and other institutions." },
  { title: "Competitive Exam Coaching", desc: "Coaching programmes to help students prepare for competitive examinations and job interviews." },
  { title: "Report Writing & Project Management Training", desc: "Workshops on professional report writing skills and project management methodologies." },
  { title: "Cultural Programmes", desc: "Cultural events and programmes that promote creativity, talent, and camaraderie among students." },
  { title: "Counselling Services", desc: "Academic and career counselling to guide students in making informed decisions about their future." },
  { title: "Entrepreneurship Development", desc: "Programmes to foster entrepreneurial thinking and equip students with skills to start and manage ventures." },
  { title: "Moral Values & Ethics Lectures", desc: "Sessions focusing on professional ethics, moral values, and responsible citizenship." },
  { title: "Discussions & Brain-Storming Sessions", desc: "Group activities, discussions, and brain-storming sessions on technical and contemporary topics." },
  { title: "Public Speaking Training", desc: "Training in public speaking, presentation skills, and effective communication." },
  { title: "Master Student Training", desc: "Programmes focused on learning how to learn — study techniques, time management, and academic excellence." },
  { title: "Industry & Work-Site Visits", desc: "Organised visits to industries and work sites to expose students to real-world engineering environments." },
  { title: "Leadership & Personality Development", desc: "Programmes in leadership skills, personality development, and professional grooming." },
  { title: "Co-operative Learning Training", desc: "Training in collaborative and co-operative learning approaches for better academic outcomes." },
  { title: "Environmental Awareness", desc: "Training and awareness programmes on environmental issues, sustainability, and green practices." },
  { title: "Basic Management Skills", desc: "Training on foundational management skills relevant to engineering professionals." },
];
---

<Layout title="ISTE Student Chapter | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/campus-life" class="hover:text-primary transition-colors">Campus Life</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">ISTE Student Chapter</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Student Chapter</div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">ISTE Student Chapter</h1>
          <p class="text-lg text-gray-600 mb-6">Indian Society for Technical Education — Student Chapter at Government Polytechnic Palanpur. Developing well-rounded technical professionals beyond the classroom.</p>
          <div class="flex flex-wrap gap-3">
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">All</div>
              <div class="text-xs text-gray-500">Departments</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">16</div>
              <div class="text-xs text-gray-500">Activity Types</div>
            </div>
            <div class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-center">
              <div class="text-2xl font-bold text-primary">NBA</div>
              <div class="text-xs text-gray-500">Aligned</div>
            </div>
          </div>
        </div>
        <div class="w-40 h-40 bg-primary/10 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-20 h-20 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- About ISTE -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About ISTE</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-4">
        <p>
          The Indian Society for Technical Education (ISTE) is the leading national professional organisation for technical education in India, founded in 1941. ISTE is dedicated to the professional development of teachers and students in technical education institutions, and to facilitating the production of quality technical manpower in the country.
        </p>
        <p>
          The ISTE Student Chapter at GP Palanpur brings together students from all engineering departments under a common platform for technical and professional development. The chapter organises a broad spectrum of activities designed to complement academic learning and prepare students for industry and competitive examinations.
        </p>
      </div>
    </div>
  </section>

  <!-- NBA Note -->
  <section class="py-10 bg-amber-50 border-y border-amber-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="flex gap-4 items-start">
        <div class="w-10 h-10 bg-amber-500 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <h3 class="font-bold text-amber-900 text-lg mb-1">Note for NBA Compliance</h3>
          <p class="text-amber-800 text-sm leading-relaxed">
            All activities listed below are recognised ISTE Student Chapter activities. Since many of these activities are routinely conducted at the individual department level, every department is free to include and mention such activities in its reports and compliance documentation when preparing for NBA accreditation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Activities -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">ISTE Chapter Activities</h2>
      <p class="text-gray-500 mb-8">The following activities are considered official ISTE Student Chapter activities and are conducted across departments.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {activities.map((a, i) => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex gap-4">
            <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
              <span class="text-white text-xs font-bold">{i + 1}</span>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 mb-1 text-sm">{a.title}</h3>
              <p class="text-gray-600 text-xs leading-relaxed">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Join -->
  <section class="py-14 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Join the ISTE Student Chapter</h2>
      <p class="text-gray-600 mb-6">Open to all diploma students at GP Palanpur across all departments. Contact your department's faculty coordinator or the institute's ISTE chapter coordinator to register your membership.</p>
      <a href="/contact" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
