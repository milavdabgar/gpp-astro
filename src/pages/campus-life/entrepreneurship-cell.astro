---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const activities = [
  {
    srNo: 1,
    date: "Feb 2023",
    activity: "Entrepreneurship Awareness Camp",
    expertLocation: "SSIP Cell, GPP Campus",
    beneficiaries: 120,
    remark: "Students from all departments",
  },
  {
    srNo: 2,
    date: "Jul 2023",
    activity: "CED Gandhinagar Visit & FDP",
    expertLocation: "Centre for Entrepreneurship Development (CED), Gandhinagar",
    beneficiaries: 8,
    remark: "Faculty members attended FDP",
  },
  {
    srNo: 3,
    date: "Sep 2023",
    activity: "SSIP Awareness Session — All Departments",
    expertLocation: "SSIP Coordinator, GPP",
    beneficiaries: 250,
    remark: "For students of all departments",
  },
  {
    srNo: 4,
    date: "Nov 2023",
    activity: "Successful Entrepreneur Talk",
    expertLocation: "Mr. Darshit Patel, Tech Startup Founder",
    beneficiaries: 60,
    remark: "Startup ideas and mentorship",
  },
  {
    srNo: 5,
    date: "Jan 2024",
    activity: "IPR & Patent Awareness Workshop",
    expertLocation: "Prof. SSIP Coordinator, GPP",
    beneficiaries: 80,
    remark: "Focused on IP rights for student projects",
  },
  {
    srNo: 6,
    date: "Mar 2024",
    activity: "Career Options After Diploma — Guidance Session",
    expertLocation: "Industry expert, Palanpur",
    beneficiaries: 130,
    remark: "For final-year students",
  },
  {
    srNo: 7,
    date: "Sep 2024",
    activity: "Internal Hackathon for Smart India Hackathon (SIH 2024)",
    expertLocation: "SSIP Cell & Departments, GPP",
    beneficiaries: 180,
    remark: "Shortlisted teams sent for SIH",
  },
  {
    srNo: 8,
    date: "Jan 2025",
    activity: "SSIP Project Showcase & Exhibition",
    expertLocation: "GPP Campus",
    beneficiaries: 300,
    remark: "Display of student innovation projects",
  },
  {
    srNo: 9,
    date: "Mar 2025",
    activity: "EDI Gandhinagar Campus Visit",
    expertLocation: "Entrepreneurship Development Institute of India (EDI), Gandhinagar",
    beneficiaries: 40,
    remark: "Industrial & startup exposure tour",
  },
  {
    srNo: 10,
    date: "Feb 2026",
    activity: "Startup Pitch Day — SSIP 2.0",
    expertLocation: "SSIP Expert Panel, GPP",
    beneficiaries: 90,
    remark: "Students pitched startup ideas for SSIP funding",
  },
];
---

<Layout title="Entrepreneurship Cell | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <a href="/campus-life" class="hover:text-primary transition-colors">Campus Life</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Entrepreneurship Cell</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-orange-50 to-yellow-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-orange-100 rounded-full mb-6">
        <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Entrepreneurship Cell</h1>
      <p class="text-lg text-gray-600">Fostering entrepreneurial spirit and innovation among students at Government Polytechnic Palanpur through awareness, mentorship, and hands-on programs.</p>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="bg-orange-600 py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
        <div><div class="text-3xl font-extrabold">10+</div><div class="text-orange-200 text-sm mt-1">Activities Conducted</div></div>
        <div><div class="text-3xl font-extrabold">1300+</div><div class="text-orange-200 text-sm mt-1">Students Benefitted</div></div>
        <div><div class="text-3xl font-extrabold">5+</div><div class="text-orange-200 text-sm mt-1">Funded SSIP Projects</div></div>
        <div><div class="text-3xl font-extrabold">2</div><div class="text-orange-200 text-sm mt-1">SIH Teams Qualified</div></div>
      </div>
    </div>
  </section>

  <!-- About ED Cell -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">About the Entrepreneurship Cell</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        The Entrepreneurship Development (ED) Cell at Government Polytechnic Palanpur works in collaboration with Government of Gujarat's Student Startup and Innovation Policy (SSIP) Cell to foster an entrepreneurial spirit among students and faculty.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        Our activities span from awareness programs, expert talks, and career guidance sessions to hands-on workshops on IPR (Intellectual Property Rights), startup ideation, and prototype development. The cell actively supports student participation in national events like Smart India Hackathon (SIH) and EDI Gandhinagar visits.
      </p>
      <p class="text-gray-600 leading-relaxed">
        Students who develop innovative ideas are guided through the SSIP 2.0 funding process where promising projects receive government financial support to develop prototypes and launch startups.
      </p>

      <!-- Key Focus Areas -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-8">
        {["Entrepreneurship Awareness", "Startup Ideation", "IPR & Patents", "SSIP Funding", "Mentorship", "Industry Visits"].map((focus) => (
          <div class="flex items-center gap-2 bg-orange-50 rounded-lg px-4 py-3">
            <svg class="h-5 w-5 text-orange-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm font-medium text-gray-800">{focus}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Activities Table -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Activities Under ED Cell – SSIP Collaboration</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-orange-600 text-white text-left">
              <th class="px-4 py-3">#</th>
              <th class="px-4 py-3">Date</th>
              <th class="px-4 py-3">Activity</th>
              <th class="px-4 py-3">Expert / Location</th>
              <th class="px-4 py-3 text-center">Beneficiaries</th>
              <th class="px-4 py-3">Remark</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {activities.map((a) => (
              <tr class="hover:bg-orange-50 transition-colors">
                <td class="px-4 py-3 text-gray-500 font-mono">{a.srNo}</td>
                <td class="px-4 py-3 text-gray-600 whitespace-nowrap">{a.date}</td>
                <td class="px-4 py-3 text-gray-800 font-medium">{a.activity}</td>
                <td class="px-4 py-3 text-gray-600">{a.expertLocation}</td>
                <td class="px-4 py-3 text-center font-semibold text-gray-800">{a.beneficiaries}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">{a.remark}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Alumni Entrepreneurs -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">GPP Alumni Entrepreneurs</h2>
      <p class="text-gray-600 mb-6">
        Many GPP alumni have gone on to establish successful ventures across various industries. Their achievements inspire current students and demonstrate the power of technical education combined with entrepreneurial drive.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          "Manufacturing & industrial solutions in Palanpur region",
          "Construction & civil contracting businesses",
          "Electronics repair & service centers",
          "Agricultural technology solutions for North Gujarat",
          "IT services and automation consulting",
          "Sustainable energy installation businesses",
        ].map((area) => (
          <div class="flex items-start gap-3 bg-orange-50 rounded-lg px-4 py-3">
            <svg class="h-5 w-5 text-orange-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01" />
            </svg>
            <span class="text-sm text-gray-700">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl text-center">
      <h2 class="text-xl font-bold text-gray-900 mb-3">Get Involved</h2>
      <p class="text-gray-600 mb-5 text-sm">
        Students with an innovative idea or interest in entrepreneurship are welcome to connect with the SSIP/ED Cell at GPP for mentorship and funding opportunities.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/ssip" class="bg-orange-600 text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-orange-700 transition-colors">SSIP Cell</a>
        <a href="/contact" class="border border-orange-600 text-orange-600 px-6 py-2.5 rounded-lg font-semibold hover:bg-orange-50 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
