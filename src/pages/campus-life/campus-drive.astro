---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const upcomingDrives = [
  {
    company: "L&T Construction",
    date: "March 18, 2026",
    branches: ["Civil Engineering", "Mechanical Engineering"],
    roles: ["Site Engineer Trainee", "Junior Engineer"],
    package: "₹3.0–3.5 LPA",
    mode: "On-Campus",
    status: "Registration Open",
  },
  {
    company: "Torrent Power Ltd.",
    date: "March 25, 2026",
    branches: ["Electrical Engineering"],
    roles: ["Junior Technician", "Apprentice Engineer"],
    package: "₹2.8–3.2 LPA",
    mode: "On-Campus",
    status: "Registration Open",
  },
  {
    company: "BCM Computers",
    date: "April 5, 2026",
    branches: ["Computer Engineering", "Information Technology"],
    roles: ["Junior Developer", "Support Engineer"],
    package: "₹2.4–3.0 LPA",
    mode: "On-Campus",
    status: "Coming Soon",
  },
  {
    company: "Gujarat Gas Ltd.",
    date: "April 12, 2026",
    branches: ["Mechanical Engineering", "Chemical Engineering"],
    roles: ["Field Technician", "Maintenance Engineer"],
    package: "₹2.6–3.0 LPA",
    mode: "On-Campus",
    status: "Coming Soon",
  },
];

const pastDrives = [
  { company: "Adani Group", month: "Feb 2026", placed: 12, branches: "CE/EE/ME" },
  { company: "Suzlon Energy", month: "Jan 2026", placed: 8, branches: "EE/ME" },
  { company: "Tata Projects", month: "Dec 2025", placed: 6, branches: "CE" },
  { company: "GSRTC", month: "Nov 2025", placed: 10, branches: "ME" },
  { company: "Reliance Industries", month: "Oct 2025", placed: 5, branches: "ME/EC" },
  { company: "ONGC", month: "Sep 2025", placed: 4, branches: "ME/EE" },
];

const eligibility = [
  "Enrolled in final year of diploma program at GPP",
  "No active backlogs at time of registration",
  "Minimum 55% aggregate (may vary by company)",
  "Registered with TPO cell before the registration deadline",
  "Must carry valid college ID and resume on drive day",
];
---

<Layout title="Campus Drives | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/campus-life" class="hover:text-primary transition-colors">Campus Life</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Campus Drives</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Campus Drives</h1>
      <p class="text-lg text-gray-600">Upcoming and past on-campus recruitment drives at Government Polytechnic Palanpur</p>
    </div>
  </section>

  <!-- Eligibility -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
        <h2 class="text-lg font-bold text-amber-900 mb-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          General Eligibility Criteria
        </h2>
        <ul class="space-y-2">
          {eligibility.map(e => (
            <li class="flex items-start gap-2 text-sm text-amber-800">
              <svg class="w-4 h-4 text-amber-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              {e}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Upcoming Drives -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Upcoming Campus Drives</h2>
      <div class="space-y-6">
        {upcomingDrives.map(drive => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:border-primary/30 transition-colors">
            <div class="flex flex-col md:flex-row">
              <div class="bg-primary/5 border-r border-gray-100 p-6 md:w-56 flex flex-col justify-center text-center md:text-left">
                <div class="text-sm text-gray-500 mb-1">Drive Date</div>
                <div class="font-bold text-gray-900 text-base">{drive.date}</div>
                <div class="mt-2">
                  <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${drive.status === 'Registration Open' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800'}`}>
                    {drive.status}
                  </span>
                </div>
              </div>
              <div class="p-6 flex-1">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                  <h3 class="text-xl font-bold text-gray-900">{drive.company}</h3>
                  <span class="bg-primary/10 text-primary text-sm font-semibold px-3 py-1 rounded-full">{drive.package}</span>
                </div>
                <div class="flex flex-wrap gap-4 text-sm text-gray-600 mb-3">
                  <div>
                    <span class="font-medium text-gray-800">Branches: </span>
                    {drive.branches.join(", ")}
                  </div>
                  <div>
                    <span class="font-medium text-gray-800">Mode: </span>
                    {drive.mode}
                  </div>
                </div>
                <div class="text-sm text-gray-600">
                  <span class="font-medium text-gray-800">Roles: </span>
                  {drive.roles.join(", ")}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Past Drives -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Recent Past Drives</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Company</th>
              <th class="px-5 py-3 font-semibold">Month</th>
              <th class="px-5 py-3 font-semibold text-center">Students Placed</th>
              <th class="px-5 py-3 font-semibold">Branches</th>
            </tr>
          </thead>
          <tbody>
            {pastDrives.map((d, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">{d.company}</td>
                <td class="px-5 py-3 text-gray-700">{d.month}</td>
                <td class="px-5 py-3 text-center font-semibold text-primary">{d.placed}</td>
                <td class="px-5 py-3 text-gray-700">{d.branches}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Invite for campus drive -->
  <section class="py-14 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Invite GPP for Your Campus Drive</h2>
      <p class="text-gray-600 mb-6">Companies interested in recruiting diploma engineers from GPP can contact the Training & Placement Office to schedule a campus visit.</p>
      <a href="/tpo" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">
        Contact TPO
      </a>
    </div>
  </section>

  <Footer />
</Layout>
