---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const services = [
  { title: "Student Records",    desc: "Maintenance of comprehensive student academic and personal records",                  icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
  { title: "Scholarships",       desc: "Information and assistance for various scholarship programs",                         icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" },
  { title: "Student Welfare",    desc: "Support services for student health, counseling, and well-being",                    icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
  { title: "Events & Activities", desc: "Organization of cultural, sports, and extracurricular activities",                  icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" },
  { title: "Announcements",      desc: "Important notices, circulars, and institutional communications",                     icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" },
  { title: "Student Committees", desc: "Support for student councils and representative committees",                         icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
];
---

<Layout title="Student Section | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Student Services</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Support & Welfare</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Official Updates</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Student Section</h1>
      <p class="text-xl text-gray-600 mb-8">Your one-stop destination for all student-related services, information, and support at Government Polytechnic Palanpur. Stay connected and informed about campus life.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">2000+</div><div class="text-sm text-gray-600">Active Students</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">50+</div><div class="text-sm text-gray-600">Annual Events</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">6</div><div class="text-sm text-gray-600">Student Clubs</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">24/7</div><div class="text-sm text-gray-600">Support Available</div></div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Dedicated to Student Success</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>The Student Section at Government Polytechnic Palanpur is committed to providing comprehensive support services that enhance the overall student experience. From academic assistance to personal welfare, we ensure every student feels supported throughout their educational journey.</p>
            <p>Our team manages student records, facilitates scholarship programs, organizes cultural and sports events, and maintains regular communication with students through various channels including our dedicated blog platform.</p>
            <p>Stay updated with the latest announcements, events, achievements, and important information through our official student section blog, which serves as the primary communication channel for all student-related matters.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-primary/5 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-primary">2000+</div>
            <div class="text-sm text-gray-600 mt-1">Enrolled Students</div>
          </div>
          <div class="bg-blue-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-blue-600">6</div>
            <div class="text-sm text-gray-600 mt-1">Active Clubs</div>
          </div>
          <div class="bg-green-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-green-600">50+</div>
            <div class="text-sm text-gray-600 mt-1">Annual Events</div>
          </div>
          <div class="bg-purple-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-purple-600">100%</div>
            <div class="text-sm text-gray-600 mt-1">Scholarship Support</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Student Support Services</h2>
        <p class="text-gray-600 max-w-xl mx-auto">Comprehensive services designed to support your academic and personal growth</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="bg-white rounded-xl p-6 text-center border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Official Blog -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="bg-primary/5 border border-primary/20 rounded-xl p-8 text-center">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Official Student Section Blog</h2>
        <p class="text-gray-600 mb-6">Stay connected with the latest news, announcements, events, and important updates from the student section through our dedicated blog platform.</p>
        <div class="grid sm:grid-cols-2 gap-3 mb-6 text-sm text-gray-600">
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
            Latest announcements and notices
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Event schedules and updates
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            Student achievements
          </div>
          <div class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Important circulars and notices
          </div>
        </div>
        <a href="https://gpstudentsection.blogspot.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors text-sm">
          Visit Student Section Blog
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Quick Links</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[["Announcements", "/announcements"], ["Admissions", "/admissions"], ["Library", "/library"], ["SSIP Cell", "/ssip"], ["TPO Cell", "/tpo"], ["Contact", "/contact"]].map(([label, href]) => (
          <a href={href} class="text-sm font-medium border border-gray-200 rounded-lg px-4 py-2 text-gray-700 hover:border-primary hover:text-primary transition-colors bg-white">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
