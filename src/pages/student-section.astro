---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const antiRaggingCommittee = [
  { name: "Shri D.D. Prajapati", role: "I/C HOD, Mechanical Dept.", position: "Convener", phone: "9429890717", email: "gppmech19@gmail.com" },
  { name: "Shri I.P. Kharodiya",  role: "Store Keeper",             position: "Member",   phone: "9426208612", email: "ibrhimp1971@gmail.com" },
  { name: "Student Representative", role: "Student",                position: "Member",   phone: "—",          email: "—" },
];

const womenCommittee = [
  { name: "Mrs. M.M. Shah",    role: "Lecturer-ICT Dept.",   position: "Convener" },
  { name: "Shri V.G. Patel",   role: "Lecturer, Mech. Dept.", position: "Member" },
  { name: "Mrs. M.K. Pedhadiya", role: "Lecturer, EC Dept.", position: "Member" },
  { name: "Mrs. F.M. Patel",   role: "Lecturer, Civil Dept.", position: "Member" },
  { name: "Mrs. P.D. Sheth",   role: "Lecturer, Civil Dept.", position: "Member" },
];

const scstCell = [
  { name: "Shri Chiragkumar Amin", role: "Lecturer, Civil Dept.",   position: "Convener", email: "chiragamin29@gmail.com" },
  { name: "Mrs. Payal Chauhan",    role: "Lecturer, Mech. Dept.",   position: "Member",   email: "payalmech001@gmail.com" },
  { name: "Shri Yagnik Rana",      role: "Lecturer, Civil Dept.",   position: "Member",   email: "ranayagnik@gmail.com" },
];
---

<Layout title="Student Section | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Student Services</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Welfare & Support</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Campus Life</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Student Section</h1>
      <p class="text-xl text-gray-600 mb-8">Your one-stop hub for hostel, welfare committees, sports, NSS, scholarships, and all student-related information at Government Polytechnic Palanpur.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">2000+</div><div class="text-sm text-gray-600">Enrolled Students</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">312</div><div class="text-sm text-gray-600">Hostel Seats</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">5</div><div class="text-sm text-gray-600">Welfare Committees</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">3+</div><div class="text-sm text-gray-600">Sports Grounds</div></div>
      </div>
    </div>
  </section>

  <!-- Hostel Facilities -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Hostel Facilities</h2>
        <p class="text-gray-600 max-w-xl mx-auto">On-campus residential facilities ensuring a safe and supportive environment for outstation students</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Boys Hostel -->
        <div class="bg-blue-50 rounded-2xl p-8 border border-blue-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Boys Hostel</h3>
              <span class="text-blue-600 text-sm font-medium">3 Blocks</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-white rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-blue-600">264</div>
              <div class="text-xs text-gray-600 mt-1">Total Seats</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-blue-600">3</div>
              <div class="text-xs text-gray-600 mt-1">Hostel Blocks</div>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Separate rooms with basic amenities</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>24/7 warden supervision</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>CCTV security coverage</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Mess/dining facility</li>
          </ul>
        </div>
        <!-- Girls Hostel -->
        <div class="bg-pink-50 rounded-2xl p-8 border border-pink-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 bg-pink-600 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">Girls Hostel</h3>
              <span class="text-pink-600 text-sm font-medium">1 Block</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-white rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-pink-600">48</div>
              <div class="text-xs text-gray-600 mt-1">Total Seats</div>
            </div>
            <div class="bg-white rounded-xl p-4 text-center">
              <div class="text-2xl font-bold text-pink-600">1</div>
              <div class="text-xs text-gray-600 mt-1">Hostel Block</div>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Secure & dedicated girls facility</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Lady warden 24/7</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>CCTV security coverage</li>
            <li class="flex items-center gap-2"><svg class="w-4 h-4 text-pink-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Separate mess facility</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sports & Campus Amenities -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Sports & Campus Amenities</h2>
        <p class="text-gray-600 max-w-xl mx-auto">Modern facilities for holistic development beyond academics</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl p-6 text-center border border-gray-100 shadow-sm">
          <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21l1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Outdoor Sports</h3>
          <p class="text-gray-500 text-sm">Cricket, Football, Volleyball, Basketball grounds — 13,950 sq.ft sports area</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center border border-gray-100 shadow-sm">
          <div class="w-14 h-14 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Gymnasium</h3>
          <p class="text-gray-500 text-sm">Fully equipped gym/sports room for indoor fitness activities</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center border border-gray-100 shadow-sm">
          <div class="w-14 h-14 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 1 1 0 5.292M15 21H3v-1a6 6 0 0 1 12 0v1zm0 0h6v-1a6 6 0 0 0-9-5.197M13 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0z"/></svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">NSS Program</h3>
          <p class="text-gray-500 text-sm">National Service Scheme with annual camps, blood donation drives, and community service</p>
        </div>
        <div class="bg-white rounded-xl p-6 text-center border border-gray-100 shadow-sm">
          <div class="w-14 h-14 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-8 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">Student Canteen</h3>
          <p class="text-gray-500 text-sm">On-campus canteen (352 sq.m) providing affordable and nutritious meals</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Anti-Ragging Committee -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Anti-Ragging Committee</h2>
          <p class="text-gray-600">GP Palanpur maintains a strict zero-tolerance policy against ragging. Our Anti-Ragging Committee is constituted as per GTU guidelines (Order No. GPP/ANTI-RAGGING/2025/1378).</p>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-xl p-6 mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-red-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.07 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            <div>
              <h4 class="font-bold text-red-800 mb-1">Anti-Ragging Helpline</h4>
              <p class="text-red-700 text-sm">UGC Anti-Ragging Helpline: <strong>1800-180-5522</strong> (Toll Free) | Campus: <strong>02742-262115</strong></p>
              <p class="text-red-700 text-sm mt-1">Report online at: <strong>www.antiragging.in</strong></p>
            </div>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-4 py-3 text-left font-semibold">Name</th>
                <th class="px-4 py-3 text-left font-semibold">Designation</th>
                <th class="px-4 py-3 text-left font-semibold">Role</th>
                <th class="px-4 py-3 text-left font-semibold">Mobile</th>
              </tr>
            </thead>
            <tbody>
              {antiRaggingCommittee.map((m, i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                  <td class="px-4 py-3 font-medium text-gray-900">{m.name}</td>
                  <td class="px-4 py-3 text-gray-600">{m.role}</td>
                  <td class="px-4 py-3"><span class={`inline-block text-xs font-semibold rounded-full px-2.5 py-0.5 ${m.position === 'Convener' ? 'bg-primary/10 text-primary' : 'bg-gray-100 text-gray-600'}`}>{m.position}</span></td>
                  <td class="px-4 py-3 text-gray-600">{m.phone}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Women's Development Committee -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Women's Development Committee</h2>
          <p class="text-gray-600">Dedicated to ensuring a safe, respectful, and conducive environment for women students and staff (Order: GPP/EST/Work Distribution/662, dated 4-Jul-2024).</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
            <thead class="bg-pink-600 text-white">
              <tr>
                <th class="px-4 py-3 text-left font-semibold">Name</th>
                <th class="px-4 py-3 text-left font-semibold">Designation</th>
                <th class="px-4 py-3 text-left font-semibold">Role</th>
              </tr>
            </thead>
            <tbody>
              {womenCommittee.map((m, i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                  <td class="px-4 py-3 font-medium text-gray-900">{m.name}</td>
                  <td class="px-4 py-3 text-gray-600">{m.role}</td>
                  <td class="px-4 py-3"><span class={`inline-block text-xs font-semibold rounded-full px-2.5 py-0.5 ${m.position === 'Convener' ? 'bg-pink-100 text-pink-700' : 'bg-gray-100 text-gray-600'}`}>{m.position}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- SC/ST Cell -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">SC / ST Cell</h2>
          <p class="text-gray-600">The SC/ST Cell is constituted as per GTU instructions to address grievances and support students from Scheduled Castes and Scheduled Tribes.</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
            <thead class="bg-green-700 text-white">
              <tr>
                <th class="px-4 py-3 text-left font-semibold">Name</th>
                <th class="px-4 py-3 text-left font-semibold">Designation</th>
                <th class="px-4 py-3 text-left font-semibold">Role</th>
                <th class="px-4 py-3 text-left font-semibold">Email</th>
              </tr>
            </thead>
            <tbody>
              {scstCell.map((m, i) => (
                <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                  <td class="px-4 py-3 font-medium text-gray-900">{m.name}</td>
                  <td class="px-4 py-3 text-gray-600">{m.role}</td>
                  <td class="px-4 py-3"><span class={`inline-block text-xs font-semibold rounded-full px-2.5 py-0.5 ${m.position === 'Convener' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600'}`}>{m.position}</span></td>
                  <td class="px-4 py-3 text-gray-500">{m.email}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Official Blog -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="bg-primary/5 border border-primary/20 rounded-xl p-8 text-center">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Official Student Section Blog</h2>
        <p class="text-gray-600 mb-6">Stay connected with the latest news, announcements, events, and important updates from the student section.</p>
        <a href="https://gpstudentsection.blogspot.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors text-sm">
          Visit Student Section Blog
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Quick Links</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {[["Announcements", "/announcements"], ["Notice Board", "/student-section/notice-board"], ["Scholarships", "/admissions/scholarship"], ["Library", "/library"], ["SSIP Cell", "/ssip"], ["TPO Cell", "/tpo"], ["Contact", "/contact"]].map(([label, href]) => (
          <a href={href} class="text-sm font-medium border border-gray-200 rounded-lg px-4 py-2 text-gray-700 hover:border-primary hover:text-primary transition-colors bg-white">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
