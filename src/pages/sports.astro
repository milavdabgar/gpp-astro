---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const sports = [
  {
    name: "Cricket",
    desc: "Dedicated cricket ground with pitch facilities for practice and inter-college matches. Students participate at district and state-level competitions.",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    color: "green",
  },
  {
    name: "Volleyball",
    desc: "Volleyball court for both men's and women's teams. Regular practice sessions and participation in GTU inter-college tournaments.",
    icon: "M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z",
    color: "blue",
  },
  {
    name: "Kabaddi",
    desc: "Traditional Indian sport with active teams representing GPP in district-level and GTU inter-polytechnic competitions.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    color: "orange",
  },
  {
    name: "Carrom & Chess",
    desc: "Indoor sports available for students to unwind and develop strategic thinking. Regular tournaments held within the college.",
    icon: "M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2",
    color: "purple",
  },
  {
    name: "Kho-Kho",
    desc: "Teams practicing Kho-Kho on the campus ground. Students actively participate in GTU and district sports festivals.",
    icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z",
    color: "red",
  },
  {
    name: "Athletics",
    desc: "Track and field activities including running, long jump, and shot put for annual sports events and inter-college competitions.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    color: "teal",
  },
];

const achievements = [
  { year: "2024-25", event: "District Level Volleyball", team: "Men's Volleyball Team", position: "Runners-Up" },
  { year: "2024-25", event: "GTU Inter-Polytechnic Cricket", team: "Cricket Team", position: "Participant" },
  { year: "2023-24", event: "District Kabaddi Championship", team: "Men's Kabaddi Team", position: "Participant" },
  { year: "2023-24", event: "GTU Sports Week", team: "Multi-sport Teams", position: "Participant" },
];

const colorBg: Record<string, string> = {
  green: "bg-green-50 border-green-200",
  blue: "bg-blue-50 border-blue-200",
  orange: "bg-orange-50 border-orange-200",
  purple: "bg-purple-50 border-purple-200",
  red: "bg-red-50 border-red-200",
  teal: "bg-teal-50 border-teal-200",
};
const colorText: Record<string, string> = {
  green: "text-green-600", blue: "text-blue-600", orange: "text-orange-600",
  purple: "text-purple-600", red: "text-red-600", teal: "text-teal-600",
};
---

<Layout title="Sports | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-green-600 to-teal-700 text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-white/20 text-white rounded-full px-3 py-1">Sports & Athletics</span>
        <span class="text-xs font-semibold border border-white/30 text-white rounded-full px-3 py-1">Campus Life</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Sports at GP Palanpur</h1>
      <p class="text-xl text-green-100 mb-8">
        Promoting physical fitness, teamwork, and sportsmanship with dedicated grounds and annual sports events on our 20-acre campus.
      </p>
      <div class="grid grid-cols-3 gap-6 max-w-xl mx-auto">
        <div class="text-center">
          <div class="text-3xl font-bold text-white">6+</div>
          <div class="text-sm text-green-200">Sports</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">20</div>
          <div class="text-sm text-green-200">Acres Campus</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-white">GTU</div>
          <div class="text-sm text-green-200">Tournaments</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sports Available -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Sports Offered</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          A range of outdoor and indoor sports available for students throughout the academic year.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sports.map((sport) => (
          <div class={`p-6 rounded-xl border ${colorBg[sport.color]} hover:shadow-md transition-shadow`}>
            <div class="flex items-start gap-4">
              <div class={`p-2 rounded-lg bg-white/70 flex-shrink-0`}>
                <svg class={`w-6 h-6 ${colorText[sport.color]}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={sport.icon}/>
                </svg>
              </div>
              <div>
                <h3 class={`font-bold text-gray-900 mb-2`}>{sport.name}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{sport.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Annual Sports Day -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Annual Sports Events</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Government Polytechnic Palanpur conducts an Annual Sports Day every year where students
            compete in various track and field events. The event is a celebration of student talent,
            fitness, and team spirit.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Students also participate in GTU Inter-Polytechnic Sports Tournaments, district-level
            competitions, and events organized by the Commissionerate of Technical Education, Gujarat.
          </p>
          <ul class="space-y-3">
            {[
              "Annual Sports Day celebration",
              "GTU Inter-Polytechnic tournaments",
              "District-level competitions",
              "NSS-organized fitness camps",
              "Yoga and wellness programs",
            ].map((item) => (
              <li class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></div>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <h3 class="font-bold text-gray-900 mb-4 text-lg">Recent Achievements</h3>
          <div class="space-y-3">
            {achievements.map((a) => (
              <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 flex-shrink-0">{a.year}</span>
                <div>
                  <div class="text-sm font-medium text-gray-900">{a.event}</div>
                  <div class="text-xs text-gray-500">{a.team} — {a.position}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sports Facilities -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Sports Infrastructure</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {[
          { name: "Cricket Ground", desc: "Dedicated cricket ground with practice pitches on the campus premises." },
          { name: "Volleyball Court", desc: "Outdoor volleyball court for regular practice and inter-team competitions." },
          { name: "Open Play Area", desc: "Large open ground available for kabaddi, kho-kho, athletics, and other sports." },
        ].map((f) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 text-center">
            <div class="inline-flex p-3 rounded-full bg-green-100 mb-4">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{f.name}</h3>
            <p class="text-sm text-gray-600">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
