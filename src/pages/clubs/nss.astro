---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const activities = [
  { title: "Swachh Bharat Abhiyan", desc: "Campus and community cleanliness drives as part of Swachh Bharat initiative near GPP.", period: "Monthly" },
  { title: "Tree Plantation Drive", desc: "Annual plantation of saplings across campus and nearby areas to promote green environment.", period: "Jul–Aug" },
  { title: "Blood Donation Camp", desc: "Bi-annual blood donation camp in collaboration with Palanpur Civil Hospital.", period: "Twice/Year" },
  { title: "Voter Awareness Campaign", desc: "Campaigns to educate youth and community members on their voting rights and responsibility.", period: "Election Season" },
  { title: "Health & Hygiene Awareness", desc: "Health camps and awareness programs for underprivileged communities around Palanpur.", period: "Yearly" },
  { title: "NSS Special Camp", desc: "7-day residential camp in an adopted village for community development activities.", period: "Dec–Jan" },
];

const stats = [
  { label: "Enrolled Volunteers", value: "100+" },
  { label: "Activities/Year", value: "15+" },
  { label: "Hours of Service", value: "2000+" },
  { label: "Villages Adopted", value: "1" },
];

const values = [
  "Social responsibility and community service",
  "Leadership and teamwork in real-world environments",
  "Awareness of national issues and civic duties",
  "Personal development through volunteering",
  "Networking with fellow NSS volunteers across Gujarat",
  "Certificate of participation for career benefits",
];
---

<Layout title="NSS | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/clubs" class="hover:text-primary transition-colors">Clubs & Activities</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">NSS</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <div class="inline-block bg-blue-100 text-blue-800 text-sm font-semibold px-4 py-1 rounded-full mb-4">Social Service</div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">National Service Scheme</h1>
          <p class="text-xl font-semibold text-primary mb-3">"Not Me But You"</p>
          <p class="text-lg text-gray-600">NSS at GPP channels student energy toward community development, social awareness, and nation-building activities.</p>
        </div>
        <div class="w-40 h-40 bg-blue-50 border-2 border-blue-200 rounded-2xl flex items-center justify-center flex-shrink-0">
          <svg class="w-16 h-16 text-blue-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{s.value}</div>
            <div class="text-sm mt-1 text-white/80">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About NSS -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">About NSS at GPP</h2>
      <div class="text-gray-700 space-y-4 leading-relaxed">
        <p>
          The National Service Scheme (NSS) was launched in 1969 with the primary objective of developing the personality and character of student youth through voluntary community service. The NSS unit at Government Polytechnic Palanpur works under the Gujarat University/GTU NSS cell and coordinates with local government bodies and NGOs for community welfare activities.
        </p>
        <p>
          NSS volunteers at GPP put in a minimum of 120 hours of community service per year. Activities range from environmental drives and health awareness campaigns to disaster relief support and rural development projects in villages near Palanpur.
        </p>
        <p>
          The programme aims to develop a sense of the "educated youth's" obligation to society and to put theoretical knowledge to practical use. NSS volunteers are known for their commitment — "Not Me But You" — placing community welfare ahead of personal gain.
        </p>
      </div>
    </div>
  </section>

  <!-- Activities -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Activities & Campaigns</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {activities.map(a => (
          <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <div class="text-xs font-semibold text-blue-700 bg-blue-50 rounded-full px-3 py-1 inline-block mb-3">{a.period}</div>
            <h3 class="font-bold text-gray-900 mb-2">{a.title}</h3>
            <p class="text-gray-600 text-sm">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What You Gain</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {values.map(v => (
          <div class="flex items-start gap-3 bg-blue-50 rounded-xl p-4">
            <div class="w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <p class="text-gray-700 text-sm">{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Special Camp Section -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">NSS Special Camp</h2>
        <p class="text-gray-700 leading-relaxed mb-4">
          Every year, GPP NSS organizes a 7-day Special Camp in an adopted village near Palanpur. During the camp, volunteers live and work in the village, carrying out infrastructure improvement, health surveys, awareness programs, and cultural activities. The camp is a transformative experience that connects urban technical students with rural realities.
        </p>
        <div class="flex flex-wrap gap-4 text-sm">
          <div class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-200">
            <div class="font-semibold text-gray-900">Duration</div>
            <div class="text-gray-600">7 days (Dec–Jan)</div>
          </div>
          <div class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-200">
            <div class="font-semibold text-gray-900">Participants</div>
            <div class="text-gray-600">50–60 volunteers</div>
          </div>
          <div class="bg-gray-50 rounded-lg px-4 py-3 border border-gray-200">
            <div class="font-semibold text-gray-900">Location</div>
            <div class="text-gray-600">Village near Palanpur</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Join CTA -->
  <section class="py-14 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Join NSS at GPP</h2>
      <p class="text-gray-600 mb-6">Enrollment is open to all diploma students at GPP. A minimum commitment of 120 hours of community service per year is expected. Contact the NSS faculty coordinator or the student section.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/student-section/nss" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">NSS Details</a>
        <a href="/contact" class="border border-primary text-primary px-6 py-3 rounded-lg font-semibold hover:bg-primary/5 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
