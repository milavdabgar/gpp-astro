---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import programs from '../../data/programs.json';
import departments from '../../data/departments.json';

const totalSeats = programs.reduce((sum, p) => sum + p.intake_capacity, 0);
const nbaAccredited = programs.filter(p => p.nba_status === "Accredited").length;
---

<Layout title="Academic Programs | GP Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-700">Programs</span>
      </nav>

      <div class="max-w-4xl">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Diploma Programs</h1>
        <p class="text-lg text-gray-600 mb-8">Choose from {programs.length} diploma engineering programs affiliated with Gujarat Technological University, designed to prepare industry-ready professionals.</p>
        
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-3xl font-bold text-primary">{programs.length}</div>
            <div class="text-sm text-gray-500 mt-1">Programs</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-3xl font-bold text-primary">{totalSeats}</div>
            <div class="text-sm text-gray-500 mt-1">Total Seats</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-3xl font-bold text-primary">{nbaAccredited}</div>
            <div class="text-sm text-gray-500 mt-1">NBA Accredited</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-3xl font-bold text-primary">3</div>
            <div class="text-sm text-gray-500 mt-1">Years</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Programs Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {programs.map(program => {
          const dept = departments.find(d => (d.programs_offered as string[]).includes(program.id));
          return (
            <div class="bg-white rounded-xl border border-gray-200 hover:border-primary hover:shadow-lg transition-all overflow-hidden group">
              <div class="bg-gradient-to-br from-primary/5 to-blue-50 p-6 border-b border-gray-100">
                <div class="flex items-start justify-between mb-3">
                  <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary group-hover:scale-110 transition-all">
                    <svg class="w-6 h-6 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                  </div>
                  {program.nba_status === "Accredited" && (
                    <span class="text-xs font-semibold bg-green-100 text-green-800 border border-green-200 rounded-full px-2 py-1">
                      ✓ NBA
                    </span>
                  )}
                  {program.nba_status === "Applying" && (
                    <span class="text-xs font-semibold bg-blue-100 text-blue-800 border border-blue-200 rounded-full px-2 py-1">
                      ⏳ NBA
                    </span>
                  )}
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">{program.short_name}</h3>
                <p class="text-xs text-gray-600">Code: {program.code} | Est. {program.established}</p>
              </div>
              
              <div class="p-6">
                {dept && (
                  <p class="text-xs text-gray-500 mb-3">
                    By <span class="font-medium text-gray-700">{dept.short_name || dept.name}</span>
                  </p>
                )}
                <p class="text-sm text-gray-600 mb-4 line-clamp-3">{program.overview}</p>
                
                <div class="grid grid-cols-2 gap-3 mb-4">
                  <div class="text-center bg-gray-50 rounded-lg p-2">
                    <div class="text-lg font-bold text-primary">{program.intake_capacity}</div>
                    <div class="text-xs text-gray-500">Seats</div>
                  </div>
                  <div class="text-center bg-gray-50 rounded-lg p-2">
                    <div class="text-lg font-bold text-primary">{program.duration_years}</div>
                    <div class="text-xs text-gray-500">Years</div>
                  </div>
                </div>
                
                <a href={`/programs/${program.slug}`} class="block text-center bg-primary text-white font-semibold py-2.5 px-4 rounded-lg hover:bg-primary/90 transition-colors">
                  View Program Details
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why Choose Our Programs -->
  <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Why Choose Our Programs?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Quality education with industry focus and comprehensive skill development</p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-green-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">NBA Accredited</h3>
          <p class="text-sm text-gray-600">Quality assured programs recognized by National Board of Accreditation</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Modern Labs</h3>
          <p class="text-sm text-gray-600">Well-equipped laboratories for hands-on practical training</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Expert Faculty</h3>
          <p class="text-sm text-gray-600">Experienced educators with industry and academic expertise</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-orange-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Industry Ready</h3>
          <p class="text-sm text-gray-600">Curriculum designed to meet industry requirements and standards</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Ready to Start Your Engineering Journey?</h2>
      <p class="text-lg mb-8 opacity-90">Join thousands of successful graduates from GP Palanpur</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/admissions" class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold bg-white text-primary hover:bg-gray-100 rounded-lg transition-colors">
          Apply Now
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold border-2 border-white text-white hover:bg-white/10 rounded-lg transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
