---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import programs from '../../data/programs.json';
import departments from '../../data/departments.json';
import facultyData from '../../data/faculty.json';
import labGallery from '../../data/lab-gallery.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return programs.map(program => {
    // Find the department offering this program
    const dept = departments.find(d => (d.programs_offered as string[]).includes(program.id));
    const deptFacultyId = program.department_id.replace('-applied-mechanics', '').replace('instrumentation-control', 'it');
    
    return {
      params: { slug: program.slug },
      props: { 
        program,
        department: dept,
        hasFaculty: !!(facultyData as any)[deptFacultyId || program.id],
        hasLabs: !!(labGallery as any)[program.id],
        labs: (labGallery as any)[program.id] || []
      },
    };
  });
};

const { program, department, hasFaculty, hasLabs, labs } = Astro.props as any;
---

<Layout title={`${program.name} | GP Palanpur`}>
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/programs" class="hover:text-primary">Programs</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-700">{program.short_name}</span>
      </nav>

      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {program.nba_status && program.nba_status === "Accredited" && (
            <span class="text-xs font-semibold bg-green-100 text-green-800 border border-green-200 rounded-full px-3 py-1">
              ✓ NBA Accredited {program.nba_valid_until ? `(Valid till ${program.nba_valid_until})` : ''}
            </span>
          )}
          {program.nba_status && program.nba_status === "Applying" && (
            <span class="text-xs font-semibold bg-blue-100 text-blue-800 border border-blue-200 rounded-full px-3 py-1">
              ⏳ NBA Accreditation in Progress
            </span>
          )}
          <span class="text-xs font-semibold bg-purple-100 text-purple-800 rounded-full px-3 py-1">Code: {program.code}</span>
          <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Est. {program.established}</span>
          <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">{program.intake_capacity} Seats</span>
          <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">{program.duration_years} Years</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{program.name}</h1>
        {department && (
          <p class="text-sm text-gray-500 mb-4">
            Offered by <a href={`/departments/${department.slug}`} class="text-primary hover:underline font-medium">{department.name}</a>
          </p>
        )}
        <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-2xl">{program.overview}</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{program.intake_capacity}</div>
            <div class="text-xs text-gray-500 mt-1">Intake Seats</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{program.duration_years}</div>
            <div class="text-xs text-gray-500 mt-1">Years</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{program.specializations?.length || '—'}</div>
            <div class="text-xs text-gray-500 mt-1">Specializations</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{program.nba_status === "Accredited" ? '✓' : program.nba_status === "Applying" ? '⏳' : '—'}</div>
            <div class="text-xs text-gray-500 mt-1">NBA Status</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Highlights -->
  <section class="py-12 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Program Highlights</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {program.nba_status === "Accredited" && (
          <div class="bg-gradient-to-br from-green-50 to-white rounded-xl p-5 border border-green-100 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-gray-900">NBA Accredited</h3>
            </div>
            <p class="text-xs text-gray-600">Quality education recognized by national standards</p>
          </div>
        )}
        <div class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-5 border border-blue-100 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-sm font-bold text-gray-900">Industry Ready</h3>
          </div>
          <p class="text-xs text-gray-600">Curriculum aligned with industry requirements</p>
        </div>
        {hasLabs && labs.length > 0 && (
          <div class="bg-gradient-to-br from-purple-50 to-white rounded-xl p-5 border border-purple-100 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
              </div>
              <h3 class="text-sm font-bold text-gray-900">Modern Labs</h3>
            </div>
            <p class="text-xs text-gray-600">Well-equipped facilities for practical learning</p>
          </div>
        )}
        <div class="bg-gradient-to-br from-orange-50 to-white rounded-xl p-5 border border-orange-100 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <h3 class="text-sm font-bold text-gray-900">GTU Affiliated</h3>
          </div>
          <p class="text-xs text-gray-600">Recognized diploma from Gujarat Technological University</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Actions -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {department && (
          <a href={`/departments/${department.slug}`} class="group bg-white rounded-xl p-5 border border-gray-200 hover:border-primary hover:shadow-lg transition-all">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary group-hover:scale-110 transition-all">
                <svg class="w-5 h-5 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-bold text-gray-900">Department</h3>
                <p class="text-xs text-gray-500">Visit department</p>
              </div>
            </div>
            <p class="text-xs text-gray-600">Faculty & facilities</p>
          </a>
        )}
        {hasLabs && labs.length > 0 && (
          <a href={`/programs/${program.slug}/labs`} class="group bg-white rounded-xl p-5 border border-gray-200 hover:border-primary hover:shadow-lg transition-all">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary group-hover:scale-110 transition-all">
                <svg class="w-5 h-5 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
              </div>
              <div>
                <h3 class="text-sm font-bold text-gray-900">Laboratories</h3>
                <p class="text-xs text-gray-500">{labs.length} labs</p>
              </div>
            </div>
            <p class="text-xs text-gray-600">Explore facilities</p>
          </a>
        )}
        <a href="#curriculum" class="group bg-white rounded-xl p-5 border border-gray-200 hover:border-primary hover:shadow-lg transition-all">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary group-hover:scale-110 transition-all">
              <svg class="w-5 h-5 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900">Curriculum</h3>
              <p class="text-xs text-gray-500">What you'll learn</p>
            </div>
          </div>
          <p class="text-xs text-gray-600">View course details</p>
        </a>
        <a href="/admissions" class="group bg-white rounded-xl p-5 border border-gray-200 hover:border-primary hover:shadow-lg transition-all">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center group-hover:bg-primary group-hover:scale-110 transition-all">
              <svg class="w-5 h-5 text-primary group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <div>
              <h3 class="text-sm font-bold text-gray-900">Apply Now</h3>
              <p class="text-xs text-gray-500">Admissions</p>
            </div>
          </div>
          <p class="text-xs text-gray-600">Start your journey</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Vision & Mission + PEOs -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Vision & Mission Section -->
      {(program.vision || program.mission) && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Vision & Mission</h2>
          <div class="grid lg:grid-cols-2 gap-6">
            {program.vision && (
              <div class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-6 border border-blue-100 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900">Vision</h3>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed">{program.vision}</p>
              </div>
            )}
            {program.mission && (
              <div class="bg-gradient-to-br from-green-50 to-white rounded-xl p-6 border border-green-100 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 bg-green-600 rounded-lg flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900">Mission</h3>
                </div>
                {Array.isArray(program.mission) ? (
                  <ul class="space-y-2">
                    {program.mission.map((m: any) => (
                      <li class="flex items-start gap-2 text-sm text-gray-700">
                        <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        {m}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p class="text-sm text-gray-700 leading-relaxed">{program.mission}</p>
                )}
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Program Educational Objectives -->
      {program.peos && program.peos.length > 0 && (
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Program Educational Objectives (PEOs)</h2>
          <div class="bg-gradient-to-br from-purple-50 to-white rounded-xl p-6 border border-purple-100 shadow-sm">
            <p class="text-sm text-gray-600 mb-4">Graduates of this program will be able to:</p>
            <ul class="grid md:grid-cols-2 gap-4">
              {program.peos.map((peo: any, idx: any) => (
                <li class="flex items-start gap-3 text-sm text-gray-700">
                  <div class="w-6 h-6 bg-purple-600 text-white rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold">{idx + 1}</div>
                  {peo}
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}

      <div class="grid lg:grid-cols-3 gap-8" id="curriculum">
        <!-- Specializations -->
        {program.specializations && program.specializations.length > 0 && (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <h2 class="text-lg font-bold text-gray-900">Specializations</h2>
            </div>
            <ul class="space-y-2">
              {program.specializations.map((s: any) => (
                <li class="flex items-center gap-2 text-sm text-gray-700">
                  <div class="w-2 h-2 bg-primary rounded-full flex-shrink-0"></div>
                  {s}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Career Opportunities -->
        {program.career_opportunities && program.career_opportunities.length > 0 && (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <h2 class="text-lg font-bold text-gray-900">Career Opportunities</h2>
            </div>
            <ul class="space-y-2">
              {program.career_opportunities.map((c: any) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {c}
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Admission Information -->
        <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Admission Info</h2>
          </div>
          <div class="space-y-3">
            <div>
              <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Eligibility</h3>
              <p class="text-sm text-gray-700">{program.eligibility}</p>
            </div>
            <div>
              <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Intake Capacity</h3>
              <p class="text-sm text-gray-700">{program.intake_capacity} seats annually</p>
            </div>
            <div>
              <h3 class="text-xs font-semibold text-gray-500 uppercase mb-1">Duration</h3>
              <p class="text-sm text-gray-700">{program.duration_years} years</p>
            </div>
            <a href="/admissions" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline mt-2">
              Learn more about admissions
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lab Gallery -->
  {hasLabs && labs.length > 0 && (
    <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Our Laboratories</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">State-of-the-art facilities equipped with modern equipment for hands-on learning</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {labs.slice(0, 3).map((lab: any) => (
            <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow border border-gray-100">
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img 
                  src={lab.image} 
                  alt={lab.name}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-5">
                <h3 class="text-lg font-bold text-gray-900 mb-2">{lab.name}</h3>
                <p class="text-sm text-gray-600">{lab.description}</p>
              </div>
            </div>
          ))}
        </div>
        {labs.length > 3 && (
          <div class="text-center mt-8">
            <a href={`/programs/${program.slug}/labs`} class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
              View All {labs.length} Labs
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <Footer />
</Layout>
