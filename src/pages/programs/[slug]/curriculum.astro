---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import programsData from "../../../data/programs.json";
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return programsData.map((program) => ({
    params: { slug: program.slug },
    props: { program },
  }));
};

const { program } = Astro.props as any;

// Map program slugs to file prefixes
const programFileMap: Record<string, string> = {
  "electronics-communication-engineering": "ec",
  "information-communication-technology": "ict",
  "information-technology": "it",
  "civil-engineering": "ce",
  "electrical-engineering": "ee",
  "mechanical-engineering": "me",
};

const filePrefix = programFileMap[program.slug];
const semesters = [1, 2, 3, 4, 5, 6];
---

<Layout title={`${program.name} - Curriculum | GP Palanpur`}>
  <Nav />
  
  <div class="bg-gray-50">
    <!-- Header -->
    <header class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-6 shadow-lg">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between">
          <div>
            <a href={`/programs/${program.slug}`} class="text-blue-200 hover:text-white transition-colors inline-flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
              </svg>
              Back to {program.name}
            </a>
            <h1 class="text-4xl font-bold">{program.name}</h1>
            <p class="text-blue-100 mt-2 text-lg">Course Curriculum</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8 max-w-7xl">
      <!-- Info Banner -->
      <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl shadow-lg p-6 mb-8 text-white">
        <div class="flex items-start gap-4">
          <div class="bg-white/20 rounded-lg p-3 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold mb-2">Curriculum Information</h2>
            <p class="text-blue-50 leading-relaxed">
              This page displays the curriculum for regular students. We show two curriculum versions:
              <strong class="text-white">GTU Diploma (Latest)</strong> starting with code DI and
              <strong class="text-white">COGC Curriculum</strong> with codes starting with 43.
            </p>
            <div class="mt-4 flex items-center gap-3">
              <a 
                href="https://gtu.ac.in/syllabus/Syllabus.aspx" 
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-white text-blue-600 px-5 py-2.5 rounded-lg font-semibold hover:bg-blue-50 transition-all shadow-md hover:shadow-lg"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Official GTU Syllabus
              </a>
              <span class="text-blue-100">For detailed information and updates</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Curriculum Tabs -->
      <div class="mb-6">
        <div class="border-b border-gray-200">
          <nav class="-mb-px flex space-x-4" role="tablist">
            <button
              class="curriculum-tab active border-b-2 border-blue-600 py-3 px-6 text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors"
              data-tab="gtu"
            >
              GTU Diploma (Latest - DI)
            </button>
            <button
              class="curriculum-tab border-b-2 border-transparent py-3 px-6 text-sm font-semibold text-gray-500 hover:text-gray-700 transition-colors"
              data-tab="cogc"
            >
              COGC Curriculum (43xxx)
            </button>
          </nav>
        </div>
      </div>

      <!-- GTU Curriculum Content -->
      <div id="gtu-content" class="curriculum-content">
        <div class="bg-white rounded-xl shadow-lg p-6 mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-blue-100 rounded-lg p-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">GTU Diploma Curriculum</h3>
              <p class="text-gray-600 text-sm">Latest curriculum effective from 2024-25</p>
            </div>
          </div>

          <div class="space-y-4">
            {semesters.map((sem) => (
              <div class="border border-gray-200 rounded-lg overflow-hidden">
                <button
                  class="semester-toggle w-full bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 flex items-center justify-between hover:from-blue-50 hover:to-blue-100 transition-all"
                  data-semester={sem}
                  data-type="gtu"
                >
                  <div class="flex items-center gap-3">
                    <span class="bg-blue-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold">
                      {sem}
                    </span>
                    <span class="font-semibold text-gray-900">Semester {sem}</span>
                  </div>
                  <svg class="toggle-icon h-5 w-5 text-gray-500 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="semester-content hidden overflow-x-auto" data-semester={sem} data-type="gtu">
                  <div class="p-6">
                    <div class="flex items-center justify-center py-8">
                      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                      <span class="ml-3 text-gray-600">Loading subjects...</span>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- COGC Curriculum Content -->
      <div id="cogc-content" class="curriculum-content hidden">
        <div class="bg-white rounded-xl shadow-lg p-6 mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-purple-100 rounded-lg p-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900">COGC Curriculum</h3>
              <p class="text-gray-600 text-sm">For students admitted before 2024-25</p>
            </div>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
            <p class="text-amber-800 text-sm">
              <strong>Note:</strong> COGC curriculum data is being updated. Please refer to the official GTU syllabus for detailed information.
            </p>
          </div>

          <div class="space-y-4">
            {semesters.map((sem) => (
              <div class="border border-gray-200 rounded-lg overflow-hidden opacity-50">
                <div class="w-full bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <span class="bg-purple-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold">
                      {sem}
                    </span>
                    <span class="font-semibold text-gray-900">Semester {sem}</span>
                  </div>
                  <span class="text-sm text-gray-500">Coming Soon</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>

    <!-- Scripts -->
    <script define:vars={{ filePrefix }}>
      // Tab switching
      const tabs = document.querySelectorAll('.curriculum-tab');
      const contents = document.querySelectorAll('.curriculum-content');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const tabType = tab.dataset.tab;
          
          // Update tab styles
          tabs.forEach(t => {
            if (t.dataset.tab === tabType) {
              t.classList.add('active', 'border-blue-600', 'text-blue-600');
              t.classList.remove('border-transparent', 'text-gray-500');
            } else {
              t.classList.remove('active', 'border-blue-600', 'text-blue-600');
              t.classList.add('border-transparent', 'text-gray-500');
            }
          });

          // Update content visibility
          contents.forEach(content => {
            if (content.id === `${tabType}-content`) {
              content.classList.remove('hidden');
            } else {
              content.classList.add('hidden');
            }
          });
        });
      });

      // Semester toggle
      const toggles = document.querySelectorAll('.semester-toggle');
      
      toggles.forEach(toggle => {
        toggle.addEventListener('click', async () => {
          const semester = toggle.dataset.semester;
          const type = toggle.dataset.type;
          const content = document.querySelector(`.semester-content[data-semester="${semester}"][data-type="${type}"]`);
          const icon = toggle.querySelector('.toggle-icon');
          
          if (content.classList.contains('hidden')) {
            // Load content if not already loaded
            if (!content.dataset.loaded) {
              await loadSemesterData(semester, type, content);
              content.dataset.loaded = 'true';
            }
            content.classList.remove('hidden');
            icon.style.transform = 'rotate(180deg)';
          } else {
            content.classList.add('hidden');
            icon.style.transform = 'rotate(0deg)';
          }
        });
      });

      // Load and parse semester data
      async function loadSemesterData(semester, type, container) {
        try {
          const filename = `${filePrefix}-${semester}.html`;
          const response = await fetch(`/docs/syllabus/${filename}`);
          
          if (!response.ok) {
            throw new Error('Syllabus file not found');
          }
          
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          
          // Find the subjects table
          const table = doc.querySelector('table.myGrid');
          if (!table) {
            throw new Error('No subjects table found');
          }
          
          const rows = Array.from(table.querySelectorAll('tr')).slice(1); // Skip header
          const subjects = [];
          
          for (const row of rows) {
            const cells = row.querySelectorAll('td');
            if (cells.length < 16) continue;
            
            const subjectCode = cells[1].textContent.trim();
            
            // Filter based on type
            if (type === 'gtu') {
              // Show only DI codes, exclude C2D students (DI01C pattern)
              if (!subjectCode.startsWith('DI') || subjectCode.match(/DI01C\d+/)) {
                continue;
              }
            } else if (type === 'cogc') {
              // Show only 43xxx codes
              if (!subjectCode.startsWith('43')) {
                continue;
              }
            }
            
            subjects.push({
              code: subjectCode,
              name: cells[4].textContent.trim(),
              category: cells[5].textContent.trim(),
              hours: {
                L: cells[7].textContent.trim(),
                T: cells[8].textContent.trim(),
                P: cells[9].textContent.trim(),
                PBL: cells[10].textContent.trim()
              },
              credits: cells[11].textContent.trim(),
              marks: {
                E: cells[12].textContent.trim(),
                M: cells[13].textContent.trim(),
                I: cells[14].textContent.trim(),
                V: cells[15].textContent.trim(),
                Total: cells[16].textContent.trim()
              }
            });
          }
          
          // Render subjects table
          if (subjects.length === 0) {
            container.innerHTML = `
              <div class="p-6 text-center text-gray-500">
                <p>No subjects found for this semester in the ${type === 'gtu' ? 'GTU Diploma' : 'COGC'} curriculum.</p>
              </div>
            `;
          } else {
            container.innerHTML = `
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Code</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Subject Name</th>
                      <th class="px-4 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Category</th>
                      <th class="px-4 py-3 text-center text-xs font-medium text-gray-700 uppercase tracking-wider">L-T-P</th>
                      <th class="px-4 py-3 text-center text-xs font-medium text-gray-700 uppercase tracking-wider">Credits</th>
                      <th class="px-4 py-3 text-center text-xs font-medium text-gray-700 uppercase tracking-wider">Total Marks</th>
                      <th class="px-4 py-3 text-center text-xs font-medium text-gray-700 uppercase tracking-wider">Syllabus</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    ${subjects.map((subject, index) => `
                      <tr class="${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'} hover:bg-blue-50 transition-colors">
                        <td class="px-4 py-4 whitespace-nowrap">
                          <span class="text-sm font-mono font-semibold text-blue-600">${subject.code}</span>
                        </td>
                        <td class="px-4 py-4">
                          <div class="text-sm font-medium text-gray-900">${subject.name}</div>
                        </td>
                        <td class="px-4 py-4">
                          <span class="text-xs px-2 py-1 rounded-full bg-blue-100 text-blue-800">${subject.category}</span>
                        </td>
                        <td class="px-4 py-4 text-center">
                          <span class="text-sm text-gray-700">${subject.hours.L}-${subject.hours.T}-${subject.hours.P}</span>
                        </td>
                        <td class="px-4 py-4 text-center">
                          <span class="inline-flex items-center justify-center px-2 py-1 text-sm font-semibold text-green-800 bg-green-100 rounded-full">
                            ${subject.credits}
                          </span>
                        </td>
                        <td class="px-4 py-4 text-center">
                          <span class="text-sm font-semibold text-gray-900">${subject.marks.Total}</span>
                        </td>
                        <td class="px-4 py-4 text-center">
                          <a 
                            href="https://s3-ap-southeast-1.amazonaws.com/gtusitecirculars/Syallbus/${subject.code}.pdf" 
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-1 text-xs font-medium text-red-600 hover:text-red-700 hover:underline"
                            title="Download ${subject.code} Syllabus PDF"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                            PDF
                          </a>
                        </td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
                <div class="mt-4 p-4 bg-gray-50 rounded-lg">
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-700">Total Subjects: <strong>${subjects.length}</strong></span>
                    <span class="text-gray-700">Total Credits: <strong>${subjects.reduce((sum, s) => sum + parseInt(s.credits || 0), 0)}</strong></span>
                  </div>
                </div>
              </div>
            `;
          }
        } catch (error) {
          console.error('Error loading syllabus:', error);
          container.innerHTML = `
            <div class="p-6 text-center">
              <div class="text-red-600 mb-2">
                <svg class="h-12 w-12 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class="text-gray-700 font-medium">Unable to load syllabus for Semester ${semester}</p>
              <p class="text-gray-500 text-sm mt-1">${error.message}</p>
            </div>
          `;
        }
      }
    </script>
  </div>
  
  <Footer />
</Layout>
