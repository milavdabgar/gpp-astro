---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import AnnouncementTicker from '../../../components/AnnouncementTicker.astro';
import programs from '../../../data/programs.json';
import labGallery from '../../../data/lab-gallery.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  const paths = [];
  for (const program of programs) {
    if ((labGallery as any)[program.id]) {
      paths.push({
        params: { slug: program.slug },
        props: { program, labs: (labGallery as any)[program.id] },
      });
    }
  }
  return paths;
};

const { program, labs } = Astro.props as any;
---

<Layout title={`Laboratories - ${program.name} | GP Palanpur`}>
  <Nav />
  <AnnouncementTicker />

  <!-- Header -->
  <section class="bg-gradient-to-br from-primary/10 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/programs" class="hover:text-primary">Programs</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={`/programs/${program.slug}`} class="hover:text-primary">{program.short_name}</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-700">Laboratories</span>
      </nav>

      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <div>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900">Laboratories</h1>
            <p class="text-lg text-gray-600">{program.short_name}</p>
          </div>
        </div>
        
        <p class="text-gray-600 mb-6">
          Our program is equipped with modern laboratories providing hands-on experience and practical knowledge to complement theoretical learning.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center bg-white/80 rounded-lg p-3 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{labs.length}</div>
            <div class="text-xs text-gray-500 mt-1">Total Labs</div>
          </div>
          <div class="text-center bg-white/80 rounded-lg p-3 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{program.intake_capacity}</div>
            <div class="text-xs text-gray-500 mt-1">Students</div>
          </div>
          <div class="text-center bg-white/80 rounded-lg p-3 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">100+</div>
            <div class="text-xs text-gray-500 mt-1">Equipment</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Laboratories List -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        {labs.map((lab: any, index: number) => (
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg transition-all overflow-hidden">
            <!-- Lab Image -->
            <div class="aspect-video bg-gray-100 overflow-hidden relative group">
              <img 
                src={lab.image} 
                alt={lab.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
              <div class="absolute top-3 right-3 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">
                Lab {index + 1}
              </div>
            </div>
            
            <!-- Lab Info -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-3">{lab.name}</h3>
              <p class="text-sm text-gray-600 leading-relaxed mb-4">{lab.description}</p>
              
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <svg class="w-4  h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                Modern equipment and facilities available
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Additional Info -->
      <div class="mt-12 bg-gradient-to-br from-blue-50 to-purple-50 rounded-2xl p-8 border border-blue-100">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Lab Facilities</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Modern equipment and instruments</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Regular maintenance and calibration</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Adequate space for student batches</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Safety equipment and protocols</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Student Benefits</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Hands-on practical experience</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Industry-standard skills development</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Project and research opportunities</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-sm text-gray-700">Faculty guidance and support</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Back Link -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
      <a href={`/programs/${program.slug}`} class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to {program.short_name}
      </a>
      <a href="/contact" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
        Visit Campus
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
