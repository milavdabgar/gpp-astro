---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const nirfData = {
  instituteName: "Government Polytechnic Palanpur",
  nirfId: "IR-P-P-XXX",
  category: "Polytechnic",
  submittingEntity: "Institute",
  state: "Gujarat",
  city: "Palanpur",
  district: "Banaskantha",
  pinCode: "385001",
  address: "Outside Malan Gate, Ambaji Road, Palanpur-385001, Banaskantha, Gujarat",
  phone: "02742-262115",
  email: "gp-palanpur-dte@gujarat.gov.in",
};

const nirfParameters = [
  {
    name: "Teaching, Learning & Resources (TLR)",
