const nirfReportYears = [
  { year: "2024", status: "submitted", doc: null },
  { year: "2023", status: "submitted", doc: null },
  { year: "2022", status: "submitted", doc: null },
];
---

<Layout title="NIRF Ranking | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">
        National Institutional Ranking Framework
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">NIRF Ranking</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Government Polytechnic Palanpur participates in the National Institutional Ranking Framework (NIRF),
        a methodology adopted by the Ministry of Education, Government of India to rank engineering and polytechnic institutions.
      </p>
    </div>
  </section>

  <!-- About NIRF -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">About NIRF</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            The National Institutional Ranking Framework (NIRF) was approved by the Ministry of Education (MoE)
            in September 2015 and was implemented from 2016. The framework outlines a methodology to rank
            institutions across India.
          </p>
          <p class="text-gray-600 leading-relaxed mb-4">
            Rankings are based on five broad parameters encompassing various key performance areas that cover
            teaching, research, diversity, and outcomes.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Participation in NIRF promotes institutional transparency, accountability, and comparative improvement.
          </p>
          <a
            href="https://www.nirfindia.org/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors text-sm"
          >
            Visit NIRF India Portal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
        <div class="bg-blue-50 rounded-2xl border border-blue-100 p-6">
          <h3 class="font-bold text-gray-900 mb-4">Institution Information</h3>
          <dl class="space-y-3">
            {[
              ["Institution", nirfData.instituteName],
              ["Category", nirfData.category],
              ["State", nirfData.state],
              ["City", nirfData.city],
              ["Contact", nirfData.phone],
              ["Email", nirfData.email],
            ].map(([k, v]) => (
              <div class="flex justify-between items-start gap-4 text-sm pb-2 border-b border-blue-100 last:border-0">
                <span class="text-gray-500 font-medium">{k}</span>
                <span class="text-gray-800 font-semibold text-right">{v}</span>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- NIRF Parameters -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">NIRF Evaluation Parameters</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {nirfParameters.map((param) => (
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <div class="flex items-start gap-3 mb-3">
              <div class="p-2 rounded-lg bg-primary/10 flex-shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={param.icon}/>
                </svg>
              </div>
              <span class="text-lg font-bold text-primary">{param.weight}</span>
            </div>
            <h3 class="font-bold text-gray-900 mb-2 text-sm leading-snug">{param.name}</h3>
            <p class="text-xs text-gray-500 leading-relaxed">{param.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NIRF Submission History -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">NIRF Submission History</h2>
      <div class="space-y-3">
        {nirfReportYears.map((r) => (
          <div class="flex items-center justify-between p-4 rounded-xl border border-gray-200 bg-gray-50 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-green-500"></span>
              <span class="font-semibold text-gray-800">NIRF {r.year}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Submitted</span>
              <span class="text-xs text-gray-400 italic">Available on NIRF portal</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 text-center text-sm text-gray-500">
        For the latest NIRF data and rankings, visit the official
        <a href="https://www.nirfindia.org/" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:text-primary/80">NIRF India portal</a>.
      </div>
    </div>
  </section>

  <Footer />
</Layout>
