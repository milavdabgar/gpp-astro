---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const objectives = [
  "Strengthening institutions to improve learning outcomes and employability of graduates",
  "Scaling up postgraduate education and demand-driven research, development, and innovation",
  "Establishing centres of excellence for focused applicable research",
  "Training of faculty for effective teaching through FDPs and workshops",
  "Enhancing institutional and system management effectiveness",
];

const implementations = [
  {
    title: "Infrastructure Development",
    description: "Upgrading laboratories, workshops, IT infrastructure, and campus facilities to meet modern industry standards.",
    icon: "M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z",
    color: "blue",
  },
  {
    title: "Faculty Development Programs",
    description: "Conducting regular Faculty Development Programs (FDPs), workshops, and technical training sessions to enhance teaching quality.",
    icon: "M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z",
    color: "green",
  },
  {
    title: "Research & Development",
    description: "Supporting faculty-led research projects and publication of research papers in journals and conferences.",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
    color: "purple",
  },
  {
    title: "Industry–Institute Interaction",
    description: "Facilitating MoUs with industries, campus recruitment drives, industrial visits, and guest lectures by industry professionals.",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01",
    color: "orange",
  },
];

const colorMap: Record<string, string> = {
  blue:   "text-blue-600 bg-blue-50",
  green:  "text-green-600 bg-green-50",
  purple: "text-purple-600 bg-purple-50",
  orange: "text-orange-600 bg-orange-50",
};
---

<Layout title="TEQIP | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">TEQIP</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">TEQIP</h1>
      <p class="text-xl text-primary font-semibold mb-3">Technical Education Quality Improvement Programme</p>
      <p class="text-lg text-gray-600">A Government of India initiative to improve the quality of technical education through systemic reforms, infrastructure enhancement, and capacity building.</p>
    </div>
  </section>

  <!-- About TEQIP -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">About TEQIP</h2>
      <div class="prose prose-lg max-w-none text-gray-700 space-y-4">
        <p>
          The Technical Education Quality Improvement Programme (TEQIP) is a centrally sponsored scheme of the Government of India, implemented by the Ministry of Education (erstwhile Ministry of Human Resource Development) in collaboration with the World Bank. The program aims to improve the quality of engineering education in India through institutional strengthening, curriculum reform, and enhanced industry linkages.
        </p>
        <p>
          TEQIP has been implemented in three phases (TEQIP-I, TEQIP-II, and TEQIP-III) across select government engineering institutions in India, focusing on upliftment of weaker institutions through financial support, faculty development, and infrastructure improvement.
        </p>
        <p>
          Government Polytechnic Palanpur has actively participated in quality improvement measures aligned with TEQIP objectives — implementing faculty development programs, improving laboratory infrastructure, strengthening industry–institute interactions, and participating in outcome-based education reforms as prescribed for technical institutions under the Gujarat DTE.
        </p>
      </div>
    </div>
  </section>

  <!-- Key Objectives -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Key Objectives of TEQIP</h2>
      <div class="space-y-4">
        {objectives.map((obj, i) => (
          <div class="flex items-start gap-4 bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <span class="w-8 h-8 rounded-full bg-primary/10 text-primary text-sm font-bold flex items-center justify-center flex-shrink-0">{i + 1}</span>
            <p class="text-gray-700">{obj}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Implementation at GPP -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Implementation at GPP</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {implementations.map((impl) => {
          const c = colorMap[impl.color] || colorMap.blue;
          return (
            <div class="flex gap-4 bg-gray-50 rounded-xl p-6 border border-gray-100">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 ${c}`}>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={impl.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">{impl.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{impl.description}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Annual Reports Placeholder -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">TEQIP Reports & Documents</h2>
      <div class="space-y-4">
        {[
          { title: "TEQIP Annual Report 2023–24", year: "2023-24" },
          { title: "TEQIP Annual Report 2022–23", year: "2022-23" },
          { title: "TEQIP Annual Report 2021–22", year: "2021-22" },
        ].map((doc) => (
          <div class="flex items-center justify-between bg-white rounded-xl px-5 py-4 border border-gray-100 shadow-sm">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="font-medium text-gray-900">{doc.title}</p>
                <p class="text-xs text-gray-500">Government Polytechnic Palanpur · {doc.year}</p>
              </div>
            </div>
            <span class="text-xs text-amber-600 bg-amber-50 border border-amber-200 rounded px-2 py-1">Uploading soon</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-lg font-bold text-gray-900 mb-3">For More Information</h2>
      <p class="text-gray-600 text-sm mb-4">Contact the Principal's office or the Academic Section for TEQIP-related queries.</p>
      <a href="/contact" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Contact Us</a>
    </div>
  </section>

  <Footer />
</Layout>
