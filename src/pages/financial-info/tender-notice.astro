---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

interface Tender {
  id: string;
  title: string;
  ref: string;
  publishDate: string;
  deadline: string;
  category: string;
  status: "active" | "closed";
  estimatedValue?: string;
  doc?: string | null;
}

const tenders: Tender[] = [
  {
    id: "GEN-2025-01",
    title: "Supply of Laboratory Furniture and Equipment",
    ref: "GPP/PURCHASE/2025/01",
    publishDate: "01 Jan 2025",
    deadline: "31 Jan 2025",
    category: "Equipment",
    status: "closed",
    estimatedValue: "—",
    doc: null,
  },
  {
    id: "GEN-2024-05",
    title: "Annual Maintenance Contract for Computers and Peripherals",
    ref: "GPP/AMC/2024/05",
    publishDate: "15 Oct 2024",
    deadline: "05 Nov 2024",
    category: "Services",
    status: "closed",
    estimatedValue: "—",
    doc: null,
  },
  {
    id: "GEN-2024-04",
    title: "Supply of Stationery Items for Academic Year 2024-25",
    ref: "GPP/PURCHASE/2024/04",
    publishDate: "01 Aug 2024",
    deadline: "25 Aug 2024",
    category: "Stationery",
    status: "closed",
    estimatedValue: "—",
    doc: null,
  },
  {
    id: "GEN-2024-03",
    title: "Civil Maintenance Works — Academic Block 2",
    ref: "GPP/CIVIL/2024/03",
    publishDate: "01 Jun 2024",
    deadline: "20 Jun 2024",
    category: "Civil Work",
    status: "closed",
    estimatedValue: "—",
    doc: null,
  },
  {
    id: "GEN-2024-02",
    title: "Supply and Installation of CCTV Surveillance System",
    ref: "GPP/SECURITY/2024/02",
    publishDate: "15 Feb 2024",
    deadline: "05 Mar 2024",
    category: "Security",
    status: "closed",
    estimatedValue: "—",
    doc: null,
  },
];

const categoryColors: Record<string, string> = {
  Equipment: "bg-blue-100 text-blue-700",
  Services: "bg-purple-100 text-purple-700",
  Stationery: "bg-green-100 text-green-700",
  "Civil Work": "bg-orange-100 text-orange-700",
  Security: "bg-red-100 text-red-700",
};

const activeTenders = tenders.filter((t) => t.status === "active");
const closedTenders = tenders.filter((t) => t.status === "closed");

const procurement = [
  { name: "GeM Portal Procurement", desc: "Government e-Marketplace (GeM) is used for direct procurement of goods and services by Government Polytechnic Palanpur.", link: "https://gem.gov.in/" },
  { name: "CPWD Standards", desc: "Civil works and construction are carried out in accordance with CPWD norms and state government guidelines." },
  { name: "DGS&D Rate Contract", desc: "Purchases are made through DGS&D rate contracts for approved categories of goods." },
];
---

<Layout title="Tender Notices | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">
        Procurement & Tenders
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Tender Notices</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Government Polytechnic Palanpur follows transparent procurement procedures in accordance with
        Government of Gujarat guidelines, GFR rules, and GeM portal requirements.
      </p>
    </div>
  </section>

  <!-- Active Tenders -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-bold text-gray-900">Active Tenders</h2>
        <span class="px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700 border border-green-200">{activeTenders.length} Active</span>
      </div>
      {activeTenders.length === 0 ? (
        <div class="text-center py-16 bg-gray-50 rounded-2xl border border-gray-200">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <p class="text-gray-500 font-medium">No active tenders at this time.</p>
          <p class="text-gray-400 text-sm mt-1">Please check back later for new procurement notices.</p>
        </div>
      ) : (
        <div class="space-y-4">
          {activeTenders.map((t) => (
            <div class="bg-green-50 rounded-xl border border-green-200 p-5 shadow-sm">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-grow">
                  <div class="flex items-center gap-2 mb-2 flex-wrap">
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    <span class="text-xs font-semibold text-gray-500">{t.ref}</span>
                    <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${categoryColors[t.category] ?? 'bg-gray-100 text-gray-600'}`}>{t.category}</span>
                  </div>
                  <h3 class="font-bold text-gray-900 mb-2">{t.title}</h3>
                  <div class="flex gap-4 text-xs text-gray-500 flex-wrap">
                    <span>Published: {t.publishDate}</span>
                    <span class="font-medium text-red-600">Deadline: {t.deadline}</span>
                  </div>
                </div>
                {t.doc && (
                  <a href={t.doc} class="flex-shrink-0 inline-flex items-center gap-1.5 text-sm text-primary font-medium hover:underline">
                    Download
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Closed Tenders -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Past Tenders</h2>
      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Reference No.</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Title</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Category</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Published</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Deadline</th>
              <th class="px-5 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {closedTenders.map((t) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-5 py-4 text-xs font-mono text-gray-600">{t.ref}</td>
                <td class="px-5 py-4 text-sm text-gray-900 max-w-xs">{t.title}</td>
                <td class="px-5 py-4"><span class={`px-2 py-0.5 rounded-full text-xs font-medium ${categoryColors[t.category] ?? 'bg-gray-100 text-gray-600'}`}>{t.category}</span></td>
                <td class="px-5 py-4 text-sm text-gray-600">{t.publishDate}</td>
                <td class="px-5 py-4 text-sm text-gray-600">{t.deadline}</td>
                <td class="px-5 py-4"><span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Closed</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Procurement Info -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Procurement Methods</h2>
      <div class="grid md:grid-cols-3 gap-5">
        {procurement.map((p) => (
          <div class="bg-gray-50 rounded-xl border border-gray-200 p-5">
            <h3 class="font-bold text-gray-900 mb-2">{p.name}</h3>
            <p class="text-sm text-gray-600 mb-3 leading-relaxed">{p.desc}</p>
            {p.link && (
              <a href={p.link} target="_blank" rel="noopener noreferrer" class="text-sm text-primary font-medium hover:underline">
                Visit Portal →
              </a>
            )}
          </div>
        ))}
      </div>
      <div class="mt-8 p-5 bg-blue-50 rounded-xl border border-blue-200">
        <p class="text-sm text-blue-800">
          <strong>Note:</strong> For queries related to procurement or tender documents, please contact the administrative office at
          <a href="mailto:gp-palanpur-dte@gujarat.gov.in" class="text-primary underline">gp-palanpur-dte@gujarat.gov.in</a> or call{" "}
          <a href="tel:02742262115" class="text-primary underline">02742-262115</a>.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
