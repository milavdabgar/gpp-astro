---

<Layout title="TPO Cell | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1 mb-4 inline-block">Training & Placement Cell</span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">TPO Cell</h1>
      <p class="text-xl text-gray-600 mb-8">
        Building bridges between academic excellence and industry opportunities. Our dedicated Training & Placement Cell focuses on comprehensive career development and successful industry integration.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">35%</div><div class="text-sm text-gray-600">Placement Rate</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">₹4.5L</div><div class="text-sm text-gray-600">Max Package</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">5+</div><div class="text-sm text-gray-600">Companies/Year</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">100+</div><div class="text-sm text-gray-600">Alumni Network</div></div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Mission</h2>
          <p class="text-lg text-gray-600 mb-6 leading-relaxed">To bridge the gap between academic learning and industry requirements by providing comprehensive training, career guidance, and placement opportunities that enable our students to excel in their professional careers.</p>
          <ul class="space-y-4">
            {[["Industry Connections", "Establishing strong partnerships with leading companies"], ["Skill Development", "Comprehensive training programs and workshops"], ["Career Guidance", "Professional counseling and mentorship programs"]].map(([title, desc]) => (
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <div>
                  <div class="font-semibold text-gray-900">{title}</div>
                  <div class="text-gray-600 text-sm">{desc}</div>
                </div>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-gradient-to-br from-primary/5 to-blue-50 rounded-2xl p-8 text-center">
          <span class="text-sm font-semibold text-primary border border-primary/30 rounded-full px-4 py-2 bg-white">"Bridging Academia & Industry"</span>
          <div class="mt-8 grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-4 shadow-sm text-center"><div class="text-2xl font-bold text-primary">171</div><div class="text-xs text-gray-500 mt-1">Placements 2024</div></div>
            <div class="bg-white rounded-xl p-4 shadow-sm text-center"><div class="text-2xl font-bold text-primary">14</div><div class="text-xs text-gray-500 mt-1">Partner Companies</div></div>
            <div class="bg-white rounded-xl p-4 shadow-sm text-center"><div class="text-2xl font-bold text-primary">₹1.8L</div><div class="text-xs text-gray-500 mt-1">Median Package</div></div>
            <div class="bg-white rounded-xl p-4 shadow-sm text-center"><div class="text-2xl font-bold text-primary">35%</div><div class="text-xs text-gray-500 mt-1">Placement Rate</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TPO Team -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">TPO Cell Team</h2>
        <p class="text-gray-600">Dedicated faculty members working to connect students with industry</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-xl shadow-sm border border-gray-200 text-sm">
          <thead class="bg-primary text-white">
            <tr>
              <th class="px-4 py-3 text-left font-semibold">Sr.</th>
              <th class="px-4 py-3 text-left font-semibold">Name</th>
              <th class="px-4 py-3 text-left font-semibold">Designation</th>
              <th class="px-4 py-3 text-left font-semibold">Department</th>
              <th class="px-4 py-3 text-left font-semibold">Email</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {tpoTeam.map((m, i) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 text-gray-500">{i + 1}</td>
                <td class="px-4 py-3 font-medium text-gray-900">{m.name}</td>
                <td class="px-4 py-3">
                  <span class={`text-xs font-semibold rounded-full px-2 py-1 ${m.role === 'Convener' ? 'bg-primary/10 text-primary' : m.role === 'Co-Convener' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'}`}>{m.role}</span>
                </td>
                <td class="px-4 py-3 text-gray-600">{m.dept}</td>
                <td class="px-4 py-3 text-gray-500">{m.email ? <a href={`mailto:${m.email}`} class="text-primary hover:underline">{m.email}</a> : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Placement Statistics -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Placement Statistics</h2>
        <p class="text-gray-600">Department-wise placement data (jobs + higher studies) — Academic Years 2020–25</p>
      </div>
      <div class="space-y-8">
        {deptData.map(dept => (
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-primary/5 px-6 py-3 border-b border-gray-200">
              <h3 class="font-bold text-gray-900">{dept.name}</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-500 text-xs uppercase">
                  <tr>
                    <th class="px-4 py-2 text-left">Year</th>
                    <th class="px-4 py-2 text-center">Pass-out</th>
                    <th class="px-4 py-2 text-center">Placed (Job)</th>
                    <th class="px-4 py-2 text-center">Higher Studies</th>
                    <th class="px-4 py-2 text-center">% Placement</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {dept.rows.map(r => (
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-2 font-medium text-gray-900">{r.year}</td>
                      <td class="px-4 py-2 text-center text-gray-700">{r.passout}</td>
                      <td class="px-4 py-2 text-center text-gray-700">{r.placed}</td>
                      <td class="px-4 py-2 text-center text-gray-700">{r.higher}</td>
                      <td class="px-4 py-2 text-center">
                        <span class="text-xs font-semibold bg-green-100 text-green-800 rounded-full px-2 py-0.5">{r.rate}</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Services Offered</h2>
        <p class="text-gray-600">Comprehensive support for career development</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-5 border border-gray-100 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">{s.title}</h3>
              <p class="text-gray-600 text-sm">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recruiters -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Major Recruiters</h2>
        <p class="text-gray-600">Companies that have recruited students from GP Palanpur</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recruiters.map((c, i) => (
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 flex items-center gap-3">
            <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0 text-primary font-bold text-sm">{i + 1}</div>
            <span class="text-gray-800 font-medium text-sm">{c}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Connect with TPO Cell</h2>
      <p class="text-gray-600 mb-6">For placement inquiries, campus recruitment, or career guidance</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
        Contact Us
      </a>
    </div>
  </section>

  <Footer />
</Layout>
