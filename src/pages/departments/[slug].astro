---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import departments from '../../data/departments.json';
import programs from '../../data/programs.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  // Newsletters data mapped by department slug
  const newslettersData: Record<string, { name: string; pdfs: { label: string; file: string }[]; siteUrl?: string }> = {
    'electronics-communication': {
      name: 'Spectrum',
      pdfs: [
        { label: "Band IV — 2024–25", file: "/docs/newsletters/ec/Spectrum-Interactive-Newsletter-2024-25.pdf" },
        { label: "Band II — 2022–23", file: "/docs/newsletters/ec/Spectrum-Interactive-Newsletter-2022-23.pdf" },
        { label: "Band I — 2021–22", file: "/docs/newsletters/ec/Spectrum-Band-I.pdf" },
      ],
      siteUrl: "https://ec.gppalanpur.ac.in/newsletter",
    },
    'civil-applied-mechanics': {
      name: 'InfraCreator',
      pdfs: [
        { label: "June 2025", file: "/docs/newsletters/civil/june-2025.pdf" },
        { label: "Dec 2024", file: "/docs/newsletters/civil/dec-2024.pdf" },
        { label: "June 2024", file: "/docs/newsletters/civil/june-2024.pdf" },
        { label: "Dec 2023", file: "/docs/newsletters/civil/dec-2023.pdf" },
        { label: "June 2023", file: "/docs/newsletters/civil/june-2023.pdf" },
        { label: "Dec 2022", file: "/docs/newsletters/civil/dec-2022.pdf" },
      ],
      siteUrl: "https://gppcivil06.wixsite.com/civil",
    },
    'electrical': {
      name: 'Spark',
      pdfs: [
        { label: "July 2025", file: "/docs/newsletters/electrical/july-2025.pdf" },
        { label: "July 2024", file: "/docs/newsletters/electrical/july-2024.pdf" },
        { label: "July 2023", file: "/docs/newsletters/electrical/july-2023.pdf" },
        { label: "July 2022", file: "/docs/newsletters/electrical/july-2022.pdf" },
        { label: "July 2021", file: "/docs/newsletters/electrical/july-2021.pdf" },
        { label: "July 2020", file: "/docs/newsletters/electrical/july-2020.pdf" },
      ],
    },
  };

  return departments.map(dept => {
    // Find programs offered by this department
    const deptPrograms = programs.filter(p => p.department_id === dept.id);
    
    // Get newsletters for this department
    const newsletters = newslettersData[dept.slug] || null;
    
    return {
      params: { slug: dept.slug },
      props: { 
        dept,
        programs: deptPrograms,
        newsletters,
      },
    };
  });
};

const { dept, programs: deptPrograms, newsletters } = Astro.props as any;
---

<Layout title={`${dept.name} | GP Palanpur`}>
  <Nav />
  <AnnouncementTicker />

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary to-blue-900 text-white py-20 overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full translate-x-1/2 translate-y-1/2"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-white/80 mb-8">
        <a href="/" class="hover:text-white">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/departments" class="hover:text-white">Departments</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-white">{dept.short_name}</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Department Info -->
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="text-xs font-semibold bg-white/20 backdrop-blur-sm text-white rounded-full px-3 py-1">Est. {dept.established}</span>
            <span class="text-xs font-semibold bg-white/20 backdrop-blur-sm text-white rounded-full px-3 py-1">{dept.faculty_count} Faculty</span>
            <span class="text-xs font-semibold bg-white/20 backdrop-blur-sm text-white rounded-full px-3 py-1">{dept.laboratories?.length ?? 0} Labs</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">{dept.name}</h1>
          <p class="text-lg text-white/90 mb-8 leading-relaxed">{dept.overview}</p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4">
            {dept.website && (
              <a href={dept.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-white text-primary font-bold px-8 py-4 rounded-xl hover:bg-white/90 transition-all shadow-xl hover:shadow-2xl transform hover:-translate-y-0.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                Visit Department Website
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            )}
            <a href={`/departments/${dept.slug}/faculty`} class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white border-2 border-white/30 font-semibold px-8 py-4 rounded-xl hover:bg-white/20 transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              View Faculty
            </a>
          </div>
        </div>

        <!-- Right: Quick Stats -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-all">
            <div class="text-5xl font-bold mb-2">{dept.faculty_count ?? '—'}</div>
            <div class="text-sm text-white/80 uppercase tracking-wide">Expert Faculty</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-all">
            <div class="text-5xl font-bold mb-2">{dept.laboratories?.length ?? 0}</div>
            <div class="text-sm text-white/80 uppercase tracking-wide">Modern Labs</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-all">
            <div class="text-5xl font-bold mb-2">{deptPrograms.length}</div>
            <div class="text-sm text-white/80 uppercase tracking-wide">{deptPrograms.length === 1 ? 'Program' : 'Programs'}</div>
          </div>
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/20 hover:bg-white/15 transition-all">
            <div class="text-5xl font-bold mb-2">{dept.established ? new Date().getFullYear() - dept.established : '—'}</div>
            <div class="text-sm text-white/80 uppercase tracking-wide">Years Legacy</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Head of Department Message -->
  {dept.head_of_department && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Message from the Head</h2>
            <p class="text-gray-600">Leadership and vision guiding our department's excellence</p>
          </div>
          
          <div class="grid lg:grid-cols-3 gap-8 items-start">
            <!-- HOD Profile Card -->
            <div class="lg:col-span-1">
              <div class="bg-gradient-to-br from-primary/5 to-blue-50 rounded-2xl p-8 border border-primary/10 sticky top-8">
                <div class="w-24 h-24 bg-primary rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
                  <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div class="text-center">
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Head of Department</p>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">{dept.head_of_department.name}</h3>
                  <p class="text-sm text-gray-600 mb-6">{dept.head_of_department.designation}</p>
                  
                  {(dept.head_of_department.email || dept.head_of_department.phone) && (
                    <div class="space-y-3 pt-6 border-t border-gray-200">
                      {dept.head_of_department.email && (
                        <a href={`mailto:${dept.head_of_department.email}`} class="flex items-center justify-center gap-2 text-sm text-primary hover:underline">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                          {dept.head_of_department.email}
                        </a>
                      )}
                      {dept.head_of_department.phone && (
                        <a href={`tel:${dept.head_of_department.phone}`} class="flex items-center justify-center gap-2 text-sm text-primary hover:underline">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                          {dept.head_of_department.phone}
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </div>
            </div>

            <!-- HOD Message -->
            <div class="lg:col-span-2">
              <div class="bg-white rounded-2xl p-8 border border-gray-200 shadow-sm">
                <svg class="w-12 h-12 text-primary/20 mb-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                </svg>
                
                {dept.head_of_department.message ? (
                  <div class="prose prose-lg max-w-none">
                    <p class="text-gray-700 leading-relaxed text-lg italic mb-6">
                      "{dept.head_of_department.message}"
                    </p>
                  </div>
                ) : (
                  <div class="prose prose-lg max-w-none">
                    <p class="text-gray-700 leading-relaxed mb-4">
                      Welcome to the {dept.short_name}! Our department is committed to providing world-class technical education and fostering innovation among our students.
                    </p>
                    <p class="text-gray-700 leading-relaxed mb-4">
                      With state-of-the-art facilities, experienced faculty, and strong industry connections, we prepare our students to become skilled professionals ready to meet the challenges of the modern engineering landscape.
                    </p>
                    <p class="text-gray-700 leading-relaxed">
                      We invite you to explore our programs and facilities, and join us in our mission to create the next generation of engineering excellence.
                    </p>
                  </div>
                )}
                
                <div class="flex items-center gap-3 mt-8 pt-6 border-t border-gray-200">
                  <div class="flex-1">
                    <p class="font-bold text-gray-900">{dept.head_of_department.name}</p>
                    <p class="text-sm text-gray-600">{dept.head_of_department.designation}</p>
                  </div>
                  <div class="w-16 h-0.5 bg-primary"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Vision & Mission -->
  {deptPrograms.length > 0 && deptPrograms[0].vision && (
    <section class="py-16 bg-gradient-to-br from-indigo-50 via-purple-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-3">Vision & Mission</h2>
            <p class="text-gray-600">Guiding principles that drive our department's excellence</p>
          </div>
          
          <div class="grid lg:grid-cols-2 gap-8">
            <!-- Vision -->
            <div class="group bg-white rounded-2xl p-8 border-2 border-indigo-100 hover:border-indigo-300 hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4 mb-6">
                <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-indigo-600 to-indigo-700 rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Our Vision</h3>
                  <div class="w-16 h-1 bg-gradient-to-r from-indigo-600 to-purple-600 rounded-full"></div>
                </div>
              </div>
              <p class="text-gray-700 leading-relaxed text-lg">{deptPrograms[0].vision}</p>
            </div>

            <!-- Mission -->
            <div class="group bg-white rounded-2xl p-8 border-2 border-purple-100 hover:border-purple-300 hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4 mb-6">
                <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Our Mission</h3>
                  <div class="w-16 h-1 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full"></div>
                </div>
              </div>
              {deptPrograms[0].mission && (
                <ul class="space-y-3">
                  {deptPrograms[0].mission.map((item: string) => (
                    <li class="flex items-start gap-3 text-gray-700">
                      <svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      <span class="leading-relaxed">{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Programs Offered -->
  {deptPrograms.length > 0 && (
    <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Diploma Programs</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Explore our GTU-affiliated diploma programs designed to shape skilled engineering professionals
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {deptPrograms.map(program => (
            <a href={`/programs/${program.slug}`} class="group relative bg-white rounded-2xl border-2 border-gray-100 hover:border-primary hover:shadow-2xl transition-all duration-300 p-6 overflow-hidden">
              <!-- Hover Effect Background -->
              <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-blue-50 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              
              <div class="relative z-10">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex-1">
                    <span class="inline-block text-sm font-bold bg-primary text-white rounded-lg px-3 py-1.5 mb-3">{program.code}</span>
                    <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-primary transition-colors leading-tight">{program.name}</h3>
                  </div>
                  {program.nba_status === "Accredited" && (
                    <div class="flex-shrink-0 ml-3">
                      <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      </div>
                      <p class="text-[10px] font-bold text-green-800 text-center mt-1">NBA</p>
                    </div>
                  )}
                </div>
                
                <p class="text-sm text-gray-600 mb-4 line-clamp-3">{program.vision.substring(0, 150)}…</p>
                
                <div class="flex flex-wrap gap-3 mb-6">
                  <div class="flex items-center gap-1.5 text-xs text-gray-600 bg-gray-50 rounded-lg px-3 py-1.5">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    {program.intake_capacity} Seats
                  </div>
                  <div class="flex items-center gap-1.5 text-xs text-gray-600 bg-gray-50 rounded-lg px-3 py-1.5">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {program.duration_years} Years
                  </div>
                </div>
                
                <div class="flex items-center gap-2 text-sm font-semibold text-primary group-hover:gap-3 transition-all">
                  Explore Program
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* For Science & Humanities - Special message */}
  {deptPrograms.length === 0 && dept.subjects_taught && (
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <div class="bg-white rounded-xl border border-gray-200 p-8">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Foundational Education</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">
              The Science and Humanities Department provides essential foundational knowledge across all engineering programs. While not offering a specific diploma program, this department plays a crucial role in educating students across the following subjects:
            </p>
            <div class="flex flex-wrap gap-2 justify-center">
              {dept.subjects_taught.map(subject => (
                <span class="text-sm bg-blue-50 text-blue-700 rounded-full px-4 py-2">{subject}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Department Newsletters -->
  {newsletters && newsletters.pdfs.length > 0 && (
    <section class="py-16 bg-gradient-to-br from-amber-50 via-orange-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-amber-600 rounded-2xl mb-4 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            </div>
            <h2 class="text-3xl font-bold text-gray-900 mb-3">{newsletters.name} Newsletter</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">
              Stay updated with department activities, student achievements, faculty insights, and technical innovations
            </p>
          </div>

          <!-- Newsletter Cards -->
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
            {newsletters.pdfs.map((pdf: { label: string; file: string }, idx: number) => (
              <a href={pdf.file} target="_blank" rel="noopener noreferrer" class="group bg-white rounded-2xl p-6 border-2 border-amber-100 hover:border-amber-300 hover:shadow-xl transition-all duration-300">
                <div class="flex items-start justify-between mb-4">
                  <div class="w-12 h-12 bg-gradient-to-br from-amber-500 to-orange-500 rounded-xl flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  </div>
                  {idx === 0 && (
                    <span class="text-xs font-bold bg-amber-100 text-amber-700 rounded-full px-2 py-1">Latest</span>
                  )}
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-amber-600 transition-colors">{pdf.label}</h3>
                <p class="text-sm text-gray-600 mb-4">{newsletters.name} Edition</p>
                <div class="flex items-center gap-2 text-sm font-semibold text-amber-600 group-hover:gap-3 transition-all">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  Download PDF
                </div>
              </a>
            ))}
          </div>

          <!-- View All Link -->
          <div class="text-center">
            <div class="flex flex-wrap gap-4 items-center justify-center">
              {newsletters.siteUrl && (
                <a href={newsletters.siteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-amber-600 text-white font-semibold px-8 py-4 rounded-xl hover:bg-amber-700 transition-all shadow-lg hover:shadow-xl">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  Read Interactive Newsletter
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              )}
              <a href="/newsletters" class="inline-flex items-center justify-center gap-2 bg-white text-amber-600 border-2 border-amber-600 font-semibold px-8 py-4 rounded-xl hover:bg-amber-50 transition-all">
                View All College Newsletters
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Laboratories -->
  {dept.laboratories && dept.laboratories.length > 0 && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">State-of-the-Art Laboratories</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Modern facilities equipped with latest technology for hands-on learning experience
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {dept.laboratories.map((lab, idx) => (
            <div class="group relative bg-gradient-to-br from-purple-50 to-white rounded-2xl p-6 border-2 border-purple-100 hover:border-purple-300 hover:shadow-xl transition-all duration-300">
              <!-- Lab Number Badge -->
              <div class="absolute top-6 right-6 w-10 h-10 bg-purple-600 text-white rounded-xl flex items-center justify-center font-bold text-lg shadow-lg group-hover:scale-110 transition-transform">
                {idx + 1}
              </div>
              
              <!-- Lab Icon -->
              <div class="w-14 h-14 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center mb-4 shadow-lg">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
              </div>
              
              <h3 class="text-lg font-bold text-gray-900 mb-3 pr-12 leading-tight">{lab.name}</h3>
              
              <div class="space-y-2">
                {lab.incharge && (
                  <div class="flex items-start gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <div>
                      <p class="text-xs text-gray-500">Lab In-charge</p>
                      <p class="font-medium text-gray-900">{lab.incharge}</p>
                    </div>
                  </div>
                )}
                {lab.equipment_count && (
                  <div class="flex items-center gap-2 text-sm">
                    <div class="flex items-center gap-1.5 bg-purple-100 text-purple-700 rounded-lg px-3 py-1.5 font-semibold">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                      {lab.equipment_count}+ Equipment
                    </div>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
        
        <div class="text-center mt-10">
          <a href={`/departments/${dept.slug}/labs`} class="inline-flex items-center justify-center gap-2 bg-purple-600 text-white font-semibold px-8 py-4 rounded-xl hover:bg-purple-700 transition-all shadow-lg hover:shadow-xl">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            View Full Lab Gallery
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Achievements -->
  {dept.achievements && dept.achievements.length > 0 && (
    <section class="py-16 bg-gradient-to-br from-green-50 via-green-50/50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-green-600 rounded-2xl mb-4 shadow-lg">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
          </div>
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Key Achievements</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            Celebrating our milestones and recognitions in academic excellence
          </p>
        </div>
        
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-4">
          {dept.achievements.map((achievement, idx) => (
            <div class="group bg-white rounded-2xl p-6 border-2 border-gray-100 hover:border-green-300 shadow-sm hover:shadow-xl transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-green-500 to-green-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <p class="text-sm text-gray-700 leading-relaxed flex-1">{achievement}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contact & Actions -->
  {dept.contact && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-gray-900 mb-3">Connect With Us</h2>
            <p class="text-gray-600">Get in touch with our department for inquiries and admissions</p>
          </div>
          
          <div class="bg-gradient-to-br from-primary/5 to-blue-50 rounded-2xl p-8 md:p-12 border border-primary/10">
            <div class="grid md:grid-cols-3 gap-8 mb-10">
              {dept.contact.email && (
                <div class="text-center">
                  <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                    <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Email Address</p>
                  <a href={`mailto:${dept.contact.email}`} class="text-sm font-semibold text-primary hover:underline break-all">{dept.contact.email}</a>
                </div>
              )}
              {dept.contact.phone && (
                <div class="text-center">
                  <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                    <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Phone Number</p>
                  <a href={`tel:${dept.contact.phone}`} class="text-sm font-semibold text-primary hover:underline">{dept.contact.phone}</a>
                </div>
              )}
              {dept.contact.location && (
                <div class="text-center">
                  <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                    <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Location</p>
                  <p class="text-sm font-semibold text-gray-700">{dept.contact.location}</p>
                </div>
              )}
            </div>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center pt-8 border-t border-primary/10">
              <a href="/admissions" class="inline-flex items-center justify-center gap-2 bg-primary text-white font-bold px-8 py-4 rounded-xl hover:bg-primary/90 transition-all shadow-lg hover:shadow-xl">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Apply for Admission
              </a>
              <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white text-primary border-2 border-primary font-semibold px-8 py-4 rounded-xl hover:bg-primary/5 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                Have Questions?
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Navigation Footer -->
  <section class="py-8 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
        <a href="/departments" class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 hover:text-primary transition-colors group">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back to All Departments
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
