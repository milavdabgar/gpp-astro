---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import departments from '../../data/departments.json';
import programs from '../../data/programs.json';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return departments.map(dept => {
    // Find programs offered by this department
    const deptPrograms = programs.filter(p => p.department_id === dept.id);
    
    return {
      params: { slug: dept.slug },
      props: { 
        dept,
        programs: deptPrograms,
      },
    };
  });
};

const { dept, programs: deptPrograms } = Astro.props as any;
---

<Layout title={`${dept.name} | GP Palanpur`}>
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-primary">Home</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/departments" class="hover:text-primary">Departments</a>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-gray-700">{dept.name}</span>
      </nav>

      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Est. {dept.established}</span>
          {dept.faculty_count && (
            <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">{dept.faculty_count} Faculty Members</span>
          )}
          {dept.laboratories && (
            <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">{dept.laboratories.length} Laboratories</span>
          )}
          {dept.website && (
            <a href={dept.website} target="_blank" rel="noopener noreferrer" class="text-xs font-semibold border border-primary text-primary hover:bg-primary hover:text-white transition-colors rounded-full px-3 py-1">
              Visit Website →
            </a>
          )}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{dept.name}</h1>
        <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-2xl">{dept.overview}</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{dept.faculty_count ?? '—'}</div>
            <div class="text-xs text-gray-500 mt-1">Faculty Members</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{dept.laboratories?.length ?? 0}</div>
            <div class="text-xs text-gray-500 mt-1">Laboratories</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{deptPrograms.length}</div>
            <div class="text-xs text-gray-500 mt-1">{deptPrograms.length === 1 ? 'Program' : 'Programs'} Offered</div>
          </div>
          <div class="text-center bg-white/80 rounded-xl p-4 border border-white shadow-sm">
            <div class="text-2xl font-bold text-primary">{dept.achievements?.length ?? 0}</div>
            <div class="text-xs text-gray-500 mt-1">Key Achievements</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Head of Department -->
  {dept.head_of_department && (
    <section class="py-12 bg-white border-b border-gray-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <div class="bg-gradient-to-br from-primary/5 to-blue-50 rounded-xl p-8 border border-primary/10">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 bg-primary rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Head of Department</p>
                <h3 class="text-2xl font-bold text-gray-900">{dept.head_of_department.name}</h3>
              </div>
            </div>
            <div class="grid sm:grid-cols-3 gap-4 pt-4 border-t border-gray-200">
              <div>
                <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Designation</p>
                <p class="text-sm font-medium text-gray-900">{dept.head_of_department.designation}</p>
              </div>
              {dept.head_of_department.email && (
                <div>
                  <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Email</p>
                  <a href={`mailto:${dept.head_of_department.email}`} class="text-sm font-medium text-primary hover:underline">{dept.head_of_department.email}</a>
                </div>
              )}
              {dept.head_of_department.phone && (
                <div>
                  <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Phone</p>
                  <a href={`tel:${dept.head_of_department.phone}`} class="text-sm font-medium text-primary hover:underline">{dept.head_of_department.phone}</a>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Programs Offered -->
  {deptPrograms.length > 0 && (
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-3 text-center">Diploma Programs Offered</h2>
        <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
          This department offers the following {deptPrograms.length === 1 ? 'program' : 'programs'} affiliated with Gujarat Technological University
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {deptPrograms.map(program => (
            <a href={`/programs/${program.slug}`} class="group bg-white rounded-xl border border-gray-200 hover:border-primary hover:shadow-lg transition-all p-6">
              <div class="flex items-start justify-between mb-3">
                <span class="text-xs font-bold bg-primary/10 text-primary rounded px-2 py-1">{program.code}</span>
                {program.nba_status === "Accredited" && (
                  <span class="text-[10px] font-bold bg-green-100 text-green-800 rounded px-1.5 py-0.5">NBA</span>
                )}
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary transition-colors">{program.name}</h3>
              <div class="flex gap-4 text-xs text-gray-500 mb-4">
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {program.intake_capacity} Seats
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  {program.duration_years} Years
                </span>
              </div>
              <p class="text-sm text-gray-600 mb-4">{program.vision.substring(0, 120)}…</p>
              <div class="flex items-center gap-2 text-sm font-medium text-primary group-hover:gap-3 transition-all">
                View Program Details
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* For Science & Humanities - Special message */}
  {deptPrograms.length === 0 && dept.subjects_taught && (
    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <div class="bg-white rounded-xl border border-gray-200 p-8">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-3">Foundational Education</h3>
            <p class="text-gray-600 mb-6 leading-relaxed">
              The Science and Humanities Department provides essential foundational knowledge across all engineering programs. While not offering a specific diploma program, this department plays a crucial role in educating students across the following subjects:
            </p>
            <div class="flex flex-wrap gap-2 justify-center">
              {dept.subjects_taught.map(subject => (
                <span class="text-sm bg-blue-50 text-blue-700 rounded-full px-4 py-2">{subject}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Laboratories -->
  {dept.laboratories && dept.laboratories.length > 0 && (
    <section class="py-16 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-3 text-center">Department Laboratories</h2>
        <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
          Well-equipped laboratories with modern equipment and experienced lab instructors
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
          {dept.laboratories.map((lab, idx) => (
            <div class="bg-gradient-to-br from-purple-50 to-white rounded-xl p-6 border border-purple-100 shadow-sm hover:shadow-lg transition-shadow">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 bg-purple-600 text-white rounded-lg flex items-center justify-center font-bold">
                  {idx + 1}
                </div>
                {lab.equipment_count && (
                  <span class="text-xs font-semibold bg-purple-100 text-purple-700 rounded-full px-2 py-1">
                    {lab.equipment_count}+ Equipment
                  </span>
                )}
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{lab.name}</h3>
              {lab.incharge && (
                <div class="flex items-center gap-2 text-sm text-gray-600 mb-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  <span>In-charge: {lab.incharge}</span>  
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Achievements -->
  {dept.achievements && dept.achievements.length > 0 && (
    <section class="py-16 bg-gradient-to-br from-green-50 to-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-3 text-center">Key Achievements</h2>
        <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
          Notable accomplishments and milestones of our department
        </p>
        <div class="max-w-4xl mx-auto space-y-4">
          {dept.achievements.map((achievement, idx) => (
            <div class="bg-white rounded-xl p-6 border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex items-start gap-4">
              <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed">{achievement}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Contact & Actions -->
  {dept.contact && (
    <section class="py-16 bg-white border-t border-gray-100">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Get in Touch</h2>
          <div class="bg-gray-50 rounded-xl p-8 border border-gray-200">
            <div class="grid sm:grid-cols-3 gap-6 mb-8">
              {dept.contact.email && (
                <div class="text-center">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Email</p>
                  <a href={`mailto:${dept.contact.email}`} class="text-sm font-medium text-primary hover:underline">{dept.contact.email}</a>
                </div>
              )}
              {dept.contact.phone && (
                <div class="text-center">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Phone</p>
                  <a href={`tel:${dept.contact.phone}`} class="text-sm font-medium text-primary hover:underline">{dept.contact.phone}</a>
                </div>
              )}
              {dept.website && (
                <div class="text-center">
                  <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
                    <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                  </div>
                  <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Website</p>
                  <a href={dept.website} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-primary hover:underline">Visit Website →</a>
                </div>
              )}
            </div>
            <div class="flex flex-col sm:flex-row gap-3 justify-center pt-6 border-t border-gray-200">
              <a href={`/departments/${dept.slug}/faculty`} class="inline-flex items-center justify-center gap-2 bg-secondary text-secondary-foreground font-semibold px-6 py-3 rounded-lg hover:bg-secondary/90 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                View All Faculty
              </a>
              <a href="/admissions" class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
                Apply for Admission
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Back Link -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row gap-4 items-center justify-between">
      <a href="/departments" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to All Departments
      </a>
      <a href="/contact" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline">
        Have questions? Contact us
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>
