---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import departments from '../../data/departments.json';
import programs from '../../data/programs.json';

// Count metrics
const totalFaculty = departments.reduce((sum, dept) => sum + (dept.faculty_count || 0), 0);
const totalLabs = departments.reduce((sum, dept) => sum + (dept.laboratories?.length || 0), 0);
const totalPrograms = programs.length;
---

<Layout title="Departments | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Academic Units</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Faculty & Infrastructure</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Academic Departments</h1>
      <p class="text-xl text-gray-600 mb-8">
        Our six specialized departments house experienced faculty, modern laboratories, and cutting-edge infrastructure to deliver quality technical education.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">{departments.length}</div><div class="text-sm text-gray-600">Departments</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">{totalFaculty}+</div><div class="text-sm text-gray-600">Faculty Members</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">{totalLabs}+</div><div class="text-sm text-gray-600">Laboratories</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">{totalPrograms}</div><div class="text-sm text-gray-600">Diploma Programs</div></div>
      </div>
    </div>
  </section>

  <!-- Departments Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {departments.map(dept => {
          // Find programs offered by this department
          const deptPrograms = programs.filter(p => p.department_id === dept.id);
          
          return (
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg transition-shadow flex flex-col">
              <div class="p-6 border-b border-gray-100">
                <div class="flex items-start justify-between mb-3">
                  <h2 class="text-lg font-bold text-gray-900 leading-tight">{dept.name}</h2>
                  {dept.website && (
                    <a href={dept.website} target="_blank" rel="noopener noreferrer" class="ml-2 flex-shrink-0 text-primary hover:text-primary/80" title="Department Website">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  )}
                </div>
                <div class="flex flex-wrap gap-3 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    Est. {dept.established}
                  </span>
                  {dept.faculty_count && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                      {dept.faculty_count} Faculty
                    </span>
                  )}
                  {dept.laboratories && (
                    <span class="flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                      {dept.laboratories.length} Labs
                    </span>
                  )}
                </div>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <p class="text-gray-600 text-sm mb-4 leading-relaxed flex-1">{dept.overview.substring(0, 130)}…</p>
                
                {/* Programs Offered */}
                {deptPrograms.length > 0 ? (
                  <div class="mb-4">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Programs Offered</h3>
                    <div class="flex flex-wrap gap-1">
                      {deptPrograms.map(program => (
                        <a href={`/programs/${program.slug}`} class="text-[11px] bg-primary/5 text-primary rounded px-2 py-0.5 hover:bg-primary/10 transition-colors">
                          {program.code}
                        </a>
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class="mb-4">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Role</h3>
                    <p class="text-[11px] text-gray-600">Teaching across all programs</p>
                  </div>
                )}

                {/* Head of Department */}
                {dept.head_of_department && (
                  <div class="mb-4 pb-4 border-t border-gray-100 pt-4">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Head of Department</h3>
                    <p class="text-sm font-medium text-gray-900">{dept.head_of_department.name}</p>
                    <p class="text-xs text-gray-600">{dept.head_of_department.designation}</p>
                  </div>
                )}

                <div class="flex gap-2 mt-auto">
                  <a href={`/departments/${dept.slug}`} class="flex-1 text-center text-sm font-semibold bg-primary text-white rounded-lg py-2 hover:bg-primary/90 transition-colors">
                    View Details
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">About Our Departments</h2>
        <div class="bg-white rounded-xl border border-gray-200 p-8 space-y-4">
          <p class="text-gray-600 leading-relaxed">
            Each department at Government Polytechnic Palanpur is staffed with qualified and experienced faculty members who are dedicated to providing quality education and mentorship to students.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Our departments are equipped with modern laboratories, industry-standard equipment, and up-to-date learning resources. Faculty members regularly participate in workshops, training programs, and research activities to stay current with industry trends.
          </p>
          <p class="text-gray-600 leading-relaxed">
            The Science & Humanities Department plays a crucial role in providing foundational knowledge in mathematics, physics, chemistry, and communication skills that are essential for all engineering disciplines.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mt-6 pt-6 border-t border-gray-200">
            <a href="/programs" class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
              View Programs
            </a>
            <a href="/faculty" class="inline-flex items-center justify-center gap-2 border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-lg hover:border-primary hover:text-primary transition-colors">
              Meet Our Faculty
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
