---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import departments from '../../data/departments.json';
---

<Layout title="Departments | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">6 Programs</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">3 NBA Accredited</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Engineering Departments</h1>
      <p class="text-xl text-gray-600 mb-8">
        Explore our six engineering disciplines offering industry-focused diploma programs with state-of-the-art facilities and experienced faculty.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">6</div><div class="text-sm text-gray-600">Programs</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">356</div><div class="text-sm text-gray-600">Total Seats</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">3</div><div class="text-sm text-gray-600">NBA Accredited</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">54+</div><div class="text-sm text-gray-600">Faculty Members</div></div>
      </div>
    </div>
  </section>

  <!-- Departments Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {departments.map(dept => (
          <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-lg transition-shadow flex flex-col">
            <div class="p-6 border-b border-gray-100">
              <div class="flex items-start justify-between mb-3">
                <h2 class="text-lg font-bold text-gray-900 leading-tight">{dept.name}</h2>
                {dept.nba_status === "Accredited" && (
                  <span class="ml-2 flex-shrink-0 text-[10px] font-bold bg-green-100 text-green-800 rounded px-1.5 py-0.5">NBA</span>
                )}
                {dept.nba_status === "Applying" && (
                  <span class="ml-2 flex-shrink-0 text-[10px] font-bold bg-blue-100 text-blue-800 rounded px-1.5 py-0.5">NBA*</span>
                )}
              </div>
              <div class="flex gap-3 text-xs text-gray-500">
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  Est. {dept.established}
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {dept.intake_capacity} Seats
                </span>
                {dept.faculty_count && (
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    {dept.faculty_count} Faculty
                  </span>
                )}
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col">
              <p class="text-gray-600 text-sm mb-4 leading-relaxed flex-1">{dept.overview.substring(0, 140)}…</p>
              <div class="mb-4">
                <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Specializations</h3>
                <div class="flex flex-wrap gap-1">
                  {dept.specializations.slice(0, 3).map(s => (
                    <span class="text-[11px] bg-primary/5 text-primary rounded px-2 py-0.5">{s}</span>
                  ))}
                  {dept.specializations.length > 3 && (
                    <span class="text-[11px] bg-gray-100 text-gray-500 rounded px-2 py-0.5">+{dept.specializations.length - 3} more</span>
                  )}
                </div>
              </div>
              <div class="flex gap-2 mt-auto">
                <a href={`/departments/${dept.slug}`} class="flex-1 text-center text-sm font-semibold bg-primary text-white rounded-lg py-2 hover:bg-primary/90 transition-colors">
                  View Details
                </a>
                {dept.website && (
                  <a href={dept.website} target="_blank" rel="noopener noreferrer" class="px-3 py-2 rounded-lg border border-gray-200 text-gray-500 hover:text-primary hover:border-primary transition-colors" title="Department Website">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Ready to Apply?</h2>
      <p class="text-gray-600 mb-8">Admissions for 2025-26 are conducted through ACPDC. Begin your engineering journey at GP Palanpur.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/admissions" class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary/90 transition-colors">
          Admissions Info
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-lg hover:border-primary hover:text-primary transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
