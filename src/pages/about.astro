---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';
import collegeInfo from '../data/college-info.json';
---

<Layout title="About Us | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <div class="flex justify-center gap-2 mb-6">
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">Est. {collegeInfo.basic_info.established}</span>
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border border-gray-200 text-gray-700">{collegeInfo.basic_info.approval}</span>
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border border-gray-200 text-gray-700">GTU Affiliated</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">About {collegeInfo.name}</h1>
        <p class="text-xl text-gray-600 mb-8">
          {collegeInfo.motto} — Building technical excellence in Banaskantha district for over {collegeInfo.achievements.established_years} years
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">{collegeInfo.achievements.established_years}</div>
            <div class="text-sm text-gray-500">Years of Excellence</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">{collegeInfo.infrastructure.total_departments}</div>
            <div class="text-sm text-gray-500">Departments</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">{collegeInfo.achievements.nba_accredited_programs}</div>
            <div class="text-sm text-gray-500">NBA Accredited</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">{collegeInfo.achievements.job_offers_2024}</div>
            <div class="text-sm text-gray-500">Placements 2024</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- College Overview -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Legacy of Excellence</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Government Polytechnic Palanpur stands as a premier technical institution in Gujarat,
              established in {collegeInfo.basic_info.established} with a commitment to providing world-class
              diploma engineering education. Located on an expansive {collegeInfo.basic_info.campus_area} campus,
              we have been at the forefront of technical education in the Banaskantha district.
            </p>
            <p>
              Our institution is {collegeInfo.basic_info.approval} and affiliated with {collegeInfo.basic_info.affiliation},
              ensuring that our academic programs meet the highest standards of technical education.
              With {collegeInfo.administration.total_faculty} dedicated faculty members, including {collegeInfo.administration.faculty_with_phd} PhD holders,
              we provide comprehensive education across {collegeInfo.infrastructure.total_departments} engineering disciplines.
            </p>
            <p>
              Strategically located outside Malan Gate near Dhaniyana Crossroads, our campus is easily
              accessible from all parts of Banaskantha district and neighboring areas.
            </p>
          </div>
          <div class="mt-8 grid md:grid-cols-2 gap-4">
            <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-8 h-8 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
              <div>
                <div class="font-semibold text-gray-900">{collegeInfo.basic_info.approval}</div>
                <div class="text-sm text-gray-500">Quality Assured</div>
              </div>
            </div>
            <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-lg">
              <svg class="w-8 h-8 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              <div>
                <div class="font-semibold text-gray-900">{collegeInfo.basic_info.campus_area}</div>
                <div class="text-sm text-gray-500">Green Campus</div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <div class="bg-white p-6 rounded-2xl shadow-xl border border-gray-100">
            <img
              src="https://dummyimage.com/600x400/1d58a5/ffffff&text=Government+Polytechnic+Palanpur"
              alt="Government Polytechnic Palanpur"
              class="rounded-xl w-full"
            />
            <div class="mt-4 text-center">
              <h3 class="font-semibold text-gray-900">Principal's Office</h3>
              <p class="text-sm text-gray-500">Led by {collegeInfo.administration.principal}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision & Mission -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Vision & Mission</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">Guiding principles that drive our commitment to excellence</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl border border-gray-200 p-8 text-center hover:shadow-xl transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Our Vision</h3>
          <p class="text-gray-600 leading-relaxed">
            To be a center of excellence in technical education, fostering innovation,
            research, and industry collaboration while producing skilled engineers who
            contribute to national development and technological advancement.
          </p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-8 text-center hover:shadow-xl transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mx-auto mb-6">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Our Mission</h3>
          <p class="text-gray-600 leading-relaxed">
            To provide quality technical education through modern curriculum, experienced faculty,
            state-of-the-art infrastructure, and industry partnerships, preparing students for
            successful careers and lifelong learning in engineering and technology.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Achievements -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Key Achievements & Recognition</h2>
        <p class="text-xl text-gray-600">Milestones that showcase our commitment to excellence</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6 text-center hover:shadow-lg transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">{collegeInfo.achievements.nba_accredited_programs}</div>
          <p class="font-medium text-gray-700">NBA Accredited Programs</p>
          <p class="text-sm text-gray-500 mt-2">Civil, Electrical & Mechanical Engineering</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 text-center hover:shadow-lg transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">{collegeInfo.achievements.job_offers_2024}</div>
          <p class="font-medium text-gray-700">Job Offers in 2024</p>
          <p class="text-sm text-gray-500 mt-2">With {collegeInfo.achievements.placement_companies}+ recruiting companies</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 text-center hover:shadow-lg transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-purple-100 rounded-full mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">{collegeInfo.administration.total_faculty}</div>
          <p class="font-medium text-gray-700">GPSC Selected Faculty</p>
          <p class="text-sm text-gray-500 mt-2">Including {collegeInfo.administration.faculty_with_phd} PhD holders</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6 text-center hover:shadow-lg transition-shadow">
          <div class="flex items-center justify-center w-16 h-16 bg-orange-100 rounded-full mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <div class="text-2xl font-bold text-primary mb-2">4</div>
          <p class="font-medium text-gray-700">Published Patents</p>
          <p class="text-sm text-gray-500 mt-2">Through SSIP Innovation Cell</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership Team -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Leadership Team</h2>
        <p class="text-xl text-gray-600">Meet the professionals leading GP Palanpur</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { name: "Mr. S D Dabhi", role: "Principal", desc: "Leading the institution with vision and excellence" },
          { name: "Mr. D D Prajapati", role: "HOD - Mechanical Engineering", desc: "Expert in mechanical systems and manufacturing" },
          { name: "Mr. D N Sheth", role: "HOD - Civil Engineering", desc: "Specialist in structural and construction engineering" },
          { name: "Mr. A D Shah", role: "HOD - Electrical Engineering", desc: "Expert in electrical systems and power engineering" },
          { name: "Mr. S J Chauhan", role: "HOD - Electronics & Communication | ICT", desc: "Leading both EC and ICT departments" },
          { name: "Ms. M M Shah", role: "HOD - Information Technology", desc: "Expert in IT systems and software development" },
        ].map(leader => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 text-center hover:shadow-lg transition-shadow">
            <div class="flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mx-auto mb-4">
              <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-1">{leader.name}</h3>
            <p class="text-primary font-medium text-sm mb-2">{leader.role}</p>
            <p class="text-gray-500 text-sm">{leader.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Infrastructure -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Infrastructure & Facilities</h2>
        <p class="text-xl text-gray-600">Modern amenities supporting comprehensive technical education</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="flex items-center justify-center w-20 h-20 bg-primary/10 rounded-full mx-auto mb-4">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Academic Excellence</h3>
          <div class="space-y-1 text-gray-600">
            <p><strong>{collegeInfo.infrastructure.total_labs}+</strong> Modern Laboratories</p>
            <p><strong>{collegeInfo.infrastructure.library_books_volumes.toLocaleString()}</strong> Library Books</p>
            <p>Smart Classrooms with CCTV</p>
            <p>Digital Learning Resources</p>
          </div>
        </div>
        <div class="text-center">
          <div class="flex items-center justify-center w-20 h-20 bg-primary/10 rounded-full mx-auto mb-4">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Campus Life</h3>
          <div class="space-y-1 text-gray-600">
            <p>Sports Complex & Facilities</p>
            <p>Modern Auditorium</p>
            <p>Campus Canteen</p>
          </div>
        </div>
        <div class="text-center">
          <div class="flex items-center justify-center w-20 h-20 bg-primary/10 rounded-full mx-auto mb-4">
            <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Green & Digital</h3>
          <div class="space-y-1 text-gray-600">
            <p><strong>86,000 units</strong> Solar Power Plant</p>
            <p><strong>14</strong> NaMo WiFi Access Points</p>
            <p>National Digital Library Access</p>
            <p>Solar Water Heaters in Hostels</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Experience GP Palanpur</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Watch our campus tour and discover what makes us a leading institution in technical education
        </p>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="relative aspect-video rounded-xl overflow-hidden shadow-2xl">
          <iframe
            src="https://www.youtube.com/embed/Z6w-asbJO9E?start=336"
            title="Government Polytechnic Palanpur Introduction"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Join Our Legacy of Excellence</h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Become part of GP Palanpur's proud tradition of producing skilled engineers.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/admissions" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary hover:bg-primary/90 rounded-lg transition-colors">
          Apply for Admission
        </a>
        <a href="/departments" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-primary border border-primary hover:bg-primary/5 rounded-lg transition-colors">
          Explore Programs
        </a>
        <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-gray-700 border border-gray-300 hover:bg-gray-50 rounded-lg transition-colors">
          Visit Campus
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
