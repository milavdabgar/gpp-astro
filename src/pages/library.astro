const usefulLinks = [
  { name: "Government Polytechnic Palanpur",  url: "http://www.gppp.cteguj.in/" },
  { name: "Gujarat Technological University", url: "https://www.gtu.ac.in/" },
  { name: "Employment News (E-version)",      url: "https://eneversion.nic.in/" },
