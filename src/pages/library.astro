];

const staff = [
  { no: 1, name: "Smt. K. A. Patel",   designation: "Library In Charge",    qualification: "B.E. (IC)",      mobile: "9428505262" },
  { no: 2, name: "Shri S. N. Chauhan", designation: "Co Library In Charge", qualification: "B.E.",           mobile: "9712130005" },
  { no: 3, name: "Shri B. N. Raval",   designation: "Librarian",            qualification: "BA, BLIS, MLIS", mobile: "9714119551" },
  { no: 4, name: "Mr. C. R. Parmar",   designation: "Peon",                 qualification: "9th Pass",       mobile: "9924658770" },
];

const objectives = [
  "Cultivate reading habits among students and teaching staff.",
  "Provide accessibility to information in a well-organised and coherent manner.",
  "Supply students with necessary skills to enhance their employability and meet future challenges.",
  "Provide facilities and services for the teaching community and students to discover needed information.",
];

const policies = [
  "Silence should be strictly maintained in the library premises.",
  "Faculty may borrow up to 5 books for 1 month; students may borrow up to 2 books for 14 days.",
  "Books are issued against Library Tickets provided to students.",
  "A fine of Rs. 1.00 per day is levied for books kept beyond the due date.",
  "Books must be checked for missing pages or damage before issue; users are responsible for any damage found later.",
  "Reference books, periodicals, and bound volumes are for use within the library premises only.",
  "Mobile phones must be switched off inside the library.",
  "Users must present identification if requested by library staff.",
  "Persistent violation of library rules may result in suspension of borrowing/access rights.",
];
---

<Layout title="Library | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center flex-wrap gap-2 mb-6">
        <span class="text-xs font-semibold bg-secondary text-secondary-foreground rounded-full px-3 py-1">Est. 1984</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Digital Resources</span>
        <span class="text-xs font-semibold border border-gray-300 rounded-full px-3 py-1">Research Support</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">GP Palanpur Library</h1>
      <p class="text-xl text-gray-600 mb-8">
        Your gateway to knowledge with over 18,000 books, open-access journals, digital e-resources, and a dedicated reading hall supporting academic excellence since 1984.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-primary">18,042</div><div class="text-sm text-gray-600">Book Volumes</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">4,159</div><div class="text-sm text-gray-600">Unique Titles</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">50+</div><div class="text-sm text-gray-600">Seating Capacity</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-primary">1984</div><div class="text-sm text-gray-600">Established</div></div>
      </div>
    </div>
  </section>

  <!-- About + Vision -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">About the Library</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Former President of India, Dr. S. Radhakrishnan once said, <em>"Library is the heart of an institution."</em> The Library at Government Polytechnic Palanpur has been serving students and faculty since <strong>1984</strong>.
            </p>
            <p>
              The library has a reading hall with a seating capacity of <strong>50 students</strong> and a very rich collection of books covering engineering, science, technology, humanities, competitive examinations, and motivational literature. Newly acquired books are placed on the <strong>New Arrivals display</strong> before being released for loan.
            </p>
            <p>
              An <strong>E-Library section</strong> is also available, providing internet-enabled access to a wide range of digital resources including e-books, e-journals, and national portals.
            </p>
          </div>
          <div class="mt-6 p-5 bg-primary/5 rounded-xl border border-primary/20">
            <div class="font-semibold text-gray-900 mb-1 flex items-center gap-2 text-sm">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              Library Portal (Blogspot)
            </div>
            <p class="text-gray-500 text-xs mb-3">Maintained by our librarian with full e-resource listings, collection details, and updates.</p>
            <a href="https://gpplibrary.blogspot.com/" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-4 py-2 rounded-lg hover:bg-primary/90 transition-colors text-xs">
              Visit Library Portal
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Vision</h3>
            <p class="text-gray-600 text-sm leading-relaxed">To serve as a <strong>knowledge hub</strong> of the college by providing information services to rural youths, shaping a better future and enriching knowledge to create a better world for themselves.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Aims and Objectives</h3>
            <ul class="space-y-1.5">
              {objectives.map(obj => (
                <li class="flex items-start gap-2 text-gray-600 text-sm">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  {obj}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Collection -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Library Collection</h2>
        <p class="text-gray-600">A rich and growing collection covering all branches of engineering and beyond</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-primary/5 px-5 py-3 border-b border-gray-100">
            <h3 class="font-bold text-gray-900">Books</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                  <th class="text-left px-5 py-3 font-semibold text-gray-700">Category</th>
                  <th class="text-right px-5 py-3 font-semibold text-gray-700">Volumes</th>
                  <th class="text-right px-5 py-3 font-semibold text-gray-700">Titles</th>
                </tr>
              </thead>
              <tbody>
                {bookCollection.map((row, i) => (
                  <tr class={`border-b border-gray-50 ${row.category === 'Total' ? 'bg-primary/5 font-bold' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                    <td class="px-5 py-3 text-gray-800">{row.category}</td>
                    <td class="px-5 py-3 text-right text-gray-800">{row.volumes.toLocaleString('en-IN')}</td>
                    <td class="px-5 py-3 text-right text-gray-800">{row.titles.toLocaleString('en-IN')}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="bg-primary/5 px-5 py-3 border-b border-gray-100">
            <h3 class="font-bold text-gray-900">Other Resources</h3>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                <th class="text-left px-5 py-3 font-semibold text-gray-700">Item</th>
                <th class="text-right px-5 py-3 font-semibold text-gray-700">Count</th>
              </tr>
            </thead>
            <tbody>
              {otherCollection.map((row, i) => (
                <tr class={`border-b border-gray-50 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                  <td class="px-5 py-3 text-gray-800">{row.item}</td>
                  <td class="px-5 py-3 text-right text-gray-800">{row.count.toLocaleString('en-IN')}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Library Services</h2>
        <p class="text-gray-600">Comprehensive services designed to support your academic journey</p>
      </div>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-5xl mx-auto">
        {services.map(s => (
          <div class="flex items-start gap-3 bg-gray-50 rounded-xl p-4 border border-gray-100">
            <svg class="w-4 h-4 mt-0.5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span class="text-gray-800 text-sm font-medium">{s}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Access E-Resources -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Open Access E-Resources</h2>
        <p class="text-gray-600">Free national and international digital learning platforms accessible to all</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {openAccessResources.map(r => (
          <a href={r.url} target="_blank" rel="noopener noreferrer"
             class="flex items-start gap-4 bg-white rounded-xl p-4 border border-gray-100 hover:border-primary/30 hover:shadow-md transition-all group">
            <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm group-hover:text-primary transition-colors">{r.name}</div>
              <div class="text-gray-500 text-xs mt-0.5">{r.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- E-Books -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">E-Books</h2>
        <p class="text-gray-600">Free digital book repositories for students and readers</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-5xl mx-auto">
        {eBooksLinks.map(b => (
          <a href={b.url} target="_blank" rel="noopener noreferrer"
             class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-primary/30 hover:shadow-md transition-all group">
            <div class="font-semibold text-gray-900 text-sm group-hover:text-primary transition-colors mb-1">{b.name}</div>
            <div class="text-gray-500 text-xs">{b.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- E-Journals Open Access -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">E-Journals (Open Access)</h2>
        <p class="text-gray-600">Peer-reviewed open access journals relevant to engineering and technology</p>
      </div>
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-3 max-w-6xl mx-auto">
        {openAccessJournals.map(j => (
          <a href={j.url} target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 bg-white rounded-lg px-4 py-2.5 border border-gray-100 mb-2 hover:border-primary/30 hover:text-primary transition-all group break-inside-avoid text-sm text-gray-800 font-medium">
            <svg class="w-3 h-3 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            {j.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Online Journals Subscription -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Online Journals (Subscription)</h2>
        <p class="text-gray-600">Inventi Impact journals available via institutional login</p>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-8 flex flex-wrap items-center gap-6">
          <svg class="w-8 h-8 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <div class="flex-1">
            <div class="font-semibold text-blue-900 mb-0.5 text-sm">Institutional Login Credentials</div>
            <p class="text-blue-700 text-xs">Use these credentials on the Inventi journal portal to access subscriber-only content.</p>
          </div>
          <div class="flex gap-6 flex-wrap">
            <div><div class="text-xs text-blue-600 font-medium uppercase tracking-wide">Username</div><div class="font-mono font-bold text-blue-900 text-sm">gppl</div></div>
            <div><div class="text-xs text-blue-600 font-medium uppercase tracking-wide">Password</div><div class="font-mono font-bold text-blue-900 text-sm">gppl@23</div></div>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {inventiJournals.map(j => (
            <a href={j.url} target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-3 bg-gray-50 rounded-lg px-4 py-3 border border-gray-100 hover:border-primary/30 hover:text-primary transition-all text-sm font-medium text-gray-800">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              {j.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- E-Magazines and E-Newspapers -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">E-Magazines and E-Newspapers</h2>
        <p class="text-gray-600">Stay informed with digital publications available in the library</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-10 max-w-5xl mx-auto">
        <div>
          <h3 class="font-bold text-gray-900 text-lg mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            E-Magazines
          </h3>
          <div class="space-y-2">
            {eMagazines.map(m => (
              <a href={m.url} target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-3 bg-white rounded-lg px-4 py-2.5 border border-gray-100 hover:border-primary/30 hover:text-primary transition-all text-sm font-medium text-gray-800">
                <svg class="w-3 h-3 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                {m.name}
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-bold text-gray-900 text-lg mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            E-Newspapers
          </h3>
          <div class="space-y-2">
            {eNewsPapers.map(n => (
              <a href={n.url} target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-3 bg-white rounded-lg px-4 py-2.5 border border-gray-100 hover:border-primary/30 hover:text-primary transition-all text-sm font-medium text-gray-800">
                <svg class="w-3 h-3 text-primary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                {n.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Policies and Guidelines -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Policies and Guidelines</h2>
        <p class="text-gray-600">Rules to keep the library environment pleasant and productive for everyone</p>
      </div>
      <div class="max-w-3xl mx-auto bg-amber-50 border border-amber-200 rounded-xl p-6">
        <ul class="space-y-3">
          {policies.map(p => (
            <li class="flex items-start gap-3 text-gray-700 text-sm">
              <svg class="w-4 h-4 mt-0.5 text-amber-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
              {p}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Useful Links -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Useful Links</h2>
        <p class="text-gray-600">Quick access to important academic and institutional websites</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
        {usefulLinks.map(l => (
          <a href={l.url} target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-5 py-3 text-sm font-medium text-gray-800 hover:border-primary/40 hover:text-primary transition-all shadow-sm">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            {l.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Library Staff -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Library Staff</h2>
        <p class="text-gray-600">Meet the dedicated team managing your library</p>
      </div>
      <div class="max-w-3xl mx-auto bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-primary/5 border-b border-gray-100">
                <th class="text-center px-4 py-3 font-semibold text-gray-700">Sr.</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-700">Name</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-700">Designation</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-700">Qualification</th>
                <th class="text-left px-4 py-3 font-semibold text-gray-700">Mobile</th>
              </tr>
            </thead>
            <tbody>
              {staff.map((s, i) => (
                <tr class={`border-b border-gray-50 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                  <td class="px-4 py-3 text-center text-gray-600">{s.no}</td>
                  <td class="px-4 py-3 font-medium text-gray-900">{s.name}</td>
                  <td class="px-4 py-3 text-gray-700">{s.designation}</td>
                  <td class="px-4 py-3 text-gray-600">{s.qualification}</td>
                  <td class="px-4 py-3 text-gray-600 font-mono text-xs">{s.mobile}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
