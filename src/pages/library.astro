  { name: "Global Journal of Technology and Optimization",                      url: "https://www.hilarispublisher.com/global-journal-technology-optimization.html" },
  { name: "Industrial Engineering and Management",                              url: "https://www.hilarispublisher.com/industrial-engineering-management.html" },
  { name: "Advances in Robotics and Automation",                                url: "https://www.hilarispublisher.com/advances-in-robotics-automation.html" },
