  { name: "Journal of Steel Structures and Construction",                       url: "https://www.hilarispublisher.com/steel-structures-construction.html" },
  { name: "American Journal of Engineering and Applied Sciences",               url: "https://thescipub.com/ajeas.toc" },
  { name: "International Journal of Advancements in Technology",                url: "https://www.longdom.org/international-journal-of-advancements-in-technology.html" },
