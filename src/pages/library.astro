const inventiJournals = [
  { name: "Inventi Impact: Antennas and Propagation",  url: "https://www.inventi.in/journal/impact/72/InventiImpactAntennasAndPropagation" },
  { name: "Inventi Impact: Artificial Intelligence",   url: "https://www.inventi.in/journal/impact/73/InventiImpactArtificialIntelligence" },
  { name: "Inventi Impact: Civil Structures",          url: "https://www.inventi.in/journal/impact/125/InventiImpactCivilStructures" },
  { name: "Inventi Impact: Electrical Engineering",    url: "https://www.inventi.in/journal/impact/122/InventiImpactElectricalEngineering" },
