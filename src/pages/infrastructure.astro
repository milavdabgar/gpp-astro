---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const sections = [
  {
    title: "Academic Buildings",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    items: [
      { name: "Main Academic Block", detail: "Classrooms and faculty offices for all 5 departments" },
      { name: "Lecture Halls", detail: "60-seat and 90-seat air-cooled lecture rooms with projectors" },
      { name: "Seminar Hall", detail: "150-seat seminar hall for events, guest lectures, and placements" },
      { name: "Administration Block", detail: "Principal's office, accounts, admission, and examination cells" },
    ],
  },
  {
    title: "Laboratories",
    icon: "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18",
    items: [
      { name: "Civil Engineering Labs", detail: "Concrete, Soil Mechanics, Surveying, and Material Testing" },
      { name: "Electrical Engineering Labs", detail: "Electrical Machines, Power Electronics, and Measurement labs" },
      { name: "Mechanical Engineering Labs", detail: "Workshop, Fluid Mechanics, Thermodynamics, and CAD lab" },
      { name: "EC Engineering Labs", detail: "Digital Electronics, Embedded Systems, and Communication labs" },
      { name: "Computer/IT Labs", detail: "3 networked computer labs with high-speed internet and GPU workstations" },
      { name: "Bee-Robokids Robotics Lab", detail: "Industry-sponsored robotics and automation lab" },
    ],
  },
  {
    title: "Library & Learning Resources",
    icon: "M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z",
    items: [
      { name: "Central Library", detail: "5,000+ books, national/international journals, and digital access" },
      { name: "NPTEL / e-Library", detail: "Online access to NPTEL video lectures and e-resources" },
      { name: "Reading Room", detail: "80-seat reading room open 9 AM – 6 PM on working days" },
      { name: "Newspaper & Magazine Section", detail: "Daily newspapers and technical periodicals available" },
    ],
  },
  {
    title: "Sports & Recreation",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    items: [
      { name: "Cricket Ground", detail: "Full-size cricket ground for inter-department and district matches" },
      { name: "Volleyball Court", detail: "Outdoor volleyball court for student and staff recreation" },
      { name: "Badminton Court", detail: "Indoor badminton facility for students and staff" },
      { name: "Outdoor Play Area", detail: "Multi-use outdoor space for kabaddi, athletics, and other sports" },
    ],
  },
  {
    title: "Student Welfare",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    items: [
      { name: "Girls Hostel", detail: "Residential accommodation for women students from outstation" },
      { name: "Canteen", detail: "Campus canteen providing snacks and meals at subsidised rates" },
      { name: "Medical First Aid", detail: "First-aid centre on campus with basic medical assistance" },
      { name: "Drinking Water", detail: "RO-purified drinking water stations across campus" },
    ],
  },
  {
    title: "IT & Connectivity",
    icon: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    items: [
      { name: "Campus Wi-Fi", detail: "High-speed Wi-Fi connectivity across academic and hostel blocks" },
      { name: "NKN Connectivity", detail: "NMEICT/NKN broadband internet connectivity" },
      { name: "CCTV Surveillance", detail: "CCTV cameras at entry points, corridors, and key campus areas" },
      { name: "Biometric Attendance", detail: "Biometric attendance system for faculty and staff" },
    ],
  },
];
---

<Layout title="Infrastructure | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Infrastructure</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Infrastructure</h1>
      <p class="text-lg text-gray-600">Modern, well-equipped campus facilities designed to support quality technical education at GPP Palanpur.</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-white">5+</div>
          <div class="text-sm text-white/80 mt-1">Academic Buildings</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">20+</div>
          <div class="text-sm text-white/80 mt-1">Laboratories</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">5,000+</div>
          <div class="text-sm text-white/80 mt-1">Library Books</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">13 acres</div>
          <div class="text-sm text-white/80 mt-1">Campus Area</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Infrastructure Sections -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="space-y-12">
        {sections.map(s => (
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-gray-900">{s.title}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {s.items.map(item => (
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-primary/30 transition-colors">
                  <h3 class="font-bold text-gray-900 mb-2 text-sm">{item.name}</h3>
                  <p class="text-gray-600 text-xs">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Explore More</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/library" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Library</div>
        </a>
        <a href="/sports" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Sports</div>
        </a>
        <a href="/about/bee-robokids-lab" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Robotics Lab</div>
        </a>
        <a href="/facilities" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">All Facilities</div>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
