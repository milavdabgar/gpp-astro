---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const buildings = [
  { name: "Main Building",    area: "4,524 sqm", use: "Civil, Electrical departments — classrooms, labs, faculty offices, admin block" },
  { name: "Workshop",         area: "1,479 sqm", use: "Mechanical workshop — Machine Lab-1 & 2, Smithy, Fitter, Carpentry" },
  { name: "BADP Building",    area: "2,056 sqm", use: "EC, ICT, IT departments — Electronics Lab, Communication Lab, Computer Labs" },
  { name: "LRUC Building",    area: "1,038 sqm", use: "Library, Reading Room, Common Rooms, Student facilities" },
  { name: "Mechanical Block", area: "4,872 sqm", use: "Mechanical dept — Thermal, CAD/CAMD, Theory of Machines, ED&MD, Physics & General labs" },
];

const sections = [
  {
    title: "Academic Buildings",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    items: [
      { name: "Classrooms (22)",         detail: "22 classrooms totalling 1,223.75 sqm; all equipped with projectors and adequate seating" },
      { name: "Drawing Halls (3)",        detail: "3 drawing halls totalling 275.45 sqm; spacious rooms for engineering graphics and design work" },
      { name: "Seminar / AV Hall (1)",    detail: "Audio-visual seminar hall of 325 sqm for guest lectures, placement drives, and events" },
      { name: "Administration Block",     detail: "1,132 sqm of administrative area: Principal's office, accounts, admissions, and examination cells" },
    ],
  },
  {
    title: "Laboratories",
    icon: "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18",
    items: [
      { name: "Civil & Applied Mechanics (8 labs)", detail: "Material Testing, Concrete Technology, Soil Mechanics, Survey, Hydraulics, Transportation, Water Supply & Sanitary Engg., Computer Lab" },
      { name: "Electrical Engineering (6 labs)",    detail: "Electrical Power Lab, Electrical Machine Lab-1 & 2, Electronics Lab, Computer Lab, Electrical Workshop & Project Lab" },
      { name: "Mechanical Engineering (12 labs)",   detail: "Thermal Engg 1&2/BME, FMHM/M&I, CAD-CAMD, Machine Lab-1 & 2, Smithy, Fitter, Carpentry, Theory of Machines, ED&MD, Manufacturing Systems, Design of Mechanical Elements" },
      { name: "EC / ICT / IT (10 labs)",            detail: "Electronics Lab, Workshop Lab, Communication Lab, Digital Lab, Computer Lab-1 & 2 (EC); Multimedia Lab, Electronics Lab, Computer Lab, Communication Lab (ICT/IT)" },
      { name: "Science & General (3 labs)",          detail: "Physics Lab, Chemistry Lab, and Language Lab (76.56 sqm, 20 PCs, standalone)" },
      { name: "Workshop (1)",                        detail: "Central workshop of 1,478 sqm — woodworking, welding, fitting, smithy, and manufacturing processes" },
    ],
  },
  {
    title: "Library & Learning Resources",
    icon: "M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z",
    items: [
      { name: "Central Library",           detail: "22,828 volumes across 4,152 titles — engineering, science, technology, humanities & competitive exams; total cost Rs. 27.4 lakh" },
      { name: "Reading Room (336 sqm)",    detail: "150-seat reading room open 10:30 AM – 6:10 PM; 10 multimedia PCs; NDLI member (INGJNCR47D4WSDV)" },
      { name: "Journals & e-Resources",   detail: "7 subscribed journals incl. Inventi Impact series (Civil, Electrical, Mechanical, EC, AI, VLSI) + Electronics for You; 619 e-Books (Diploma)" },
      { name: "Digital & NPTEL Access",   detail: "NPTEL/SWAYAM video lectures; photocopying facility; computerised library operations; internet access for all users" },
    ],
  },
  {
    title: "Computer Facilities",
    icon: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    items: [
      { name: "Student Computer Labs (3)",  detail: "233 PCs exclusively for students across 3 computer centres (total 226.71 sqm); 200 Mbps internet; 4:1 contention ratio" },
      { name: "Language Lab",              detail: "Standalone language lab: 20 PCs; 76.56 sqm; air-conditioned; communication skills development" },
      { name: "Library & Admin PCs",       detail: "10 PCs in library for student digital access; 20 PCs in administrative office; 40 PCs for faculty members; 5 student printers" },
      { name: "Software (14 titles)",       detail: "AutoCAD, CREO Parametric 2018, Revit 2018, STAAD Pro, Scilab, Logisim, Tinkercad, PyCharm, Jupyter, Open Office, 8085GNUSIM, ExpressPCB, Safe, WPL — all open source" },
    ],
  },
  {
    title: "Sports & Recreation",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    items: [
      { name: "Sports Ground (13,950 sqm)", detail: "Full-size multi-sport ground for cricket, athletics, kabaddi, volleyball, and other outdoor sports" },
      { name: "Volleyball Court",           detail: "Outdoor volleyball court for inter-department and recreational use" },
      { name: "Badminton Court",            detail: "Indoor badminton facilities for students and staff" },
      { name: "Common Rooms (2)",           detail: "2 common rooms (166 sqm total) including Girls' Common Room for relaxation and informal gatherings" },
    ],
  },
  {
    title: "Student Welfare",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    items: [
      { name: "Boys Hostel (3 blocks)",   detail: "3 hostel blocks covering 7,256 sqm; 264 sanctioned seats; 24-hr water, electricity, security, warden; gym/sports room" },
      { name: "Girls Hostel",             detail: "Girls hostel of 1,055 sqm; 48 sanctioned seats; residential warden; fire safety measures; medical first aid on-site" },
      { name: "Canteen (352 sqm)",        detail: "Campus canteen with nutritious food at subsidised rates; hygienic kitchen; seating for students and staff" },
      { name: "Other Amenities",          detail: "18 toilet blocks (548 sqm); staff quarters; compound wall; RO/potable water; public address system; medical & counselling facility" },
    ],
  },
  {
    title: "Power, Safety & Connectivity",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
    items: [
      { name: "100 KW Solar Plant",         detail: "Rooftop PV plant generating 91,458 units in 2024-25; ~73 tonnes CO₂ avoided annually; green campus initiative" },
      { name: "Generator Backup (10 kVA)",  detail: "Diesel generator backup for uninterrupted power to labs, classrooms, and critical areas" },
      { name: "Internet (200 Mbps)",        detail: "200 Mbps dedicated broadband; 4:1 contention ratio; campus-wide Wi-Fi across academic and hostel blocks" },
      { name: "CCTV & Security",            detail: "CCTV surveillance across classrooms, store rooms, exam control room, library, and entry points; biometric attendance for staff" },
    ],
  },
];
---

<Layout title="Infrastructure | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Infrastructure</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Infrastructure</h1>
      <p class="text-lg text-gray-600">Modern, well-equipped campus facilities designed to support quality technical education at GPP Palanpur.</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl font-bold text-white">5</div>
          <div class="text-sm text-white/80 mt-1">Academic Buildings</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">38</div>
          <div class="text-sm text-white/80 mt-1">Laboratories</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">22,462 sqm</div>
          <div class="text-sm text-white/80 mt-1">Built-up Area</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white">20.36 acres</div>
          <div class="text-sm text-white/80 mt-1">Campus Area</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Buildings Table -->
  <section class="py-10 bg-white border-b border-gray-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Campus Buildings</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-primary/10">
            <tr>
              <th class="px-5 py-3 text-left font-semibold text-primary">#</th>
              <th class="px-5 py-3 text-left font-semibold text-primary">Building</th>
              <th class="px-5 py-3 text-left font-semibold text-primary">Built-up Area</th>
              <th class="px-5 py-3 text-left font-semibold text-primary">Primary Use</th>
            </tr>
          </thead>
          <tbody>
            {buildings.map((b, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 text-gray-400 font-medium">{i + 1}</td>
                <td class="px-5 py-3 font-semibold text-gray-900">{b.name}</td>
                <td class="px-5 py-3 text-gray-700 whitespace-nowrap">{b.area}</td>
                <td class="px-5 py-3 text-gray-600">{b.use}</td>
              </tr>
            ))}
            <tr class="bg-primary/5 border-t-2 border-primary/20">
              <td class="px-5 py-3"></td>
              <td class="px-5 py-3 font-bold text-gray-900">Total</td>
              <td class="px-5 py-3 font-bold text-gray-900">22,462 sqm</td>
              <td class="px-5 py-3 text-gray-500 text-xs">Total built-up area (Government land, 20.36 acres)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Infrastructure Sections -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="space-y-12">
        {sections.map(s => (
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-gray-900">{s.title}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {s.items.map(item => (
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 hover:border-primary/30 transition-colors">
                  <h3 class="font-bold text-gray-900 mb-2 text-sm">{item.name}</h3>
                  <p class="text-gray-600 text-xs">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Explore More</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="/library" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Library</div>
        </a>
        <a href="/campus-life/sports" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Sports</div>
        </a>
        <a href="/about/bee-robokids-lab" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">Robotics Lab</div>
        </a>
        <a href="/facilities" class="bg-white rounded-xl p-4 border border-gray-100 text-center hover:border-primary/40 hover:shadow-sm transition-all">
          <div class="text-primary font-semibold text-sm">All Facilities</div>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
