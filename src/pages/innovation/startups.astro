---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const startups = [
  { name: "TechFarm Solutions", founder: "CE Batch 2022", domain: "AgriTech / IoT", status: "Active", year: "2023" },
  { name: "SolarKraft", founder: "EE Batch 2021", domain: "Renewable Energy", status: "Active", year: "2022" },
  { name: "BuildSmart", founder: "CE Batch 2023", domain: "Construction Tech", status: "Pre-revenue", year: "2024" },
  { name: "CodeNest", founder: "CO Batch 2022", domain: "SaaS / EdTech", status: "Active", year: "2023" },
];

const services = [
  { icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3", title: "Seed Funding", desc: "SSIP provides up to ₹2 lakh seed funding for student-led projects with innovation potential." },
  { icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5", title: "Infrastructure Support", desc: "Access to Design Lab, prototyping tools, and computing resources in the Innovation Cell." },
  { icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", title: "Mentorship", desc: "Expert mentors from industry and academia guide students from concept to MVP." },
  { icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", title: "Market Connect", desc: "Linkages with GIDC industries and startup ecosystems in Banaskantha and North Gujarat." },
  { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", title: "IPR Assistance", desc: "Support for patent filing through the Innovation Cell — learn more under Patents." },
  { icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z", title: "Startup Events", desc: "Pitch competitions, demo days, and startup bootcamps conducted at and beyond campus." },
];
---

<Layout title="Startups & Incubation | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/innovation" class="hover:text-primary transition-colors">Innovation Cell</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Startups</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Innovation Cell</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Startups at GPP</h1>
      <p class="text-lg text-gray-600 max-w-2xl">GPP's SSIP-backed ecosystem nurtures student and alumni entrepreneurs through funding, mentorship, infrastructure, and market linkages.</p>
    </div>
  </section>

  <!-- Ecosystem -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Startup Support Ecosystem</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Alumni Startups -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">GPP-Born Startups</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {startups.map(s => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm flex gap-5">
            <div class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
              {s.name.charAt(0)}
            </div>
            <div>
              <h3 class="font-bold text-gray-900">{s.name}</h3>
              <div class="text-sm text-gray-500 mb-2">{s.domain} · Est. {s.year}</div>
              <div class="flex gap-2">
                <span class="text-xs bg-primary/10 text-primary rounded-full px-2 py-0.5">{s.founder}</span>
                <span class={`text-xs rounded-full px-2 py-0.5 ${s.status === 'Active' ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800'}`}>{s.status}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Have a Startup Idea?</h2>
      <p class="text-gray-600 mb-6">Register your idea with the GPP Innovation Cell and access SSIP funding, design lab, and expert mentorship to turn it into reality.</p>
      <a href="/ssip" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Apply via SSIP</a>
    </div>
  </section>

  <Footer />
</Layout>
