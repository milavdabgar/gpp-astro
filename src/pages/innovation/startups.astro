---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const startups = [
  {
    name: "Prahantam Pvt. Ltd.",
    founder: "Dhaval Nai",
    domain: "Manufacturing",
    status: "Active",
    desc: "Ahmedabad-based manufacturer of automated tea cup washing machines for hygiene-conscious tea vendors and hospitality businesses."
  },
  {
    name: "Zephyr Digisteth",
    founder: "Dr. Vipul Tank",
    domain: "Healthcare & MedTech",
    status: "Active",
    desc: "Compact AI-powered medical device integrating auscultation, ECG, temperature and blood sugar monitoring with modular attachments. Supports tele-consultations and remote care."
  },
  {
    name: "BeeRobokids Innovations Pvt. Ltd.",
    founder: "Rishabh Prajapati",
    domain: "STEM Education",
    status: "Active",
    desc: "Empowering kids and young innovators through hands-on Robotics, IoT, and emerging technology learning kits. Nurtures creativity and problem-solving for the next generation."
  },
  {
    name: "Innovate 3D",
    founder: "Deepak Chaudhary",
    domain: "Tech / Manufacturing",
    status: "Active",
    desc: "Advancing 3D design, printing and rapid prototyping. Develops cost-effective 3D printers, STEM education kits, and offers prototyping support for startups and industries."
  },
  {
    name: "Sky Print Startup",
    founder: "Yuvraj Rajput",
    domain: "Drone Technology",
    status: "Active",
    desc: "Custom drone solutions for diverse industries — FPV, surveillance, flower-dropping event drones. Offers drone services, training, and ready-to-fly models."
  },
  {
    name: "Sky Craft",
    founder: "Bharat Mali",
    domain: "STEM Education",
    status: "Active",
    desc: "Low-cost robotics and IoT kits making future technologies accessible. Activity-based learning modules for rural schools along with teacher training programs."
  },
];

const services = [
  { icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3", title: "POC Funding", desc: "SSIP cell has funded 32 POC projects (2022–2026) totalling ₹4.80 lakh, supporting student-led proof-of-concept innovations." },
  { icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5", title: "Infrastructure Support", desc: "Access to the SSIP facility equipped with modern instruments, computers, and internet connectivity for prototype development." },
  { icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", title: "Mentorship", desc: "Expert mentors from industry and academia guide students from concept to MVP under the coordination of the SSIP faculty team." },
  { icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", title: "Startup Conclave Access", desc: "Students participate in state-level events like Startup Conclave Gandhinagar, gaining exposure to the broader Gujarat startup ecosystem." },
  { icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", title: "IPR Assistance", desc: "SSIP has supported 4 patent filings (2 granted, 2 under examination), funding IPR costs through the Innovation Cell." },
  { icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z", title: "Startup Events", desc: "41+ events organised since 2022 — bootcamps, sensitization programs, New Palanpur for New India, and Startup Conclave participation." },
];
---

<Layout title="Startups & Incubation | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/innovation" class="hover:text-primary transition-colors">Innovation Cell</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Startups</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Innovation Cell</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Startups at GPP</h1>
      <p class="text-lg text-gray-600 max-w-2xl">GPP's SSIP-backed ecosystem nurtures student and alumni entrepreneurs through funding, mentorship, infrastructure, and market linkages.</p>
    </div>
  </section>

  <!-- Ecosystem -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Startup Support Ecosystem</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GPP-Supported Startups -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-2">GPP-Supported Startups</h2>
      <p class="text-gray-500 mb-8">SSIP-incubated student and alumni ventures (as of 2025–26)</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {startups.map(s => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="flex items-start gap-4 mb-3">
              <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-lg flex-shrink-0">
                {s.name.charAt(0)}
              </div>
              <div>
                <h3 class="font-bold text-gray-900">{s.name}</h3>
                <div class="flex flex-wrap gap-2 mt-1">
                  <span class="text-xs bg-primary/10 text-primary rounded-full px-2 py-0.5">{s.domain}</span>
                  <span class="text-xs bg-green-100 text-green-800 rounded-full px-2 py-0.5">{s.status}</span>
                </div>
              </div>
            </div>
            <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
            <p class="text-xs text-gray-400 mt-2">Founder: {s.founder}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Have a Startup Idea?</h2>
      <p class="text-gray-600 mb-6">Register your idea with the GPP Innovation Cell and access SSIP funding, design lab, and expert mentorship to turn it into reality.</p>
      <a href="/ssip" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Apply via SSIP</a>
    </div>
  </section>

  <Footer />
</Layout>
