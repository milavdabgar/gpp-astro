---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const incubatees = [
  { name: "AgroBotix", sector: "AgriTech", stage: "Prototype", year: "2024", team: "CE + EC students" },
  { name: "EcoKraft", sector: "Sustainability", stage: "MVP", year: "2023", team: "ME students" },
  { name: "SmartPave", sector: "Civil Tech", stage: "Ideation", year: "2025", team: "Civil faculty + students" },
];

const facilities = [
  { icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", title: "Dedicated Workspaces", desc: "Hot-desks and dedicated seating for incubated teams to work on their ventures." },
  { icon: "M13 10V3L4 14h7v7l9-11h-7z", title: "Design Lab Access", desc: "Priority access to 3D printers, laser cutters, and electronics workbenches." },
  { icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", title: "Expert Network", desc: "Access to a network of industry experts, investors, and startup mentors." },
  { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", title: "Legal & IPR Support", desc: "Guidance on company registration, IP protection, and legal compliance." },
  { icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z", title: "Seed Funding", desc: "SSIP seed funding up to ₹2 lakh for selected incubated projects." },
  { icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", title: "Industry Connect", desc: "Introductions to GIDC companies, MSMEs, and corporates for pilots and funding." },
];

const applySteps = [
  "Prepare a 1-page idea summary (problem, solution, market, team)",
  "Submit to the SSIP/Innovation Cell coordinator at GPP",
  "Present your idea to the selection panel (monthly review)",
  "Selected teams receive workspace and initial mentoring",
  "Apply for SSIP seed funding with mentor support",
];
---

<Layout title="Incubation Centre | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <a href="/innovation" class="hover:text-primary transition-colors">Innovation Cell</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Incubation</span>
      </nav>
    </div>
  </div>

  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="inline-block bg-primary/10 text-primary text-sm font-semibold px-4 py-1 rounded-full mb-4">Innovation Cell</div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Incubation Centre</h1>
      <p class="text-lg text-gray-600 max-w-2xl">GPP's pre-incubation support for early-stage student and faculty innovations under the SSIP framework.</p>
    </div>
  </section>

  <!-- Facilities -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What We Offer</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {facilities.map(f => (
          <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon}/>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{f.title}</h3>
            <p class="text-gray-600 text-sm">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Current Incubatees -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Current Incubatees</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {incubatees.map(i => (
          <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
            <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center text-white font-bold text-xl mb-4">{i.name.charAt(0)}</div>
            <h3 class="font-bold text-gray-900">{i.name}</h3>
            <div class="text-sm text-gray-500 mb-3">{i.sector} · Est. {i.year}</div>
            <div class="flex gap-2 flex-wrap">
              <span class="text-xs bg-primary/10 text-primary rounded-full px-2 py-0.5">{i.stage}</span>
              <span class="text-xs bg-gray-100 text-gray-600 rounded-full px-2 py-0.5">{i.team}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How to Apply -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">How to Join the Incubation Programme</h2>
      <div class="space-y-3">
        {applySteps.map((s, i) => (
          <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
            <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0">{i + 1}</div>
            <p class="text-gray-700 text-sm pt-1">{s}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Apply for Incubation Support</h2>
      <p class="text-gray-600 mb-6">Have a startup idea? Submit your application to the GPP Innovation Cell today and get the support you need to build your venture.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/ssip" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">SSIP at GPP</a>
        <a href="/contact" class="border border-primary text-primary px-6 py-3 rounded-lg font-semibold hover:bg-primary/5 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
