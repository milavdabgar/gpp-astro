---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const objectives = [
  { title: "Promote Innovation",    desc: "Foster a culture of creativity and innovative thinking among students and faculty",           color: "blue",   icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
  { title: "Support Prototyping",   desc: "Provide resources, labs, and guidance to develop working prototypes from ideas",              color: "green",  icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
  { title: "Enable Startups",       desc: "Support student entrepreneurs in launching and scaling their technology startups",             color: "purple", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { title: "Foster Collaboration",  desc: "Build partnerships with industry, government, and academic institutions",                     color: "orange", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" },
  { title: "Develop IP Assets",     desc: "Guide students and faculty through patent filing, copyright, and IP protection processes",    color: "red",    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" },
  { title: "Provide Incubation",    desc: "Offer incubation support with funding, mentoring, and infrastructure for growth-stage ideas", color: "indigo", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
];

const borderMap: Record<string, string> = {
  blue: "border-t-blue-500", green: "border-t-green-500", purple: "border-t-purple-500",
  orange: "border-t-orange-500", red: "border-t-red-500", indigo: "border-t-indigo-500",
};
const iconBgMap: Record<string, string> = {
  blue: "bg-blue-50 text-blue-600", green: "bg-green-50 text-green-600", purple: "bg-purple-50 text-purple-600",
  orange: "bg-orange-50 text-orange-600", red: "bg-red-50 text-red-600", indigo: "bg-indigo-50 text-indigo-600",
};

const patents = [
  { sr: 1, innovation: "Switchboard",                   mentor: "Prof. B.M. Patel (EE Faculty) and team", appNo: "202021026651" },
  { sr: 2, innovation: "Smart Rotary Switchboard",      mentor: "Prof. B.M. Patel (EE Faculty) and team", appNo: "202021044176" },
  { sr: 3, innovation: "Water TAP Alarm",               mentor: "Prof. D.D. Panchal (ME Faculty) and team", appNo: "202121004092" },
  { sr: 4, innovation: "Cup and Glass Cleaning Device", mentor: "Prof. B.M. Patel (EE Faculty) and team", appNo: "202121049081" },
];

const processSteps = [
  { title: "Idea Submission",     desc: "Submit innovative ideas through our portal",         color: "blue",   icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
  { title: "Concept Development", desc: "Refine ideas with mentor guidance",                  color: "green",  icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
  { title: "Prototype Building",  desc: "Technical development support",                      color: "purple", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { title: "Validation & IP",     desc: "Market validation and patent filing",                color: "orange", icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" },
  { title: "Incubation",          desc: "Business model development and scaling",             color: "red",    icon: "M18 3a1 1 0 00-1.447-.894L4 9H3a1 1 0 00-1 1v4a1 1 0 001 1h.13l-.13.694A1 1 0 004 17h1a2 2 0 104 0h6a2 2 0 104 0h1a1 1 0 00.92-1.392l-1.084-2.748A2 2 0 0021 11V9a1 1 0 00-.553-.894L18 7.382V3z" },
];
---

<Layout title="Innovation & SSIP | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero — special blue-to-purple gradient -->
  <section class="bg-gradient-to-br from-blue-600 to-purple-700 text-white py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-4xl">
      <div class="flex justify-center gap-2 mb-6">
        <span class="text-xs font-semibold bg-white/20 text-white rounded-full px-3 py-1">SSIP Cell</span>
        <span class="text-xs font-semibold border border-white/30 text-white rounded-full px-3 py-1">Innovation Hub</span>
        <span class="text-xs font-semibold border border-white/30 text-white rounded-full px-3 py-1">Patent Support</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Student Startup &amp;<br/>Innovation Policy</h1>
      <p class="text-xl text-blue-100 mb-8">Empowering students to transform innovative ideas into real-world solutions through the SSIP cell at Government Polytechnic Palanpur.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center"><div class="text-3xl font-bold text-white">8000+</div><div class="text-sm text-blue-200">Students Engaged</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-white">4</div><div class="text-sm text-blue-200">Patents Filed</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-white">POC</div><div class="text-sm text-blue-200">Projects Supported</div></div>
        <div class="text-center"><div class="text-3xl font-bold text-white">1</div><div class="text-sm text-blue-200">Growth-stage Startup</div></div>
      </div>
    </div>
  </section>

  <!-- Vision -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Innovation Vision</h2>
          <p class="text-gray-600 leading-relaxed mb-4">The SSIP Cell at Government Polytechnic Palanpur is dedicated to cultivating an entrepreneurial mindset among students. We provide a complete ecosystem for ideation, prototyping, mentorship, and incubation.</p>
          <p class="text-gray-600 leading-relaxed">With support from the Government of Gujarat's Student Startup &amp; Innovation Policy, we have helped students file patents, build prototypes, and launch startups that solve real-world problems.</p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-blue-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-blue-600">8000+</div>
            <div class="text-sm text-gray-600 mt-1">Students Engaged</div>
          </div>
          <div class="bg-purple-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-purple-600">4</div>
            <div class="text-sm text-gray-600 mt-1">Patents Published</div>
          </div>
          <div class="bg-green-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-green-600">Multiple</div>
            <div class="text-sm text-gray-600 mt-1">POC Projects</div>
          </div>
          <div class="bg-orange-50 rounded-xl p-6 text-center">
            <div class="text-3xl font-bold text-orange-600">1</div>
            <div class="text-sm text-gray-600 mt-1">Funded Startup</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Objectives -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Key Objectives</h2>
        <p class="text-gray-600 max-w-xl mx-auto">Our structured approach to building an innovation ecosystem</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {objectives.map(obj => (
          <div class={`bg-white rounded-xl p-6 border-t-4 ${borderMap[obj.color]} shadow-sm hover:shadow-md transition-shadow`}>
            <div class={`w-12 h-12 ${iconBgMap[obj.color]} rounded-xl flex items-center justify-center mb-4`}>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={obj.icon}/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-2">{obj.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{obj.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Success Stories -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Success Stories</h2>
        <p class="text-gray-600">Innovations that made a difference and created real-world impact</p>
      </div>
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-xl font-bold text-green-600">Rover Making Project</h3>
            <span class="text-xs font-semibold bg-green-100 text-green-700 rounded-full px-3 py-1 shrink-0 ml-3">₹50,000 Prize</span>
          </div>
          <p class="text-sm text-gray-500 mb-3">Team Leader: Seliya Abrar (Electrical Engineering) &nbsp;·&nbsp; Mentor: Prof. B.M. Patel</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">Developed a multi-purpose rover with advanced sensing capabilities for agricultural and surveillance applications. This innovative project showcased cutting-edge engineering solutions.</p>
          <div class="flex items-center gap-2 text-sm font-medium text-yellow-600">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Won State Competition
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-xl font-bold text-blue-600">Smart Rotary Switchboard</h3>
            <span class="text-xs font-semibold bg-blue-100 text-blue-700 rounded-full px-3 py-1 shrink-0 ml-3">Patent Filed</span>
          </div>
          <p class="text-sm text-gray-500 mb-3">Team: Electrical Engineering Students &nbsp;·&nbsp; Mentor: Prof. B.M. Patel</p>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">Created an energy-efficient switchboard with enhanced safety features. Patent Application Number: 202021044176</p>
          <div class="flex items-center gap-2 text-sm font-medium text-blue-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Patent Published
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Patents Table -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Patents Published</h2>
        <p class="text-gray-600">Our SSIP cell has successfully supported the publication of multiple patents</p>
      </div>
      <div class="bg-white rounded-xl shadow overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sr. No.</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Innovation</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Faculty Mentor &amp; Team</th>
                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Patent Application No.</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {patents.map(p => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{p.sr}</td>
                  <td class="px-6 py-4 text-sm text-gray-900 font-medium">{p.innovation}</td>
                  <td class="px-6 py-4 text-sm text-gray-600">{p.mentor}</td>
                  <td class="px-6 py-4 text-sm font-mono text-gray-900">{p.appNo}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- SSIP Process Flow -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">SSIP Process Flow</h2>
        <p class="text-gray-600">From idea to implementation — our structured approach to innovation</p>
      </div>
      <div class="grid md:grid-cols-5 gap-6">
        {processSteps.map((step, i) => (
          <div class="text-center relative">
            {i < processSteps.length - 1 && (
              <div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-gray-200 z-0"></div>
            )}
            <div class={`relative z-10 w-16 h-16 ${iconBgMap[step.color]} rounded-full flex items-center justify-center mx-auto mb-4`}>
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon}/></svg>
            </div>
            <h3 class="font-semibold text-gray-900 mb-1 text-sm">{step.title}</h3>
            <p class="text-xs text-gray-500">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Student Testimonials</h2>
        <p class="text-gray-600">Hear from our student innovators about their SSIP journey</p>
      </div>
      <div class="grid lg:grid-cols-3 gap-8">
        {[
          { quote: "SSIP provided me the platform, resources, and guidance to transform my idea into a patented invention. The mentorship from faculty was invaluable.", name: "Seliya Abrar", dept: "Electrical Engineering", border: "border-l-blue-500" },
          { quote: "The design thinking workshops and regular feedback sessions helped refine our concept. SSIP's support in securing funding was crucial for building our prototype.", name: "ME Student Team", dept: "Mechanical Engineering", border: "border-l-green-500" },
          { quote: "Beyond technical support, SSIP helped us understand the business side of innovation. The entrepreneurship workshops prepared us for market viability.", name: "ECE Student", dept: "Electronics & Communication", border: "border-l-purple-500" },
        ].map(t => (
          <div class={`bg-white rounded-xl p-6 border-l-4 ${t.border} shadow-sm`}>
            <div class="flex gap-0.5 mb-4">
              {Array(5).fill(0).map(() => (
                <svg class="w-4 h-4 text-yellow-400 fill-yellow-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm italic mb-4">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div>
                <div class="font-semibold text-gray-900 text-sm">{t.name}</div>
                <div class="text-xs text-gray-500">{t.dept}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact SSIP -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Contact SSIP Cell</h2>
        <p class="text-gray-600">Ready to transform your idea into reality? Get in touch with us!</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Get in Touch
          </h3>
          <div class="space-y-3 text-sm text-gray-600">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href="mailto:ssip@gppalanpur.ac.in" class="hover:text-primary transition-colors">ssip@gppalanpur.ac.in</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href="tel:02742262115" class="hover:text-primary transition-colors">02742-262115</a>
            </div>
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-gray-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              SSIP Cell, Ground Floor, Administrative Block
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Monday to Friday, 10:00 AM to 4:00 PM
            </div>
          </div>
        </div>
        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-900 mb-3">Join the Innovation Movement</h3>
