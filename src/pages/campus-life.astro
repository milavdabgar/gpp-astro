---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const highlights = [
  {
    title: "Sports & Athletics",
    desc: "Dedicated cricket grounds, volleyball, kabaddi, and indoor sports facilities for physical well-being.",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    color: "blue",
    link: "/sports",
  },
  {
    title: "NSS & Social Service",
    desc: "National Service Scheme unit actively participates in community service, blood donation drives, and social awareness campaigns.",
    icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    color: "red",
    link: "/student-section/nss",
  },
  {
    title: "Cultural Activities",
    desc: "Annual cultural festival, technical fests, inter-college competitions and celebrations of national events.",
    icon: "M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3",
    color: "purple",
    link: "/events",
  },
  {
    title: "SSIP & Innovation",
    desc: "Student Startup and Innovation Policy cell supports student entrepreneurs with funding, mentorship, and prototype development.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    color: "orange",
    link: "/ssip",
  },
  {
    title: "Library & Reading",
    desc: "18,000+ books, e-journals, and digital resources in a well-equipped library, open to all students.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
    color: "teal",
    link: "/library",
  },
  {
    title: "Training & Placement",
    desc: "Dedicated TPO cell with career counseling, campus drives, mock interviews, and industry interaction programs.",
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    color: "green",
    link: "/tpo",
  },
];

const facilities = [
  { name: "20.36 Acre Campus", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5" },
  { name: "5 Academic Buildings", icon: "M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" },
  { name: "25+ Labs", icon: "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18" },
  { name: "200 Mbps Internet", icon: "M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0" },
  { name: "Solar Power Plant", icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" },
  { name: "Girls Hostel", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { name: "18,180 Library Books", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
  { name: "Canteen", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
];

const colorBg: Record<string, string> = {
  blue: "bg-blue-50 text-blue-600 border-blue-200",
  red: "bg-red-50 text-red-600 border-red-200",
  purple: "bg-purple-50 text-purple-600 border-purple-200",
  orange: "bg-orange-50 text-orange-600 border-orange-200",
  teal: "bg-teal-50 text-teal-600 border-teal-200",
  green: "bg-green-50 text-green-600 border-green-200",
};
---

<Layout title="Campus Life | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto">
        <div class="flex justify-center gap-2 mb-6">
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200">20-Acre Campus</span>
          <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border border-gray-200 text-gray-700">Est. 1984</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Life at GP Palanpur</h1>
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">
          Experience a vibrant campus life that goes beyond academics. With sports, cultural activities,
          innovation initiatives, and a supportive community, GPP offers a holistic education experience.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">330+</div>
            <div class="text-sm text-gray-500">Students/Year</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">20.36</div>
            <div class="text-sm text-gray-500">Acre Campus</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">64</div>
            <div class="text-sm text-gray-500">Faculty Members</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-primary">42+</div>
            <div class="text-sm text-gray-500">Years of Legacy</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Campus Highlights -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Campus Highlights</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Discover the diverse opportunities that make campus life at GPP enriching and fulfilling.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {highlights.map((item) => (
          <a href={item.link} class={`group p-6 rounded-xl border ${colorBg[item.color]} hover:shadow-md transition-all duration-200`}>
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-white/70 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-2 group-hover:underline">{item.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Campus Facilities -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Campus Infrastructure</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          State-of-the-art facilities to support academic and extracurricular growth.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {facilities.map((f) => (
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center hover:shadow-sm transition-shadow">
            <div class="inline-flex p-2 rounded-lg bg-primary/10 mb-3">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon}/>
              </svg>
            </div>
            <div class="text-sm font-medium text-gray-700">{f.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Campus Location -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Campus Location</h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Government Polytechnic Palanpur is located outside Malan Gate on Ambaji Road, Palanpur,
            easily accessible from all parts of Banaskantha district. The 20.36-acre campus comprises
            5 major academic buildings, well-equipped workshops, and ample open spaces.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            The campus features a dedicated girls' hostel, playground, canteen, and green surrounding
            making it a pleasant and productive learning environment.
          </p>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span class="text-gray-700">Outside Malan Gate, Ambaji Road, Palanpur-385001, Banaskantha, Gujarat</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <span class="text-gray-700">02742-262115 | 9099063226</span>
            </div>
          </div>
          <div class="mt-6">
            <a
              href="https://maps.app.goo.gl/palanpur-gpp"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              View on Google Maps
            </a>
          </div>
        </div>
        <div class="bg-gray-100 rounded-2xl h-80 flex items-center justify-center">
          <div class="text-center text-gray-400">
            <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <p class="text-sm font-medium">GP Palanpur, Ambaji Road</p>
            <p class="text-xs">Palanpur, Banaskantha, Gujarat</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
