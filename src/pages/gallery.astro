---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';
import labGallery from '../data/lab-gallery.json';

const deptLabels: Record<string, string> = {
  "civil-applied-mechanics": "Civil Engineering",
  "ec": "Electronics & Communication",
  "electrical": "Electrical Engineering",
  "mechanical": "Mechanical Engineering",
  "science-humanities": "Science & Humanities",
};

// Flatten labs per dept into gallery entries
const labEntries = Object.entries(labGallery).flatMap(([dept, labs]) =>
  (labs as { name: string; image: string; description: string }[]).map(lab => ({
    dept,
    deptLabel: deptLabels[dept] ?? dept,
    name: lab.name,
    image: lab.image,
    description: lab.description,
  }))
);

const depts = ["all", ...Object.keys(labGallery)];
---

<Layout title="Gallery | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span class="text-gray-900 font-medium">Gallery</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-2xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Photo Gallery</h1>
      <p class="text-gray-600 text-lg">A visual tour of our laboratories, campus, and facilities</p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="bg-white border-b border-gray-200 sticky top-0 z-30">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-1 overflow-x-auto py-3 scrollbar-hide" id="gallery-tabs">
        <button
          onclick="filterGallery('all')"
          data-filter="all"
          class="gallery-tab flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-primary text-white"
        >All Labs</button>
        {Object.entries(deptLabels).map(([key, label]) => (
          <button
            onclick={`filterGallery('${key}')`}
            data-filter={key}
            class="gallery-tab flex-shrink-0 px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-gray-100 text-gray-700 hover:bg-gray-200"
          >{label}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-10 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4" id="gallery-grid">
        {labEntries.map(entry => (
          <div
            class="gallery-item break-inside-avoid rounded-xl overflow-hidden border border-gray-200 shadow-sm hover:shadow-md transition-shadow cursor-pointer group"
            data-dept={entry.dept}
            onclick={`openLightbox('${entry.image.replace(/'/g, "\\'")}', '${entry.name.replace(/'/g, "\\'")}', '${entry.deptLabel.replace(/'/g, "\\'")}', '${entry.description.replace(/'/g, "\\'")}')`}
          >
            <div class="overflow-hidden">
              <img
                src={entry.image}
                alt={entry.name}
                class="w-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                onerror="this.parentElement.parentElement.style.display='none'"
              />
            </div>
            <div class="p-3">
              <p class="text-xs font-semibold text-gray-900">{entry.name}</p>
              <p class="text-xs text-primary mt-0.5">{entry.deptLabel}</p>
            </div>
          </div>
        ))}
      </div>
      <!-- Empty state -->
      <div id="gallery-empty" class="hidden text-center py-16 text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-sm">No images found for this department.</p>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black/80 z-50 hidden items-center justify-center p-4 backdrop-blur-sm" onclick="closeLightbox(event)">
    <div class="relative max-w-3xl w-full bg-white rounded-2xl overflow-hidden shadow-2xl" onclick="event.stopPropagation()">
      <button onclick="closeLightbox()" class="absolute top-3 right-3 z-10 w-8 h-8 bg-black/50 text-white rounded-full flex items-center justify-center hover:bg-black/70">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <img id="lb-img" src="" alt="" class="w-full max-h-[60vh] object-contain bg-gray-900" />
      <div class="p-5">
        <p id="lb-title" class="font-bold text-gray-900 text-lg"></p>
        <p id="lb-dept" class="text-primary text-sm font-medium mt-0.5"></p>
        <p id="lb-desc" class="text-gray-600 text-sm mt-1"></p>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline>
function filterGallery(filter) {
  const items = document.querySelectorAll('.gallery-item');
  const tabs = document.querySelectorAll('.gallery-tab');
  let visible = 0;
  items.forEach(item => {
    const show = filter === 'all' || item.dataset.dept === filter;
    item.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  tabs.forEach(tab => {
    tab.classList.toggle('bg-primary', tab.dataset.filter === filter);
    tab.classList.toggle('text-white', tab.dataset.filter === filter);
    tab.classList.toggle('bg-gray-100', tab.dataset.filter !== filter);
    tab.classList.toggle('text-gray-700', tab.dataset.filter !== filter);
  });
  document.getElementById('gallery-empty').classList.toggle('hidden', visible > 0);
}

function openLightbox(src, title, dept, desc) {
  document.getElementById('lb-img').src = src;
  document.getElementById('lb-img').alt = title;
  document.getElementById('lb-title').textContent = title;
  document.getElementById('lb-dept').textContent = dept;
  document.getElementById('lb-desc').textContent = desc;
  const lb = document.getElementById('lightbox');
  lb.classList.remove('hidden');
  lb.classList.add('flex');
}

function closeLightbox(e) {
  const lb = document.getElementById('lightbox');
  lb.classList.add('hidden');
  lb.classList.remove('flex');
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
