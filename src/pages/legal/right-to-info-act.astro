---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';

const pioInfo = {
  name: "Shri Sureshkumar D. Dabhi",
  designation: "Principal (In-charge)",
  institution: "Government Polytechnic Palanpur",
  address: "Outside Malan Gate, Ambaji Road, Palanpur-385001, Banaskantha, Gujarat",
  phone: "02742-262115",
  mobile: "9099063226",
  email: "gp-palanpur-dte@gujarat.gov.in",
};

const appellateInfo = {
  body: "Commissioner of Technical Education, Gujarat",
  address: "Commissionerate of Technical Education, Block No. 1, Dr. Jivraj Mehta Bhawan, Gandhinagar-382010, Gujarat",
  website: "https://gtu.ac.in/",
};

const rtiFees = [
  { method: "Application Fee", amount: "₹10/-", mode: "Indian Postal Order / DD / Court Fee Stamp" },
  { method: "SC/ST/BPL", amount: "Exempt", mode: "Submit relevant certificate along with application" },
  { method: "Additional pages (A4)", amount: "₹2/- per page", mode: "For physical documents" },
  { method: "Larger size copies", amount: "Actual cost", mode: "As determined by PIO" },
  { method: "CD/Floppy/DVD", amount: "₹50 per disc", mode: "For electronic documents" },
  { method: "Inspection fee", amount: "No charge (first hour)", mode: "₹5/- per 15 min thereafter" },
];

const rtiSections = [
  { sec: "Sec. 4", title: "Proactive Disclosure", desc: "Institutions are required to proactively disclose information about their organization, functions, duties, rules, regulations, and records." },
  { sec: "Sec. 6", title: "Filing Application", desc: "Any citizen can file an RTI application in writing or electronically, with the prescribed fee, to the first appellate authority or the PIO." },
  { sec: "Sec. 7", title: "30-Day Deadline", desc: "The PIO must provide information within 30 days. If information concerns life/liberty, it must be provided within 48 hours." },
  { sec: "Sec. 8", title: "Exemptions", desc: "Certain categories of information are exempt from disclosure, including information affecting national security, commercial confidence, or personal privacy." },
  { sec: "Sec. 19", title: "Appeal Process", desc: "If unsatisfied with the response, applicant can appeal to the First Appellate Authority within 30 days, and then to the State Information Commission." },
];

const disclosureItems = [
  "Organization structure and functions",
  "Powers and duties of employees",
  "Procedure for decision making",
  "Norms for functioning and policies",
  "Rules and regulations followed",
  "Statements of categories of documents",
  "Consultative arrangements with the public",
  "Details of boards, councils, committees",
  "Directory of employees and contact details",
  "Monthly remuneration of employees",
  "Budget and annual accounts",
  "Subsidy programs and beneficiaries",
  "Concession, licenses, permits granted",
  "Information in electronic form",
];
---

<Layout title="Right to Information Act | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 border border-blue-200">
        RTI Act, 2005
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Right to Information Act</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        The Right to Information Act, 2005 empowers citizens to request information from public authorities.
        Government Polytechnic Palanpur is committed to transparency and timely disclosure.
      </p>
    </div>
  </section>

  <!-- PIO Details -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-blue-50 rounded-2xl border border-blue-200 p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 rounded-xl bg-primary/10">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <h2 class="text-xl font-bold text-gray-900">Public Information Officer (PIO)</h2>
          </div>
          <dl class="space-y-4">
            <div class="pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Name</dt>
              <dd class="font-bold text-gray-900">{pioInfo.name}</dd>
            </div>
            <div class="pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Designation</dt>
              <dd class="text-sm text-gray-700">{pioInfo.designation}</dd>
            </div>
            <div class="pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Institution</dt>
              <dd class="text-sm text-gray-700">{pioInfo.institution}</dd>
            </div>
            <div class="pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Address</dt>
              <dd class="text-sm text-gray-700 leading-relaxed">{pioInfo.address}</dd>
            </div>
            <div class="pb-3 border-b border-blue-200">
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Phone / Mobile</dt>
              <dd class="text-sm text-gray-700">{pioInfo.phone} / {pioInfo.mobile}</dd>
            </div>
            <div>
              <dt class="text-xs font-semibold text-gray-500 uppercase mb-0.5">Email</dt>
              <dd><a href={`mailto:${pioInfo.email}`} class="text-sm text-primary hover:underline">{pioInfo.email}</a></dd>
            </div>
          </dl>
        </div>
        <div class="space-y-5">
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <h3 class="font-bold text-gray-900 mb-3">First Appellate Authority</h3>
            <p class="text-sm font-medium text-gray-700 mb-2">{appellateInfo.body}</p>
            <p class="text-sm text-gray-600 leading-relaxed mb-3">{appellateInfo.address}</p>
            <a href={appellateInfo.website} target="_blank" rel="noopener noreferrer" class="text-sm text-primary hover:underline flex items-center gap-1 font-medium">
              Official Website →
            </a>
          </div>
          <div class="bg-yellow-50 rounded-2xl border border-yellow-200 p-6">
            <h3 class="font-bold text-yellow-900 mb-3">How to File an RTI</h3>
            <ol class="space-y-2">
              {["Write your application in English, Hindi, or Gujarati", "Submit to PIO with ₹10/- fee (IPO/DD not required for online)", "You will receive a response within 30 days", "Appeal to First Appellate Authority if unsatisfied"].map((step, i) => (
                <li class="flex items-start gap-2.5 text-sm text-yellow-800">
                  <span class="w-5 h-5 rounded-full bg-yellow-400 text-white flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5">{i+1}</span>
                  {step}
                </li>
              ))}
            </ol>
            <a
              href="https://rtionline.gov.in/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 mt-4 text-sm font-medium text-yellow-700 underline hover:text-yellow-900"
            >
              File RTI Online →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Fee Structure -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">RTI Fee Structure</h2>
      <div class="overflow-x-auto bg-white rounded-xl border border-gray-200 shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Type</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Amount</th>
              <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase">Payment Mode</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rtiFees.map((f) => (
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm font-medium text-gray-900">{f.method}</td>
                <td class="px-6 py-4 text-sm font-bold text-primary">{f.amount}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{f.mode}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Sections & Proactive Disclosure -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Key RTI Act Provisions</h2>
          <div class="space-y-4">
            {rtiSections.map((s) => (
              <div class="flex gap-4 p-4 rounded-xl border border-gray-200 bg-gray-50">
                <span class="px-2 py-1 rounded bg-primary text-white text-xs font-bold flex-shrink-0 h-fit">{s.sec}</span>
                <div>
                  <h4 class="font-bold text-gray-900 text-sm mb-1">{s.title}</h4>
                  <p class="text-xs text-gray-600 leading-relaxed">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">Proactive Disclosure (Sec. 4)</h2>
          <p class="text-sm text-gray-600 mb-4">
            As per Section 4 of the RTI Act, Government Polytechnic Palanpur proactively discloses the following information:
          </p>
          <ul class="grid grid-cols-1 gap-2">
            {disclosureItems.map((item) => (
              <li class="flex items-center gap-2.5 text-sm text-gray-700 p-2 rounded-lg hover:bg-gray-50">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
