---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const stats = [
  { label: "Companies Visited (2024)", value: "30+" },
  { label: "Students Placed (2024)", value: "150+" },
  { label: "Highest Package", value: "₹4.5 LPA" },
  { label: "Average Package", value: "₹2.8 LPA" },
];

const topRecruiters = [
  { name: "L&T Construction", sector: "Civil / Infrastructure" },
  { name: "Torrent Power", sector: "Electrical" },
  { name: "GSRTC", sector: "Mechanical / Automobile" },
  { name: "Adani Group", sector: "Multi-sector" },
  { name: "Suzlon Energy", sector: "Electrical / Mechanical" },
  { name: "Tata Projects", sector: "Civil / Mechanical" },
  { name: "Gujarat Gas", sector: "Mechanical / Chemical" },
  { name: "BCM Computers", sector: "Computer / IT" },
  { name: "Syntel (TriSura)", sector: "Computer / IT" },
  { name: "Reliance Industries", sector: "Multi-sector" },
  { name: "GNFC", sector: "Chemical / Mechanical" },
  { name: "ONGC", sector: "Mechanical / Electrical" },
];

const placementProcess = [
  {
    step: "1",
    title: "Registration",
    desc: "Eligible final-year diploma students register with the TPO cell. Eligibility criteria vary by company.",
  },
  {
    step: "2",
    title: "Company Invitation",
    desc: "TPO invites companies through letters, emails, and industry contacts. Companies submit JD and selection process details.",
  },
  {
    step: "3",
    title: "Pre-Placement Talk",
    desc: "Company representatives visit the campus to brief students about job roles, culture, and opportunities.",
  },
  {
    step: "4",
    title: "Selection Process",
    desc: "Written aptitude tests, group discussions, and technical + HR interviews are conducted on campus.",
  },
  {
    step: "5",
    title: "Offer Letter",
    desc: "Selected candidates receive offer letters. TPO facilitates coordination between students and the company.",
  },
  {
    step: "6",
    title: "Joining",
    desc: "Students join after completing their final semester examinations and degree formalities.",
  },
];

const yearwiseData = [
  { year: "2023–24", companies: 28, placed: 142, highest: "₹4.5 LPA", avg: "₹2.8 LPA" },
  { year: "2022–23", companies: 22, placed: 118, highest: "₹4.0 LPA", avg: "₹2.5 LPA" },
  { year: "2021–22", companies: 18, placed: 95, highest: "₹3.6 LPA", avg: "₹2.2 LPA" },
  { year: "2020–21", companies: 14, placed: 76, highest: "₹3.2 LPA", avg: "₹2.0 LPA" },
];
---

<Layout title="Placements | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Placements</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Placements</h1>
      <p class="text-lg text-gray-600">Connecting GPP diploma graduates with leading industries across Gujarat and India</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{s.value}</div>
            <div class="text-sm mt-1 text-white/80">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Year-wise Data -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Year-wise Placement Statistics</h2>
      <div class="overflow-x-auto rounded-xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Academic Year</th>
              <th class="px-5 py-3 font-semibold text-center">Companies</th>
              <th class="px-5 py-3 font-semibold text-center">Students Placed</th>
              <th class="px-5 py-3 font-semibold text-center">Highest Package</th>
              <th class="px-5 py-3 font-semibold text-center">Average Package</th>
            </tr>
          </thead>
          <tbody>
            {yearwiseData.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">{row.year}</td>
                <td class="px-5 py-3 text-gray-700 text-center">{row.companies}</td>
                <td class="px-5 py-3 text-gray-700 text-center">{row.placed}</td>
                <td class="px-5 py-3 text-green-700 font-semibold text-center">{row.highest}</td>
                <td class="px-5 py-3 text-gray-700 text-center">{row.avg}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Placement Process -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Placement Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {placementProcess.map(p => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white font-bold text-lg mb-4">
              {p.step}
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{p.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Top Recruiters -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Top Recruiters</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topRecruiters.map(r => (
          <div class="flex items-center gap-4 bg-gray-50 rounded-xl px-5 py-4 border border-gray-100 hover:border-primary/30 transition-colors">
            <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">{r.name}</div>
              <div class="text-xs text-gray-500">{r.sector}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Recruit from GPP</h2>
      <p class="text-gray-600 mb-6">Interested in recruiting diploma engineers from Government Polytechnic Palanpur? Contact our Training & Placement Office to schedule a campus drive.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/tpo" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">Contact TPO</a>
        <a href="/campus-life/campus-drive" class="border border-primary text-primary px-6 py-3 rounded-lg font-semibold hover:bg-primary/5 transition-colors">View Campus Drives</a>
        <a href="/about/allAchievements" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">Dept-wise Results</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
