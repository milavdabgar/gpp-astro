---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import AnnouncementTicker from '../components/AnnouncementTicker.astro';

const stats = [
  { label: "Final-Year Students (2025-26)", value: "65" },
  { label: "Placed in Industry (2025-26)", value: "9" },
  { label: "Pursuing Higher Studies", value: "55" },
  { label: "Placement Officer", value: "N.V. Oza" },
];

const topRecruiters = [
  { name: "L&T Construction", sector: "Civil / Infrastructure" },
  { name: "Torrent Power", sector: "Electrical" },
  { name: "GSRTC", sector: "Mechanical / Automobile" },
  { name: "Adani Group", sector: "Multi-sector" },
  { name: "Suzlon Energy", sector: "Electrical / Mechanical" },
  { name: "Tata Projects", sector: "Civil / Mechanical" },
  { name: "Gujarat Gas", sector: "Mechanical / Chemical" },
  { name: "BCM Computers", sector: "Computer / IT" },
  { name: "Syntel (TriSura)", sector: "Computer / IT" },
  { name: "Reliance Industries", sector: "Multi-sector" },
  { name: "GNFC", sector: "Chemical / Mechanical" },
  { name: "ONGC", sector: "Mechanical / Electrical" },
];

const placementProcess = [
  {
    step: "1",
    title: "Registration",
    desc: "Eligible final-year diploma students register with the TPO cell. Eligibility criteria vary by company.",
  },
  {
    step: "2",
    title: "Company Invitation",
    desc: "TPO invites companies through letters, emails, and industry contacts. Companies submit JD and selection process details.",
  },
  {
    step: "3",
    title: "Pre-Placement Talk",
    desc: "Company representatives visit the campus to brief students about job roles, culture, and opportunities.",
  },
  {
    step: "4",
    title: "Selection Process",
    desc: "Written aptitude tests, group discussions, and technical + HR interviews are conducted on campus.",
  },
  {
    step: "5",
    title: "Offer Letter",
    desc: "Selected candidates receive offer letters. TPO facilitates coordination between students and the company.",
  },
  {
    step: "6",
    title: "Joining",
    desc: "Students join after completing their final semester examinations and degree formalities.",
  },
];

// Placement data from GTU Affiliation Report 2026-27 (§9 Examination/Training/Placement)
const placementData2526 = [
  { branch: "Civil Engineering",                        code: "CE",  inBranch: 21, industry: 0,  higherStudy: 21, entrepreneur: 0 },
  { branch: "Electrical Engineering",                   code: "EE",  inBranch: 25, industry: 5,  higherStudy: 20, entrepreneur: 0 },
  { branch: "Mechanical Engineering",                   code: "ME",  inBranch: 13, industry: 4,  higherStudy: 9,  entrepreneur: 0 },
  { branch: "Electronics & Communication Engineering",  code: "EC",  inBranch: 3,  industry: 0,  higherStudy: 2,  entrepreneur: 0 },
  { branch: "Information & Communication Technology",   code: "ICT", inBranch: 3,  industry: 0,  higherStudy: 3,  entrepreneur: 0 },
];
const totalInBranch   = placementData2526.reduce((s, r) => s + r.inBranch, 0);
const totalIndustry   = placementData2526.reduce((s, r) => s + r.industry, 0);
const totalHigher     = placementData2526.reduce((s, r) => s + r.higherStudy, 0);

const tpo = {
  name:  "Shri N.V. Oza",
  email: "gpptpo@gmail.com",
  phone: "02742 262115",
  mobile: "9067737576",
};
---

<Layout title="Placements | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>&rsaquo;</span>
        <span class="text-gray-900 font-medium">Placements</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-14">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-full mb-6">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Placements</h1>
      <p class="text-lg text-gray-600">Connecting GPP diploma graduates with leading industries across Gujarat and India</p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-primary py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{s.value}</div>
            <div class="text-sm mt-1 text-white/80">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 2025-26 Placement Data -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="mb-6">
        <h2 class="text-3xl font-bold text-gray-900 mb-1">Branch-wise Placement Outcomes — AY 2025-26</h2>
        <p class="text-gray-500 text-sm">Source: GTU Affiliation Application 2026-27 (§9 Training & Placement). Covers final-year (Sem 6) graduating batch.</p>
      </div>
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-primary text-white text-left">
              <th class="px-5 py-3 font-semibold">Branch</th>
              <th class="px-5 py-3 font-semibold text-center">In Branch</th>
              <th class="px-5 py-3 font-semibold text-center">Placed (Industry)</th>
              <th class="px-5 py-3 font-semibold text-center">Higher Studies</th>
              <th class="px-5 py-3 font-semibold text-center">Entrepreneur</th>
            </tr>
          </thead>
          <tbody>
            {placementData2526.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 font-medium text-gray-900">
                  <span class="text-xs bg-gray-100 text-gray-600 font-semibold rounded px-1.5 py-0.5 mr-1.5">{row.code}</span>
                  {row.branch}
                </td>
                <td class="px-5 py-3 text-gray-700 text-center font-semibold">{row.inBranch}</td>
                <td class="px-5 py-3 text-center">
                  <span class={`font-bold ${row.industry > 0 ? 'text-green-600' : 'text-gray-400'}`}>{row.industry}</span>
                </td>
                <td class="px-5 py-3 text-center">
                  <span class={`font-bold ${row.higherStudy > 0 ? 'text-blue-600' : 'text-gray-400'}`}>{row.higherStudy}</span>
                </td>
                <td class="px-5 py-3 text-gray-400 text-center">{row.entrepreneur}</td>
              </tr>
            ))}
            <tr class="bg-primary/5 border-t-2 border-primary/20 font-bold">
              <td class="px-5 py-3 text-gray-900">Total</td>
              <td class="px-5 py-3 text-center text-gray-900">{totalInBranch}</td>
              <td class="px-5 py-3 text-center text-green-700">{totalIndustry}</td>
              <td class="px-5 py-3 text-center text-blue-700">{totalHigher}</td>
              <td class="px-5 py-3 text-center text-gray-400">0</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-gray-400">Note: IT department graduates (2025-26) are completing their 3rd year; placement data will be available in the next cycle. IT dept started 2023-24.</p>
    </div>
  </section>

  <!-- Placement Process -->
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Placement Process</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {placementProcess.map(p => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center text-white font-bold text-lg mb-4">
              {p.step}
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{p.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Top Recruiters -->
  <section class="py-14 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Top Recruiters</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {topRecruiters.map(r => (
          <div class="flex items-center gap-4 bg-gray-50 rounded-xl px-5 py-4 border border-gray-100 hover:border-primary/30 transition-colors">
            <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 text-sm">{r.name}</div>
              <div class="text-xs text-gray-500">{r.sector}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-primary/5">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Recruit from GPP</h2>
        <p class="text-gray-600">Interested in recruiting diploma engineers from Government Polytechnic Palanpur? Contact our Training & Placement Officer directly.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mb-6">
        <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wide text-primary">Training & Placement Officer</h3>
        <div class="grid sm:grid-cols-2 gap-4 text-sm">
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Name</div>
            <div class="font-semibold text-gray-900">{tpo.name}</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Email</div>
            <a href={`mailto:${tpo.email}`} class="text-primary hover:underline">{tpo.email}</a>
          </div>
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Phone</div>
            <a href={`tel:${tpo.phone}`} class="text-gray-700">{tpo.phone}</a>
          </div>
          <div>
            <div class="text-xs text-gray-500 mb-0.5">Mobile</div>
            <a href={`tel:${tpo.mobile}`} class="text-gray-700">{tpo.mobile}</a>
          </div>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/tpo" class="bg-primary text-white px-6 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors">TPO Page</a>
        <a href="/campus-life/campus-drive" class="border border-primary text-primary px-6 py-3 rounded-lg font-semibold hover:bg-primary/5 transition-colors">View Campus Drives</a>
        <a href="/student-section/results" class="border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-semibold hover:bg-gray-50 transition-colors">Academic Results</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
