---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AnnouncementTicker from '../../components/AnnouncementTicker.astro';
import { getSortedAnnouncements } from '../../data/announcements';

const items = getSortedAnnouncements();

const categoryStyles: Record<string, string> = {
  admission:     "bg-blue-100 text-blue-800 border-blue-200",
  exam:          "bg-amber-100 text-amber-800 border-amber-200",
  recruitment:   "bg-green-100 text-green-800 border-green-200",
  event:         "bg-purple-100 text-purple-800 border-purple-200",
  result:        "bg-rose-100 text-rose-800 border-rose-200",
  scholarship:   "bg-teal-100 text-teal-800 border-teal-200",
  accreditation: "bg-indigo-100 text-indigo-800 border-indigo-200",
  general:       "bg-gray-100 text-gray-700 border-gray-200",
};

const categoryLabels: Record<string, string> = {
  admission:     "Admission",
  exam:          "Examination",
  recruitment:   "Recruitment",
  event:         "Events",
  result:        "Results",
  scholarship:   "Scholarship / SSIP",
  accreditation: "NBA Accreditation",
  general:       "General",
};
---

<Layout
  title="Announcements | Government Polytechnic Palanpur"
  description="Latest announcements, notices, and updates from Government Polytechnic Palanpur."
>
  <Nav />
  <AnnouncementTicker />

  <main class="flex-1 bg-gray-50 min-h-screen">
    <!-- Page header -->
    <section class="bg-primary/5 py-10 border-b border-gray-200">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3 mb-2">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
          </svg>
          <h1 class="text-3xl font-bold text-gray-900">Announcements</h1>
        </div>
        <p class="text-gray-600 max-w-xl">
          Latest notices, updates, and important information from Government Polytechnic Palanpur.
        </p>
      </div>
    </section>

    <!-- List -->
    <section class="py-10">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
        {items.length === 0 ? (
          <p class="text-center text-gray-500 py-20">No announcements at the moment. Please check back later.</p>
        ) : (
          <ul class="space-y-3">
            {items.map(ann => (
              <li>
                {ann.hasDetailPage ? (
                  <a
                    href={`/announcements/${ann.slug}`}
                    class="group flex items-start gap-4 rounded-xl bg-white border border-gray-200 p-5 hover:border-primary/50 hover:shadow-sm transition-all"
                  >
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        {ann.isNew && (
                          <span class="inline-flex items-center rounded-sm bg-primary px-1.5 py-px text-[10px] font-bold text-white uppercase tracking-wider">NEW</span>
                        )}
                        <span class={`inline-flex items-center gap-1 rounded-full border px-2 py-px text-[11px] font-semibold capitalize ${categoryStyles[ann.category] ?? categoryStyles.general}`}>
                          {categoryLabels[ann.category] ?? ann.category}
                        </span>
                        <span class="flex items-center gap-1 text-xs text-gray-400">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                          {ann.date}
                        </span>
                      </div>
                      <p class="text-sm sm:text-base font-medium text-gray-800 group-hover:text-primary transition-colors">
                        {ann.title}
                      </p>
                    </div>
                    <svg class="w-5 h-5 text-gray-300 group-hover:text-primary flex-shrink-0 mt-0.5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                ) : (
                  <div class="flex items-start gap-4 rounded-xl bg-white border border-gray-200 p-5">
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <span class={`inline-flex items-center gap-1 rounded-full border px-2 py-px text-[11px] font-semibold capitalize ${categoryStyles[ann.category] ?? categoryStyles.general}`}>
                          {categoryLabels[ann.category] ?? ann.category}
                        </span>
                        <span class="flex items-center gap-1 text-xs text-gray-400">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                          {ann.date}
                        </span>
                      </div>
                      <p class="text-sm sm:text-base font-medium text-gray-800">{ann.title}</p>
                    </div>
                  </div>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
