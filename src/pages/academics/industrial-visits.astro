---

<Layout title="Industrial Visits | Academics | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span class="hover:text-primary transition-colors">Academics</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Industrial Visits</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Industry–Academia Connect
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Industrial Visits</h1>
      <p class="text-gray-600 text-lg">
        Hands-on exposure to real-world industrial settings — bridging classroom learning with professional practice.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {stats.map(s => (
          <div class="text-center">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={s.icon}/>
              </svg>
            </div>
            <div class="text-2xl font-bold text-gray-900">{s.value}</div>
            <div class="text-xs text-gray-500 mt-0.5">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Filter Controls -->
  <section class="bg-gray-50 border-b border-gray-200 py-4 sticky top-0 z-30">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class="text-sm font-medium text-gray-600 shrink-0">Filter by:</span>

        <!-- Department Filter -->
        <div class="flex flex-wrap gap-1.5" id="dept-filters">
          <button onclick="filterVisits('dept', 'all')" data-dept="all"
            class="filter-dept-btn px-3 py-1 rounded-full text-xs font-medium bg-primary text-white transition-colors">
            All Depts
          </button>
          {depts.map(d => (
            <button onclick={`filterVisits('dept', '${d}')`} data-dept={d}
              class="filter-dept-btn px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-300 text-gray-700 hover:border-primary hover:text-primary transition-colors">
              {d}
            </button>
          ))}
        </div>

        <!-- Year Filter -->
        <div class="flex flex-wrap gap-1.5 ml-auto" id="year-filters">
          <button onclick="filterVisits('year', 'all')" data-year="all"
            class="filter-year-btn px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-300 text-gray-700 hover:border-primary hover:text-primary transition-colors">
            All Years
          </button>
          {years.map(y => (
            <button onclick={`filterVisits('year', '${y}')`} data-year={String(y)}
              class="filter-year-btn px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-300 text-gray-700 hover:border-primary hover:text-primary transition-colors">
              {y}
            </button>
          ))}
        </div>
      </div>
      <div class="mt-2 text-xs text-gray-500">
        Showing <span id="visible-count">{visits.length}</span> visits
      </div>
    </div>
  </section>

  <!-- Table -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm" id="visits-table">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 text-left font-semibold">#</th>
              <th class="px-4 py-3 text-left font-semibold">Department</th>
              <th class="px-4 py-3 text-left font-semibold">Industry / Site Visited</th>
              <th class="px-4 py-3 text-center font-semibold">Date</th>
              <th class="px-4 py-3 text-center font-semibold">Sem</th>
              <th class="px-4 py-3 text-center font-semibold">Students</th>
            </tr>
          </thead>
          <tbody>
            {visits.map((v, i) => (
              <tr
                class={`visit-row ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'} hover:bg-blue-50 transition-colors`}
                data-dept={v.dept}
                data-year={v.year}
              >
                <td class="px-4 py-3 text-gray-400 text-xs">{v.id}</td>
                <td class="px-4 py-3">
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${deptColors[v.dept] ?? 'bg-gray-100 text-gray-700'}`}>
                    {v.dept}
                  </span>
                </td>
                <td class="px-4 py-3 font-medium text-gray-900">{v.industry}</td>
                <td class="px-4 py-3 text-center text-gray-600 whitespace-nowrap">{v.date}</td>
                <td class="px-4 py-3 text-center text-gray-600">{v.sem}</td>
                <td class="px-4 py-3 text-center font-semibold text-gray-900">{v.students}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Empty state -->
      <div id="visits-empty" class="hidden text-center py-16 text-gray-400">
        <svg class="w-10 h-10 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-sm">No visits found for the selected filter.</p>
      </div>
    </div>
  </section>

  <!-- About Industrial Visits -->
  <section class="py-10 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-xl font-bold text-gray-900 mb-4">About Our Industrial Visit Programme</h2>
          <p class="text-gray-600 text-sm leading-relaxed mb-3">
            Industrial visits are a mandatory component of the GTU Diploma curriculum. Students from all departments undertake field visits to local industries, construction sites, research institutions, and infrastructure projects to gain first-hand operational knowledge.
          </p>
          <p class="text-gray-600 text-sm leading-relaxed">
            These visits cover a broad spectrum — from dairy processing plants (Banas Dairy) and precision manufacturing (Sahajanand Laser Tech) to power substations (220KV Sadarpur), civic infrastructure (WDFC Project Site), and research labs (IPR Gandhinagar, PDPU-SGP Lab).
          </p>
        </div>
        <div class="space-y-3">
          <h3 class="font-bold text-gray-900 text-sm">Key Industry Partners</h3>
          {[
            { name: "Banas Dairy, Palanpur", tag: "Food Processing" },
            { name: "Sahajanand Laser Technology, Gandhinagar", tag: "Manufacturing" },
            { name: "220KV Substation Sadarpur", tag: "Power Sector" },
            { name: "IPR Gandhinagar / PDPU-SGP Lab", tag: "Research" },
            { name: "WDFC Project Site", tag: "Infrastructure" },
            { name: "Community Radio Station Palanpur", tag: "Media / Telecom" },
            { name: "Netram Command & Control Centre", tag: "Technology" },
          ].map(p => (
            <div class="flex items-center gap-3 bg-white border border-gray-200 rounded-lg px-4 py-2.5">
              <div class="w-2 h-2 rounded-full bg-primary shrink-0"></div>
              <span class="text-sm font-medium text-gray-900 flex-1">{p.name}</span>
              <span class="text-xs text-gray-400">{p.tag}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
let activeDept = 'all';
let activeYear = 'all';

function filterVisits(type, value) {
  if (type === 'dept') activeDept = value;
  if (type === 'year') activeYear = value;

  // Update button styles
  document.querySelectorAll('.filter-dept-btn').forEach(btn => {
    const isActive = btn.dataset.dept === activeDept;
    btn.classList.toggle('bg-primary', isActive);
    btn.classList.toggle('text-white', isActive);
    btn.classList.toggle('bg-white', !isActive);
    btn.classList.toggle('border', !isActive);
    btn.classList.toggle('border-gray-300', !isActive);
    btn.classList.toggle('text-gray-700', !isActive);
  });
  document.querySelectorAll('.filter-year-btn').forEach(btn => {
    const isActive = btn.dataset.year === activeYear;
    btn.classList.toggle('bg-primary', isActive);
    btn.classList.toggle('text-white', isActive);
    btn.classList.toggle('bg-white', !isActive);
    btn.classList.toggle('border', !isActive);
    btn.classList.toggle('border-gray-300', !isActive);
    btn.classList.toggle('text-gray-700', !isActive);
  });

  let visible = 0;
  document.querySelectorAll('.visit-row').forEach(row => {
    const deptMatch = activeDept === 'all' || row.dataset.dept === activeDept;
    const yearMatch = activeYear === 'all' || row.dataset.year === activeYear;
    const show = deptMatch && yearMatch;
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });

  document.getElementById('visible-count').textContent = visible;
  document.getElementById('visits-empty').classList.toggle('hidden', visible > 0);
}
</script>
