---

<Layout title="Faculty Development Programs | Academics | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span>Academics</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Faculty Development Programs</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-emerald-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Continuous Professional Development
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Faculty Development Programs</h1>
      <p class="text-gray-600 text-lg">
        GPP faculty members continually upgrade their skills through national programs at premier institutions — IITs, NITTTR Bhopal, GTU, and global MOOC platforms.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-5 max-w-5xl mx-auto text-center">
        <div>
          <div class="text-3xl font-bold text-primary">{totalFDP}+</div>
          <div class="text-sm text-gray-500 mt-1">FDP Participations</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">5</div>
          <div class="text-sm text-gray-500 mt-1">Years Covered</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">25+</div>
          <div class="text-sm text-gray-500 mt-1">Faculty Trained</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">12+</div>
          <div class="text-sm text-gray-500 mt-1">Host Institutions</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">40+</div>
          <div class="text-sm text-gray-500 mt-1">Unique Topics</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Faculty Activities Summary -->
  <section class="py-8 bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Faculty Activities at a Glance</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-white border border-gray-200 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-gray-900">Workshops Attended</div>
              <div class="text-sm text-gray-500">External professional workshops</div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-2">
            <div class="bg-orange-50 rounded-lg p-3 text-center">
              <div class="text-2xl font-bold text-orange-700">70</div>
              <div class="text-xs text-orange-600">Participations</div>
            </div>
            <div class="bg-orange-50 rounded-lg p-3 text-center">
              <div class="text-2xl font-bold text-orange-700">18</div>
              <div class="text-xs text-orange-600">Faculty Members</div>
            </div>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-gray-900">FDPs Attended</div>
              <div class="text-sm text-gray-500">Faculty Development Programs</div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-2">
            <div class="bg-emerald-50 rounded-lg p-3 text-center">
              <div class="text-2xl font-bold text-emerald-700">89</div>
              <div class="text-xs text-emerald-600">Participations</div>
            </div>
            <div class="bg-emerald-50 rounded-lg p-3 text-center">
              <div class="text-2xl font-bold text-emerald-700">25</div>
              <div class="text-xs text-emerald-600">Faculty Members</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Participants -->
  <section class="py-8 bg-white border-b border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Faculty with Most FDP Participations</h2>
      <div class="grid md:grid-cols-2 gap-3">
        {topFaculty.map((f, i) => (
          <div class="flex items-center gap-3">
            <span class={`w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0 ${i < 3 ? 'bg-yellow-400 text-yellow-900' : 'bg-gray-100 text-gray-600'}`}>
              {i + 1}
            </span>
            <div class="flex-1">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-semibold text-gray-900">{f.name}</span>
                <span class="text-xs font-bold text-primary">{f.count} FDPs</span>
              </div>
              <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-primary rounded-full" style={`width: ${Math.round((f.count / topFaculty[0].count) * 100)}%`}></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FDP List grouped by Host -->
  <section class="py-10 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">FDP Programs by Host Institution</h2>
      <div class="space-y-6">
        {fdpGroups.map(group => (
          <div class={`border ${borderMap[group.color]} rounded-2xl overflow-hidden bg-white`}>
            <!-- Group Header -->
            <div class={`${headMap[group.color]} px-6 py-4 flex items-center justify-between`}>
              <div class="flex items-center gap-3">
                <span class={`px-3 py-1 rounded-full text-xs font-bold ${colorMap[group.color]}`}>{group.count} FDPs</span>
                <h3 class="font-bold text-gray-900 text-lg">{group.host}</h3>
              </div>
            </div>
            <!-- Entries Table -->
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 border-b border-gray-100 text-left text-xs text-gray-500 uppercase tracking-wide">
                    <th class="px-4 py-2 font-semibold">Faculty</th>
                    <th class="px-4 py-2 font-semibold">Topic / Program</th>
                    <th class="px-4 py-2 font-semibold">Platform</th>
                    <th class="px-4 py-2 font-semibold text-center">Year</th>
                  </tr>
                </thead>
                <tbody>
                  {group.entries.map((e, idx) => (
                    <tr class={`border-b border-gray-50 ${idx % 2 === 0 ? '' : 'bg-gray-50/50'} hover:bg-primary/5 transition-colors`}>
                      <td class="px-4 py-2.5 font-medium text-gray-900 whitespace-nowrap">{e.faculty}</td>
                      <td class="px-4 py-2.5 text-gray-700">{e.topic}</td>
                      <td class="px-4 py-2.5 text-gray-500 whitespace-nowrap">{e.platform}</td>
                      <td class="px-4 py-2.5 text-center">
                        <span class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs font-medium">{e.year}</span>
                      </td>
                    </tr>
                  ))}
                  {group.count > group.entries.length && (
                    <tr class={`${headMap[group.color]}`}>
                      <td colspan="4" class="px-4 py-2.5 text-sm text-gray-500 text-center italic">
                        + {group.count - group.entries.length} additional records on file (total {group.count} FDPs for this institution)
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>

