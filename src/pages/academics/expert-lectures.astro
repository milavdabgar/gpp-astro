---

<Layout title="Expert Lectures | Academics | Government Polytechnic Palanpur">
  <Nav />
  <AnnouncementTicker />

  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-gray-500 flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span>›</span>
        <span class="text-gray-600">Academics</span>
        <span>›</span>
        <span class="text-gray-900 font-medium">Expert Lectures</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 to-blue-50 py-12">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 px-4 py-1.5 rounded-full text-sm font-medium mb-4">
        Industry &amp; Academia Connect
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Expert Lectures</h1>
      <p class="text-gray-600 text-lg">
        Eminent professionals from industry and academia share cutting-edge knowledge with GPP students through invited talks, workshops, and seminars.
      </p>
    </div>
  </section>

  <!-- Stats Banner -->
  <section class="bg-white border-b border-gray-200 py-8">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto text-center">
        <div>
          <div class="text-3xl font-bold text-primary">{lectures.length}</div>
          <div class="text-sm text-gray-500 mt-1">Expert Lectures</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{totalOrgs}</div>
          <div class="text-sm text-gray-500 mt-1">Organisations</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{years.length}</div>
          <div class="text-sm text-gray-500 mt-1">Years (2021–2025)</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">5+</div>
          <div class="text-sm text-gray-500 mt-1">Disciplines Covered</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Year filter -->
  <section class="bg-gray-50 border-b sticky top-0 z-30 py-3">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-sm font-medium text-gray-600 shrink-0">Year:</span>
        <button onclick="filterYear('all')" data-year="all"
          class="yr-btn px-3 py-1 rounded-full text-xs font-semibold bg-primary text-white">All</button>
        {years.map(y => (
          <button onclick={`filterYear(${y})`} data-year={String(y)}
            class="yr-btn px-3 py-1 rounded-full text-xs font-semibold bg-white border border-gray-300 text-gray-700 hover:border-primary hover:text-primary transition-colors">
            {y}
          </button>
        ))}
        <span class="ml-auto text-xs text-gray-500">Showing <span id="lec-count">{lectures.length}</span> lectures</span>
      </div>
    </div>
  </section>

  <!-- Lectures Grid -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="lectures-grid">
        {lectures.map(lec => (
          <div class="lec-card border border-gray-200 rounded-xl p-5 hover:border-primary/40 hover:shadow-md transition-all" data-year={lec.year}>
            <!-- Topic -->
            <h3 class="font-bold text-gray-900 text-sm mb-1 leading-snug">{lec.topic}</h3>

            <!-- Speaker -->
            <div class="mt-3 flex items-start gap-2.5">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900">{lec.name}</p>
                <p class="text-xs text-gray-500">{lec.designation}</p>
              </div>
            </div>

            <!-- Org & date -->
            <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between">
              <span class="text-xs text-gray-600 flex items-center gap-1">
                <svg class="w-3 h-3 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
                </svg>
                <span class="line-clamp-1">{lec.org}</span>
              </span>
              <span class="text-xs text-gray-400 shrink-0 ml-2">{lec.date}</span>
            </div>
          </div>
        ))}
      </div>

      <div id="lec-empty" class="hidden text-center py-16 text-gray-400">
        <p class="text-sm">No lectures found for selected year.</p>
      </div>
    </div>
  </section>

  <!-- About Expert Lectures -->
  <section class="py-10 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Notable Visiting Experts</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {[
          { name: "Mr. Prakash Darji", role: "Design Engineer", org: "Google Bangalore", topic: "Future of Electronics in Industries" },
          { name: "Mr. Nishant Patel",  role: "Application Engineer", org: "Synopsys Inc., California", topic: "VLSI Low Power Techniques" },
          { name: "Mr. Pranav Dave",   role: "Associate Consultant", org: "TCS Gandhinagar", topic: "Importance of Programming" },
          { name: "Dr. V K Thakar",    role: "Dean, Indrashil University", org: "Indrashil University", topic: "Internet of Things" },
          { name: "Mr. Vishal Vadher",  role: "Asst. Manager Training", org: "Sofcon India Pvt. Ltd.", topic: "AI-ML – A New Era of Future" },
          { name: "Mr. Krishna Panchal", role: "Associate Engineer", org: "E-Infochips", topic: "Career Guidance for EC Engineers" },
        ].map(e => (
          <div class="bg-white border border-gray-200 rounded-xl p-4 flex gap-3 items-start">
            <div class="w-9 h-9 bg-purple-100 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-4 h-4 text-purple-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div>
              <p class="font-bold text-gray-900 text-sm">{e.name}</p>
              <p class="text-xs text-gray-500">{e.role} · {e.org}</p>
              <p class="text-xs text-primary mt-1 font-medium">"{e.topic}"</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
function filterYear(year) {
  document.querySelectorAll('.yr-btn').forEach(btn => {
    const active = btn.dataset.year === String(year);
    btn.classList.toggle('bg-primary', active);
    btn.classList.toggle('text-white', active);
    btn.classList.toggle('bg-white', !active);
    btn.classList.toggle('border', !active);
    btn.classList.toggle('border-gray-300', !active);
    btn.classList.toggle('text-gray-700', !active);
  });

  let count = 0;
  document.querySelectorAll('.lec-card').forEach(card => {
    const show = year === 'all' || parseInt(card.dataset.year) === year;
    card.style.display = show ? '' : 'none';
    if (show) count++;
  });
  document.getElementById('lec-count').textContent = count;
  document.getElementById('lec-empty').classList.toggle('hidden', count > 0);
}
</script>
